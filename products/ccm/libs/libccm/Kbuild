# =============================================================================
# libccm 库构建配置
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 构建目标配置
# -----------------------------------------------------------------------------
# 静态库
lib-y += ccm

# 动态库
so-y += ccm

# -----------------------------------------------------------------------------
# 2. 源文件列表
# -----------------------------------------------------------------------------
ccm-objs := \
	src/libccm_ipc.o \
	src/libccm_protocol.o

# -----------------------------------------------------------------------------
# 3. 编译标志
# -----------------------------------------------------------------------------
ccflags-y += -I$(src)/include
ccflags-y += -I$(srctree)/core/osal/include
ccflags-y += -I$(srctree)/core/hal/include
ccflags-y += -I$(srctree)/include

# 动态库需要 -fPIC
ccm-cflags-y := -fPIC

# -----------------------------------------------------------------------------
# 4. 链接标志
# -----------------------------------------------------------------------------
# 动态库链接标志
ccm-ldflags := -shared -Wl$(comma)-soname$(comma)libccm.so.1
ccm-ldflags += -L$(objtree)/lib -losal

# -----------------------------------------------------------------------------
# 5. 头文件导出
# -----------------------------------------------------------------------------
header-y := ccm_common.h ccm_utils.h

# -----------------------------------------------------------------------------
# 6. 清理规则
# -----------------------------------------------------------------------------
clean-files := *.so *.so.* *.a
