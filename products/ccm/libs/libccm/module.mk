# =============================================================================
# libccm 模块非递归 Make 配置
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 基础源文件
# -----------------------------------------------------------------------------
libccm_SRCS := \
	products/ccm/libs/libccm/src/libccm_ipc.c \
	products/ccm/libs/libccm/src/libccm_protocol.c

# -----------------------------------------------------------------------------
# 2. 编译标志
# -----------------------------------------------------------------------------
libccm_CFLAGS := \
	-Iinclude/libccm \
	-Iinclude/osal

# -----------------------------------------------------------------------------
# 3. 链接标志
# -----------------------------------------------------------------------------
libccm_LDFLAGS := \
	-L$(STAGING_DIR)/lib \
	-Wl,--no-as-needed \
	-losal \
	-Wl,--as-needed \
	-lpthread

# -----------------------------------------------------------------------------
# 4. 生成目标文件列表
# -----------------------------------------------------------------------------
libccm_OBJS := $(call srcs_to_objs,$(libccm_SRCS))

# -----------------------------------------------------------------------------
# 5. 定义目标
# -----------------------------------------------------------------------------
libccm_TARGET := $(STAGING_DIR)/lib/libccm.so
ALL_TARGETS += $(libccm_TARGET)

# -----------------------------------------------------------------------------
# 6. 添加编译标志到全局
# -----------------------------------------------------------------------------
$(libccm_OBJS): CFLAGS += $(libccm_CFLAGS)

# -----------------------------------------------------------------------------
# 7. 定义构建规则
# -----------------------------------------------------------------------------
$(eval $(call build_shared_lib,$(libccm_TARGET),$(libccm_OBJS),$(libccm_LDFLAGS)))

# -----------------------------------------------------------------------------
# 8. 依赖关系
# -----------------------------------------------------------------------------
# libccm 依赖 osal
$(libccm_TARGET): $(STAGING_DIR)/lib/libosal.so

# -----------------------------------------------------------------------------
# 9. 清理规则
# -----------------------------------------------------------------------------
CLEAN_TARGETS += $(libccm_OBJS) $(libccm_TARGET)
