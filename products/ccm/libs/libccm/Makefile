# =============================================================================
# libccm 库构建配置
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 构建目标配置
# -----------------------------------------------------------------------------
# 静态库
lib-y += ccm

# 动态库
so-y += ccm

# -----------------------------------------------------------------------------
# 2. 源文件列表
# -----------------------------------------------------------------------------
ccm-objs := \
	src/libccm_ipc.o \
	src/libccm_protocol.o

# -----------------------------------------------------------------------------
# 3. 编译标志
# -----------------------------------------------------------------------------
# 通用编译标志（引用统一的 include 目录）
ccflags-y += -I$(srctree)/include/libccm
ccflags-y += -I$(srctree)/include/osal

# 动态库需要 -fPIC
ccm-cflags-y := -fPIC

# -----------------------------------------------------------------------------
# 4. 链接标志
# -----------------------------------------------------------------------------
# 动态库链接标志
ccm-ldflags := -shared -Wl$(comma)-soname$(comma)libccm.so.1
ccm-ldflags += -L$(LIB_DIR) -losal

# -----------------------------------------------------------------------------
# 5. 清理规则
# -----------------------------------------------------------------------------
clean-files := *.so *.so.* *.a
