# ============================================================================
# CCM Product Configuration
# ============================================================================
# CCM (Central Control Module) is a satellite payload control and data
# management system designed for H200 platform with AM625 SoC.
# ============================================================================

menu "CCM Product"

# ============================================================================
# Platform Configuration
# ============================================================================

menu "Platform Configuration"

choice
    prompt "Select Platform"
    default PROJECT_H200_100P_AM625
    help
      Select the hardware platform for CCM product.

config PROJECT_H200_100P_AM625
    bool "H200 100P AM625 Platform"
    help
      TI AM625 SoC based H200 100P carrier board.
      Provides ACONFIG and PCONFIG configuration for AM625 platform.

config PROJECT_H200_200P
    bool "H200 200P Platform"
    help
      H200 200P platform configuration.

endchoice

# Note: PROJECT_NAME is defined globally in the root Config.in
# It automatically derives the correct value based on the platform choice above.

endmenu

# ============================================================================
# Product Components
# ============================================================================

menu "Product Libraries"

source "products/ccm/libs/libccm/Config.in"

endmenu

# ============================================================================
# Applications
# ============================================================================

menu "Applications"

source "products/ccm/apps/app_collector/Config.in"
source "products/ccm/apps/app_comm/Config.in"
source "products/ccm/apps/app_health/Config.in"
source "products/ccm/apps/app_logger/Config.in"
source "products/ccm/apps/app_supervisor/Config.in"

# Test Application (Debug/Verification)
source "products/ccm/apps/test_call_chain/Config.in"

endmenu

endmenu
