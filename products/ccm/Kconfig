# ============================================================================
# CCM Product Configuration
# ============================================================================
# CCM (Central Control Module) is a satellite payload control and data
# management system designed for H200 platform with AM625 SoC.
# ============================================================================

menu "CCM Product"

# ============================================================================
# Platform Configuration
# ============================================================================

menu "Platform Configuration"

config H200_AM625
    bool "H200 AM625 Platform"
    default y
    help
      Enable H200 AM625 platform configuration.
      This provides ACL and PCL configuration data for TI AM625 SoC.

endmenu

# ============================================================================
# Product Components
# ============================================================================

menu "Product Components"

osource "$SDK_PATH/products/ccm/components/libccm/Kconfig"

endmenu

# ============================================================================
# Applications
# ============================================================================

menu "Applications"

osource "$SDK_PATH/products/ccm/apps/app_collector/Kconfig"
osource "$SDK_PATH/products/ccm/apps/app_comm/Kconfig"
osource "$SDK_PATH/products/ccm/apps/app_health/Kconfig"
osource "$SDK_PATH/products/ccm/apps/app_logger/Kconfig"
osource "$SDK_PATH/products/ccm/apps/app_supervisor/Kconfig"

endmenu

endmenu
