# ============================================================================
# CCM Product Configuration
# ============================================================================
# CCM (Central Control Module) is a satellite payload control and data
# management system designed for H200 platform with AM625 SoC.
# ============================================================================

menu "CCM Product"

# ============================================================================
# Platform Configuration
# ============================================================================

menu "Platform Configuration"

choice
    prompt "Select Platform"
    default PROJECT_H200_100P_AM625
    help
      Select the hardware platform for CCM product.

config PROJECT_H200_100P_AM625
    bool "H200 100P AM625 Platform"
    help
      TI AM625 SoC based H200 100P carrier board.
      Provides ACL and PCL configuration for AM625 platform.

config PROJECT_H200_200P
    bool "H200 200P Platform"
    help
      H200 200P platform configuration.

endchoice

config PROJECT_NAME
    string
    default "h200_100p_am625" if PROJECT_H200_100P_AM625
    default "h200_200p" if PROJECT_H200_200P
    help
      Project configuration directory name.
      Used by CMake to locate platform config files.

endmenu

# ============================================================================
# Product Components
# ============================================================================

menu "Product Libraries"

source "products/ccm/libs/libccm/Kconfig"

endmenu

# ============================================================================
# Applications
# ============================================================================

menu "Applications"

source "products/ccm/apps/app_collector/Kconfig"
source "products/ccm/apps/app_comm/Kconfig"
source "products/ccm/apps/app_health/Kconfig"
source "products/ccm/apps/app_logger/Kconfig"
source "products/ccm/apps/app_supervisor/Kconfig"

endmenu

endmenu
