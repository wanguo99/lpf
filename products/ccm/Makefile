# =============================================================================
# CCM 产品构建配置
# =============================================================================

# 禁止并行构建子目录，因为 apps 依赖 libs 和 h200_am625 的输出
# 在递归 make + PHONY 目标的组合下，普通依赖声明无法保证构建顺序
.NOTPARALLEL:

# -----------------------------------------------------------------------------
# 1. 子目录构建顺序
# -----------------------------------------------------------------------------
# 按依赖关系排列：libs -> h200_am625 -> apps

obj-y += libs/
obj-y += h200_am625/
obj-y += apps/

# 定义子目录之间的依赖关系
# 问题：在并行构建时，PHONY 目标的依赖关系不能保证递归 make 的输出文件已完成
# 解决方案：使用 order-only prerequisites 强制顺序
# apps 必须在 libs 和 h200_am625 的递归 make 完成后才能开始
apps/: | libs/ h200_am625/
