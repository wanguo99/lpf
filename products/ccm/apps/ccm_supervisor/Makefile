# =============================================================================
# CCM Supervisor 应用构建配置
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 可执行程序目标
# -----------------------------------------------------------------------------
app-y += ccm_supervisor

# -----------------------------------------------------------------------------
# 2. 源文件列表
# -----------------------------------------------------------------------------
ccm_supervisor-objs := \
	src/main.o \
	src/ccm_supervisor.o

# -----------------------------------------------------------------------------
# 3. 编译标志
# -----------------------------------------------------------------------------
ccflags-y += -I$(src)/include
# 引用统一的 include 目录
ccflags-y += -I$(srctree)/include/libccm
ccflags-y += -I$(srctree)/include/acl
ccflags-y += -I$(srctree)/include/pdl
ccflags-y += -I$(srctree)/include/pcl
ccflags-y += -I$(srctree)/include/hal
ccflags-y += -I$(srctree)/include/osal

# -----------------------------------------------------------------------------
# 4. 链接标志
# -----------------------------------------------------------------------------
ccm_supervisor-ldflags := -L$(LIB_DIR)
ccm_supervisor-ldflags += -Wl,-rpath,$$ORIGIN/../lib
ccm_supervisor-ldflags += -lh200_am625 -lccm
ccm_supervisor-ldflags += -lacl -lpdl -lpcl -lhal -losal

# -----------------------------------------------------------------------------
# 5. 清理规则
# -----------------------------------------------------------------------------
clean-files := ccm_supervisor
