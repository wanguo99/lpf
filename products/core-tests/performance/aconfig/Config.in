# ACL Performance Test Configuration
#
# Measures application configuration layer performance.
# Tests telecommand/telemetry mapping and processing speed.

if TEST_PERFORMANCE_ACL

menu "ACL Performance Tests"

config TEST_PERF_ACL_TC
	bool "Telecommand processing performance tests"
	default n
	help
	  Telecommand mapping and validation speed benchmarks.

	  Measures:
	    - TC ID lookup latency
	    - Parameter validation overhead
	    - Command routing performance
	    - TC queue processing throughput

	  Runtime: 2-3 seconds
	  Hardware: None
	  Dependencies: CONFIG_ACL
	  Tags: performance, telecommand
	  Test file: test_perf_aconfig_tc.c

config TEST_PERF_ACL_TM
	bool "Telemetry collection performance tests"
	default n
	help
	  Telemetry mapping and collection speed benchmarks.

	  Measures:
	    - TM ID lookup latency
	    - Data format conversion overhead
	    - Telemetry aggregation performance
	    - High-frequency sampling throughput

	  Runtime: 2-3 seconds
	  Hardware: None
	  Dependencies: CONFIG_ACL
	  Tags: performance, telemetry
	  Test file: test_perf_aconfig_tm.c

endmenu

endif # TEST_PERFORMANCE_ACL
