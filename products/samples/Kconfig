# 示例模块配置

config MYLIB
	bool "Enable mylib (sample library)"
	default n
	help
	  This is a sample library template.
	  Copy and modify it to create your own library.

if MYLIB

config MYLIB_BUILD_STATIC
	bool "Build static library"
	default y
	help
	  Build libmylib.a static library.

config MYLIB_BUILD_SHARED
	bool "Build shared library"
	default y
	help
	  Build libmylib.so shared library.

endif # MYLIB

config BUILD_MYAPP
	bool "Build myapp (sample application)"
	default n
	help
	  This is a sample application template.
	  Copy and modify it to create your own application.
