# PCONFIG System Test Configuration
#
# Platform configuration layer integration tests.
# Tests PCONFIG with underlying HAL and PDL components.

if TEST_SYSTEM_PCONFIG

menu "PCONFIG System Tests"

config TEST_SYSTEM_PCONFIG_HAL
	bool "PCONFIG + HAL integration tests"
	default n
	help
	  Platform configuration with HAL driver initialization.

	  Tests:
	    - Device tree → HAL driver initialization
	    - Pin configuration application
	    - Clock configuration validation
	    - Bus parameters (baud rate, speed)
	    - Hardware resource allocation

	  Verifies:
	    - HAL drivers initialized per config
	    - Correct parameter application
	    - Configuration validation errors caught
	    - Resource allocation correctness

	  Runtime: 3-5 seconds
	  Hardware: Mock devices
	  Dependencies: CONFIG_PCONFIG, CONFIG_HAL
	  Tags: integration, config, hal
	  Test file: test_system_pconfig_hal.c

config TEST_SYSTEM_PCONFIG_PDL
	bool "PCONFIG + PDL integration tests"
	default n
	help
	  Platform configuration with PDL device mapping.

	  Tests:
	    - Device configuration → PDL device creation
	    - Device ID mapping
	    - Protocol parameter configuration
	    - Multi-device setup from config
	    - Configuration update without restart

	  Verifies:
	    - PDL devices match configuration
	    - Correct device ID assignment
	    - Protocol parameters applied
	    - Dynamic reconfiguration support

	  Runtime: 3-5 seconds
	  Hardware: Mock devices
	  Dependencies: CONFIG_PCONFIG, CONFIG_PDL
	  Tags: integration, config, pdl
	  Test file: test_system_pconfig_pdl.c

config TEST_SYSTEM_PCONFIG_RUNTIME
	bool "Runtime configuration change tests"
	default n
	help
	  Dynamic configuration changes at runtime.

	  Tests:
	    - Hot-reload configuration files
	    - Device reconfiguration without restart
	    - Configuration rollback on error
	    - Partial configuration updates
	    - Configuration validation before apply

	  Verifies:
	    - Safe runtime reconfiguration
	    - No device state corruption
	    - Correct rollback behavior
	    - Validation prevents bad config

	  Runtime: 5-10 seconds
	  Hardware: Mock devices
	  Dependencies: CONFIG_PCONFIG
	  Tags: integration, config, dynamic
	  Test file: test_system_pconfig_runtime.c

endmenu

endif # TEST_SYSTEM_PCONFIG
