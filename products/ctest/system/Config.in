# System Test Configuration
#
# System tests verify integration and interaction between multiple components.
# Tests cross-layer functionality and end-to-end scenarios.
#
# Organization:
#   - system/Config.in (this file) - Entry point, sources layer configs
#   - system/osal/Config.in - OSAL system/integration tests
#   - system/hal/Config.in - HAL system/integration tests
#   - system/pdl/Config.in - PDL system/integration tests
#   - system/pconfig/Config.in - PCONFIG system/integration tests
#   - system/aconfig/Config.in - ACONFIG system/integration tests
#   - system/integration/Config.in - Full stack integration tests

if TEST_SYSTEM

menu "System Tests"

config TEST_SYSTEM_ALL
	bool "Enable all system tests"
	default y
	select TEST_SYSTEM_OSAL if TEST_OSAL
	select TEST_SYSTEM_HAL if TEST_HAL
	select TEST_SYSTEM_PDL if TEST_PDL
	select TEST_SYSTEM_PRL if TEST_PRL
	select TEST_SYSTEM_PCONFIG if TEST_PCONFIG
	select TEST_SYSTEM_ACONFIG if TEST_ACONFIG
	select TEST_SYSTEM_ACONFIG if CONFIG_ACONFIG
	select TEST_SYSTEM_PCONFIG if CONFIG_PCONFIG
	select TEST_INTEGRATION
	help
	  Enable all system and integration tests at once.
	  Disabling this allows individual layer selection below.

	  System tests verify:
	    - Cross-module integration
	    - End-to-end data flow
	    - Real-world usage scenarios
	    - Multi-component interactions
	    - System-level error handling

	  Runtime: Varies by test (typically 5-30 seconds per test)
	  Tags: slow, integration, system

# Source layer-specific Config.in files
if TEST_OSAL
	source "products/ctest/system/osal/Config.in"
endif

if TEST_HAL
	source "products/ctest/system/hal/Config.in"
endif

if TEST_PDL
	source "products/ctest/system/pdl/Config.in"
endif

if TEST_PRL
	source "products/ctest/system/prl/Config.in"
endif

if CONFIG_PCONFIG
	source "products/ctest/system/pconfig/Config.in"
endif

if CONFIG_ACONFIG
	source "products/ctest/system/aconfig/Config.in"
endif

# Integration tests (full stack)
source "products/ctest/system/integration/Config.in"

endmenu

endif # TEST_SYSTEM
