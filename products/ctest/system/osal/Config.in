# OSAL System Test Configuration
#
# Cross-module integration tests for OSAL components.
# Tests interactions between multiple OSAL subsystems.

if TEST_SYSTEM_OSAL

menu "OSAL System Tests"

config TEST_SYSTEM_OSAL_CORE
	bool "Core system integration tests"
	default y
	help
	  Core OSAL system integration tests.

	  Tests:
	    - Multi-thread coordination (producer-consumer)
	    - IPC end-to-end (threads + shared memory + semaphores)
	    - Resource management full flow (allocation/use/cleanup)
	    - System startup/shutdown flow (worker threads lifecycle)

	  Verifies:
	    - Correct synchronization across subsystems
	    - Resource lifecycle management
	    - Graceful startup and shutdown
	    - No resource leaks

	  Runtime: 5-10 seconds
	  Hardware: None
	  Dependencies: CONFIG_OSAL
	  Tags: integration, core, lifecycle
	  Test file: test_system_osal.c

config TEST_SYSTEM_OSAL_THREADING_IPC
	bool "Thread + IPC integration tests"
	default y
	help
	  Integration tests for threading with IPC mechanisms.

	  Tests:
	    - Producer-consumer pattern with condition variables
	    - Thread pool with semaphore coordination
	    - Shared memory access from multiple threads
	    - Condition variable wakeup patterns

	  Verifies:
	    - Correct thread synchronization
	    - IPC data integrity
	    - Deadlock-free operation
	    - Wakeup reliability

	  Runtime: 10-15 seconds
	  Hardware: None
	  Dependencies: CONFIG_OSAL
	  Tags: integration, threading, ipc
	  Test file: test_system_osal_threading_ipc.c

config TEST_SYSTEM_OSAL_FILE_THREAD
	bool "File I/O + Threading integration tests"
	default y
	help
	  Concurrent file operations from multiple threads.

	  Tests:
	    - Multiple threads reading same file
	    - Multiple threads writing to separate files
	    - File locking coordination
	    - File position tracking per thread
	    - File descriptor cleanup

	  Verifies:
	    - Thread-safe file operations
	    - No file corruption
	    - Correct file position tracking
	    - Proper fd cleanup

	  Runtime: 10-15 seconds
	  Hardware: Requires filesystem
	  Dependencies: CONFIG_OSAL
	  Tags: integration, filesystem, threading
	  Test file: test_system_osal_file_thread.c

config TEST_SYSTEM_OSAL_PROCESS_IPC
	bool "Process + IPC integration tests"
	default n
	help
	  Inter-process communication tests.

	  Tests:
	    - Parent-child communication via pipes
	    - Shared memory between processes
	    - Semaphore-based process synchronization
	    - Signal-based process coordination
	    - Process group operations

	  Verifies:
	    - Correct IPC across process boundaries
	    - Process cleanup on exit
	    - Signal delivery to processes
	    - Shared resource cleanup

	  Runtime: 15-20 seconds
	  Hardware: None
	  Dependencies: CONFIG_OSAL
	  Tags: integration, process, ipc
	  Test file: test_system_osal_process_ipc.c

	  Note: Disabled by default as it requires fork() which may
	        not be available in all environments.

config TEST_SYSTEM_OSAL_REALTIME
	bool "Real-time scheduling integration tests"
	default n
	help
	  Real-time thread scheduling and priority tests.

	  Tests:
	    - RT thread priority enforcement
	    - Priority inheritance with mutexes
	    - CPU affinity with RT threads
	    - RT thread + Timer interaction
	    - Scheduler policy interactions

	  Verifies:
	    - Priority ordering correctness
	    - Priority inversion avoidance
	    - Deterministic wakeup latency
	    - CPU affinity enforcement

	  Runtime: 10-15 seconds
	  Hardware: None (RT scheduler may not be available)
	  Dependencies: CONFIG_OSAL
	  Tags: integration, realtime, scheduling
	  Test file: test_system_osal_realtime.c

	  Note: Disabled by default as RT features may require
	        root privileges or RT kernel.

endmenu

endif # TEST_SYSTEM_OSAL
