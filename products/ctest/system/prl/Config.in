# PRL System Test Configuration
#
# System integration tests for PRL protocol layer.
# Tests realistic communication scenarios and interaction with other layers.

if TEST_SYSTEM_PRL

menu "PRL System Tests"

config TEST_SYSTEM_PRL_REQUEST_RESPONSE
	bool "Request-response communication pattern"
	default y
	help
	  End-to-end request-response communication scenarios.

	  Tests:
	    - PMC → MCU request with response
	    - PMC → PMC telemetry request
	    - GSC → Multiple devices queries
	    - ACK flag handling in request-response
	    - Sequence number correlation
	    - Timeout and retry scenarios

	  Verifies:
	    - Complete encode-decode-response cycle
	    - PRL_BuildResponse correctness
	    - Sequence number preservation in responses
	    - Flag handling (NEED_ACK/IS_ACK)
	    - Response payload integrity

	  Runtime: 2-5 seconds
	  Dependencies: CONFIG_PRL
	  Tags: integration, prl, request-response
	  Test file: test_system_prl_request_response.c

config TEST_SYSTEM_PRL_ROUTING
	bool "Packet routing and fast extraction"
	default y
	help
	  Packet routing using fast extraction APIs.

	  Tests:
	    - Multi-device packet routing by device type
	    - Fast device/message type extraction
	    - Sequence-based deduplication
	    - Routing table lookup simulation
	    - High-frequency packet classification

	  Verifies:
	    - PRL_GetDeviceType performance
	    - PRL_GetMessageType accuracy
	    - PRL_GetSequence for duplicate detection
	    - PRL_ValidatePacket for quick validation
	    - Routing decisions without full decode

	  Runtime: 2-5 seconds
	  Dependencies: CONFIG_PRL
	  Tags: integration, prl, routing, performance
	  Test file: test_system_prl_routing.c

config TEST_SYSTEM_PRL_MULTIDEVICE
	bool "Multi-device concurrent communication"
	default y
	help
	  Concurrent communication between multiple devices.

	  Tests:
	    - Simultaneous MCU, PMC, PMC, GSC communication
	    - Interleaved encode/decode operations
	    - Device type isolation
	    - Concurrent sequence number generation
	    - Message type diversity handling

	  Verifies:
	    - No cross-device interference
	    - Sequence numbers remain unique
	    - Device type routing correctness
	    - Thread-safe sequence generation
	    - Message integrity under concurrency

	  Runtime: 3-8 seconds
	  Dependencies: CONFIG_PRL, TEST_OSAL
	  Tags: integration, prl, concurrency, multidevice
	  Test file: test_system_prl_multidevice.c

config TEST_SYSTEM_PRL_ERROR_RECOVERY
	bool "Error handling and recovery scenarios"
	default y
	help
	  Error injection and recovery testing.

	  Tests:
	    - Corrupted packet handling
	    - Invalid device type rejection
	    - CRC mismatch detection
	    - Buffer overflow protection
	    - Partial packet handling
	    - Protocol version mismatch

	  Verifies:
	    - Graceful error handling
	    - Error code correctness
	    - PRL_GetErrorString accuracy
	    - System stability after errors
	    - No resource leaks on errors

	  Runtime: 2-5 seconds
	  Dependencies: CONFIG_PRL
	  Tags: integration, prl, error, robustness
	  Test file: test_system_prl_error_recovery.c

config TEST_SYSTEM_PRL_LIFECYCLE
	bool "Module lifecycle and state management"
	default y
	help
	  PRL initialization, operation, and cleanup.

	  Tests:
	    - PRL_Init → operations → PRL_Deinit cycle
	    - Multiple init/deinit cycles
	    - Operations without explicit init
	    - Sequence number persistence across init
	    - PRL_ResetSequence functionality
	    - PRL_GetCurrentSequence accuracy

	  Verifies:
	    - Proper resource initialization
	    - Clean shutdown without leaks
	    - State consistency across lifecycle
	    - Sequence number management
	    - Module re-initialization safety

	  Runtime: 1-3 seconds
	  Dependencies: CONFIG_PRL
	  Tags: integration, prl, lifecycle
	  Test file: test_system_prl_lifecycle.c

config TEST_SYSTEM_PRL_PROTOCOL_STACK
	bool "Full protocol stack integration (HAL + PRL)"
	default n
	depends on TEST_HAL
	help
	  Integration with HAL layer for realistic communication.

	  Tests:
	    - PRL encode → HAL CAN transmit simulation
	    - HAL CAN receive → PRL decode
	    - PRL encode → HAL UART transmit simulation
	    - End-to-end data flow through layers
	    - Protocol overhead measurement

	  Verifies:
	    - Seamless HAL/PRL integration
	    - No data corruption between layers
	    - Proper buffer management
	    - Performance characteristics
	    - Real-world usage patterns

	  Runtime: 3-8 seconds
	  Hardware: Mock HAL CAN/UART
	  Dependencies: CONFIG_PRL, CONFIG_HAL
	  Tags: integration, prl, hal, stack
	  Test file: test_system_prl_protocol_stack.c

endmenu

endif # TEST_SYSTEM_PRL
