# ACONFIG Stress Test Configuration
#
# Tests application configuration layer under extreme conditions.
# Verifies concurrent access, performance baselines, and stability.

menu "ACONFIG Stress Tests"

config TEST_STRESS_ACONFIG
	bool "ACONFIG comprehensive stress tests"
	default y
	help
	  Comprehensive stress testing for ACONFIG module.

	  Includes:
	    - Concurrent query operations (TC/TM)
	    - Large table performance baseline
	    - Long-running stability tests
	    - High-frequency throughput tests

	  Tests thread-safety, performance, and memory stability
	  under various stress conditions.

	  Runtime: 30-60 seconds total
	  Hardware: None (in-memory only)
	  Dependencies: CONFIG_ACONFIG
	  Tags: stress, concurrency, performance
	  Test file: test_stress_aconfig.c

config TEST_STRESS_ACONFIG_CONCURRENT
	bool "Concurrent query stress tests"
	default y
	help
	  Multi-threaded concurrent query operations.

	  Tests:
	    - TC query from 10+ concurrent threads
	    - TM query from 10+ concurrent threads
	    - Mixed TC/TM queries (16 threads)
	    - Statistics query from 8 threads
	    - 10000+ iterations per thread

	  Verifies:
	    - Thread-safe read operations
	    - rwlock correctness
	    - No race conditions
	    - 99.9%+ success rate
	    - Zero errors under load

	  Runtime: 5-15 seconds
	  Hardware: None (in-memory only)
	  Dependencies: CONFIG_ACONFIG
	  Tags: stress, concurrency, thread-safety
	  Test file: test_stress_aconfig.c

config TEST_STRESS_ACONFIG_PERFORMANCE
	bool "Large table performance tests"
	default y
	help
	  Performance baseline for O(n) sparse array lookup.

	  Tests:
	    - 100 TC entries, 200 TM entries
	    - Random access patterns
	    - 4 threads, 1000 iterations
	    - Latency measurement per query

	  Verifies:
	    - O(n) lookup behavior
	    - Acceptable average latency
	    - Performance consistency
	    - No performance cliffs

	  Runtime: 5-10 seconds
	  Hardware: None
	  Dependencies: CONFIG_ACONFIG
	  Tags: stress, performance, baseline
	  Test file: test_stress_aconfig.c

config TEST_STRESS_ACONFIG_STABILITY
	bool "Long-running stability tests"
	default y
	help
	  Extended duration operation for leak detection.

	  Tests:
	    - 10 second continuous operation
	    - 8 threads mixed queries
	    - Memory stability monitoring
	    - Resource leak detection

	  Verifies:
	    - No memory leaks
	    - Consistent performance over time
	    - 99.9%+ success rate
	    - System stability

	  Runtime: 10-15 seconds
	  Hardware: None
	  Dependencies: CONFIG_ACONFIG
	  Tags: stress, stability, leak-detection
	  Test file: test_stress_aconfig.c

config TEST_STRESS_ACONFIG_THROUGHPUT
	bool "High-frequency throughput tests"
	default y
	help
	  Maximum query throughput measurement.

	  Tests:
	    - 20 threads, 50000 iterations
	    - High-frequency mixed queries
	    - Operations per second measurement

	  Verifies:
	    - Sustained high throughput
	    - 99.9%+ success rate
	    - Throughput baseline established

	  Runtime: 10-20 seconds
	  Hardware: None
	  Dependencies: CONFIG_ACONFIG
	  Tags: stress, performance, throughput
	  Test file: test_stress_aconfig.c

endmenu
