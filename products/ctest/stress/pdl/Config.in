# PDL Stress Test Configuration
#
# Tests PDL device drivers under high load and error conditions.
# Verifies device protocol stability and error recovery.

if TEST_STRESS_PDL

menu "PDL Stress Tests"

config TEST_STRESS_PDL_MCU_LONG_RUNNING
	bool "MCU long-running query stress"
	default y
	depends on PDL_MCU_SUPPORT
	help
	  MCU status query stress test over extended duration.

	  Tests:
	    - Single thread continuous status queries
	    - 30 second duration
	    - Query every 10ms
	    - Timeout handling

	  Verifies:
	    - Long-running operation stability
	    - Memory leak freedom
	    - Success rate > 90%
	    - Timeout recovery

	  Runtime: ~30 seconds
	  Hardware: MCU device (CAN/Serial)
	  Dependencies: CONFIG_PDL_MCU_SUPPORT
	  Tags: stress, pdl, duration
	  Test function: test_stress_mcu_long_running_query

config TEST_STRESS_PDL_PMC_CONCURRENT
	bool "PMC concurrent communication stress"
	default y
	depends on PDL_PMC_SUPPORT
	help
	  PMC communication concurrent stress test.

	  Tests:
	    - 6 threads concurrently sending commands
	    - 10 second duration
	    - Send every 50ms per thread
	    - Ethernet protocol

	  Verifies:
	    - Thread-safe command sending
	    - Network protocol stability
	    - Success rate > 90%
	    - Connection management under load

	  Runtime: ~10 seconds
	  Hardware: PMC Ethernet interface
	  Dependencies: CONFIG_PDL_PMC_SUPPORT
	  Tags: stress, pdl, concurrency, network
	  Test function: test_stress_pmc_concurrent_communication

config TEST_STRESS_PDL_MULTIDEVICE
	bool "Multi-device mixed operations stress"
	default y
	depends on PDL_MCU_SUPPORT
	help
	  Multi-device concurrent mixed operations stress test.

	  Tests:
	    - 4 threads alternating MCU operations
	    - 20 second duration
	    - Interleaved device access
	    - Shared resource management

	  Verifies:
	    - Device independence (no interference)
	    - Thread-safe multi-device access
	    - Success rate > 85%
	    - Resource management correctness

	  Runtime: ~20 seconds
	  Hardware: MCU devices
	  Dependencies: CONFIG_PDL_MCU_SUPPORT
	  Tags: stress, pdl, multidevice, integration
	  Test function: test_stress_multidevice_mixed

config TEST_STRESS_PDL_RESOURCE_EXHAUSTION
	bool "Resource exhaustion and memory leak detection"
	default y
	depends on PDL_MCU_SUPPORT
	help
	  Resource exhaustion and memory leak detection test.

	  Tests:
	    - 1000 iterations of init/deinit cycles
	    - Memory allocation/deallocation
	    - File descriptor management
	    - Resource cleanup verification

	  Verifies:
	    - No memory leaks
	    - Proper resource cleanup
	    - No file descriptor leaks
	    - Stable repeated init/deinit

	  Runtime: ~10-20 seconds
	  Hardware: MCU device (any interface)
	  Dependencies: CONFIG_PDL_MCU_SUPPORT
	  Tags: stress, pdl, memory, resource
	  Test function: test_stress_resource_exhaustion

endmenu

endif # TEST_STRESS_PDL
