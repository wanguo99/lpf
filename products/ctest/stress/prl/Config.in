# PRL Stress Test Configuration
#
# Tests PRL protocol layer under extreme load and resource pressure.
# Verifies encoding/decoding performance, concurrency safety, and stability.

if TEST_STRESS_PRL

menu "PRL Stress Tests"

config TEST_STRESS_PRL_ENCODE_HIGH_FREQUENCY
	bool "High-frequency encoding stress test"
	default y
	help
	  Rapidly encode packets from multiple threads.

	  Tests:
	    - 16 threads encoding packets simultaneously
	    - 10 second sustained encoding operations
	    - Medium-sized payloads (1KB)
	    - Automatic sequence number management
	    - Thread-safe encode operations

	  Verifies:
	    - No encoding errors under load
	    - Sequence number correctness
	    - Timestamp generation
	    - CRC calculation accuracy
	    - Thread safety of PRL_Encode

	  Metrics:
	    - Total successful encodes
	    - Throughput (ops/sec)
	    - Success rate (should be >99.9%)

	  Runtime: ~10 seconds
	  Hardware: None
	  Dependencies: CONFIG_PRL
	  Tags: stress, prl, encoding, concurrency
	  Test function: test_stress_encode_high_frequency

config TEST_STRESS_PRL_ROUNDTRIP_CONCURRENCY
	bool "Encode-decode round-trip concurrency test"
	default y
	help
	  Full encode-decode cycle under concurrent load.

	  Tests:
	    - 8 threads performing encode+decode cycles
	    - 10,000 iterations per thread (80K total)
	    - Small payloads (64 bytes)
	    - Data integrity verification
	    - Zero-copy decode payload extraction

	  Verifies:
	    - Encode-decode correctness
	    - Payload data integrity
	    - Device type preservation
	    - Message type preservation
	    - Flag handling (NEED_ACK)
	    - No data corruption under concurrency

	  Metrics:
	    - Total encode/decode operations
	    - Error count (should be 0)
	    - Data mismatch detection

	  Runtime: ~15 seconds
	  Hardware: None
	  Dependencies: CONFIG_PRL
	  Tags: stress, prl, roundtrip, concurrency
	  Test function: test_stress_roundtrip_concurrency

config TEST_STRESS_PRL_LARGE_PAYLOAD
	bool "Large payload sustained load test"
	default y
	help
	  Maximum payload size encoding under continuous load.

	  Tests:
	    - 4 threads encoding large packets
	    - 1,000 iterations per thread
	    - Maximum payload size (4096 bytes)
	    - Memory allocation/deallocation per iteration
	    - Sustained high memory bandwidth

	  Verifies:
	    - Large payload handling correctness
	    - No memory leaks
	    - Buffer overflow protection
	    - Performance with maximum packet size

	  Metrics:
	    - Total packets encoded
	    - Total data processed (MB)
	    - Memory allocation success rate

	  Runtime: ~20 seconds
	  Hardware: Sufficient memory (several MB)
	  Dependencies: CONFIG_PRL
	  Tags: stress, prl, memory, heavy
	  Test function: test_stress_large_payload

config TEST_STRESS_PRL_FAST_EXTRACTION
	bool "Fast extraction API performance test"
	default y
	help
	  High-frequency use of routing APIs without full decode.

	  Tests:
	    - 16 threads using fast extraction APIs
	    - 5 second sustained operations
	    - PRL_GetDeviceType() - routing
	    - PRL_GetMessageType() - filtering
	    - PRL_GetSequence() - deduplication
	    - No CRC verification (fast path)

	  Verifies:
	    - Fast extraction correctness
	    - Performance benefit vs full decode
	    - Thread safety of fast APIs
	    - Use case: packet routing

	  Metrics:
	    - Total extraction operations (3 per iteration)
	    - Throughput (ops/sec)
	    - Success rate

	  Runtime: ~5 seconds
	  Hardware: None
	  Dependencies: CONFIG_PRL
	  Tags: stress, prl, performance, routing
	  Test function: test_stress_fast_extraction

config TEST_STRESS_PRL_RESPONSE_BUILDING
	bool "Response building under load test"
	default y
	help
	  PRL_BuildResponse API stress testing.

	  Tests:
	    - 8 threads building responses
	    - 10,000 iterations per thread
	    - Request-response pattern simulation
	    - Automatic ACK flag setting
	    - Sequence number preservation

	  Verifies:
	    - Response building correctness
	    - ACK flag is set automatically
	    - Device/message type extraction from request
	    - Sequence number preservation
	    - Common request-response use case

	  Metrics:
	    - Total responses built
	    - Error count
	    - Throughput

	  Runtime: ~10 seconds
	  Hardware: None
	  Dependencies: CONFIG_PRL
	  Tags: stress, prl, response, protocol
	  Test function: test_stress_response_building

config TEST_STRESS_PRL_SEQUENCE_ROLLOVER
	bool "Sequence number rollover test"
	default y
	help
	  Verify sequence number behavior at UINT32_MAX boundary.

	  Tests:
	    - Reset sequence to UINT32_MAX - 100
	    - Encode 200 packets across rollover
	    - Extract and verify sequence numbers
	    - Check rollover from 0xFFFFFFFF to 0x00000000

	  Verifies:
	    - Sequence increment at boundary
	    - No overflow errors
	    - Rollover behavior correctness
	    - Long-running system scenario

	  Metrics:
	    - Sequence values before/after rollover
	    - Rollover detection

	  Runtime: <1 second
	  Hardware: None
	  Dependencies: CONFIG_PRL
	  Tags: stress, prl, sequence, boundary
	  Test function: test_stress_sequence_rollover

config TEST_STRESS_PRL_LONG_RUNNING
	bool "Long-running stability test"
	default n
	help
	  Extended duration test for stability and leak detection.

	  Tests:
	    - 4 threads performing round-trip operations
	    - 30 second sustained test
	    - Continuous encode-decode cycles
	    - Memory leak detection
	    - Performance degradation check

	  Verifies:
	    - No memory leaks over time
	    - No resource exhaustion
	    - Stable performance
	    - No error accumulation
	    - System remains responsive

	  Metrics:
	    - Total operations (encode + decode)
	    - Average throughput over duration
	    - Error rate over time
	    - Memory usage (external monitoring)

	  Runtime: ~30 seconds (SLOW)
	  Hardware: None
	  Dependencies: CONFIG_PRL
	  Tags: stress, prl, stability, slow, heavy
	  Test function: test_stress_long_running

endmenu

endif # TEST_STRESS_PRL
