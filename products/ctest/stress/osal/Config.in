# OSAL Stress Test Configuration
#
# Tests OSAL components under extreme load and resource pressure.
# Verifies stability, leak-free operation, and graceful degradation.

config TEST_STRESS_OSAL
	bool "OSAL stress tests"
	depends on TEST_STRESS && TEST_OSAL
	default y if TEST_STRESS_ALL
	help
	  Comprehensive stress tests for OSAL layer.

	  Test scenarios:
	    - Atomic operations under high contention (20+ threads)
	    - Mutex lock contention (50+ threads competing)
	    - Semaphore rapid post/wait cycles
	    - Condition variable signaling storms
	    - Thread creation/destruction stress (100+ threads)
	    - Memory allocation/deallocation cycles
	    - Time operations from multiple threads
	    - String operations under concurrency
	    - File I/O concurrent access
	    - CRC computation performance
	    - Mixed operations workload

	  Verifies:
	    - Correctness under concurrent access
	    - No memory leaks during stress
	    - No deadlocks or race conditions
	    - Performance characteristics (throughput, latency)
	    - Graceful handling of resource limits
	    - System stability after stress

	  Test count: 11 stress scenarios
	  Runtime: ~90 seconds total
	  Hardware: None (uses /tmp for file tests)
	  Dependencies: CONFIG_OSAL
	  Tags: stress, concurrency, performance, slow

if TEST_STRESS_OSAL

menu "OSAL Stress Test Options"

config TEST_STRESS_OSAL_THREAD_COUNT
	int "Default thread count for concurrency tests"
	default 20
	range 1 200
	help
	  Number of concurrent threads to use in stress tests.

	  Higher values create more contention but may hit system limits.
	  Recommended: 10-50 for typical systems, 20 is balanced.

config TEST_STRESS_OSAL_DURATION_SEC
	int "Default duration for time-based tests (seconds)"
	default 10
	range 1 300
	help
	  How long to run each time-based stress test.

	  Longer durations better detect memory leaks and rare race conditions.
	  Recommended: 5-30 seconds, 10 is balanced.

config TEST_STRESS_OSAL_ITERATIONS
	int "Default iterations for count-based tests"
	default 10000
	range 100 10000000
	help
	  Number of iterations for count-based stress tests.

	  Higher values provide better statistical confidence.
	  Recommended: 1000-100000, 10000 is balanced.

config TEST_STRESS_OSAL_VERBOSE
	bool "Enable verbose output during stress tests"
	default n
	help
	  Print detailed progress and metrics during test execution.

	  Useful for debugging but increases test runtime.
	  Disable for CI/CD pipelines.

config TEST_STRESS_OSAL_ATOMIC
	bool "Atomic operations stress"
	default y
	help
	  Test atomic operations under high contention.

	  Scenarios:
	    - Concurrent atomic_inc from 20 threads
	    - fetch_add/fetch_sub combinations
	    - compare_exchange_strong under contention

	  Verifies lock-free correctness and performance.
	  Runtime: ~10 seconds

config TEST_STRESS_OSAL_MUTEX
	bool "Mutex contention stress"
	default y
	help
	  Test mutex under extreme contention.

	  Scenarios:
	    - 50 threads competing for single mutex
	    - Millions of lock/unlock cycles

	  Verifies no deadlocks and fair scheduling.
	  Runtime: ~10 seconds

config TEST_STRESS_OSAL_SEMAPHORE
	bool "Semaphore signaling stress"
	default y
	help
	  Test semaphore post/wait under load.

	  Scenarios:
	    - Rapid post/wait cycles
	    - Multiple producers and consumers

	  Verifies correct counting and wake-up behavior.
	  Runtime: ~5 seconds

config TEST_STRESS_OSAL_CONDITION
	bool "Condition variable stress"
	default y
	help
	  Test condition variables under signaling storms.

	  Scenarios:
	    - Many threads waiting and signaling
	    - Signal/broadcast interleaving

	  Verifies no lost wake-ups or spurious signals.
	  Runtime: ~5 seconds

config TEST_STRESS_OSAL_THREAD
	bool "Thread creation stress"
	default y
	help
	  Test thread creation/destruction at scale.

	  Scenarios:
	    - Rapidly create 100 threads
	    - Measure creation throughput

	  Verifies no resource leaks and proper cleanup.
	  Runtime: ~5 seconds

config TEST_STRESS_OSAL_MEMORY
	bool "Memory allocation stress"
	default y
	help
	  Test memory allocator under concurrent load.

	  Scenarios:
	    - Concurrent alloc/free from 20 threads
	    - Various allocation sizes (16B - 16KB)
	    - Millions of allocation cycles

	  Verifies no memory leaks and allocator performance.
	  Runtime: ~10 seconds

config TEST_STRESS_OSAL_TIME
	bool "Time operations stress"
	default y
	help
	  Test time functions from multiple threads.

	  Scenarios:
	    - Concurrent get_tick_count calls
	    - get_monotonic_time verification
	    - get_local_time thread safety

	  Verifies thread safety and monotonicity.
	  Runtime: ~5 seconds

config TEST_STRESS_OSAL_STRING
	bool "String operations stress"
	default y
	help
	  Test string functions under concurrent access.

	  Scenarios:
	    - Concurrent snprintf formatting
	    - strcmp/strcpy operations
	    - strlen calculations

	  Verifies thread safety and correctness.
	  Runtime: ~5 seconds

config TEST_STRESS_OSAL_FILE
	bool "File I/O stress"
	default y
	help
	  Test file operations under concurrent load.

	  Scenarios:
	    - Multiple threads creating/writing/reading files
	    - Concurrent file descriptor usage
	    - Rapid create/delete cycles in /tmp

	  Verifies no fd leaks and proper file handling.
	  Runtime: ~5 seconds
	  Note: Creates temporary files in /tmp

config TEST_STRESS_OSAL_CRC
	bool "CRC computation stress"
	default y
	help
	  Test CRC functions under concurrent load.

	  Scenarios:
	    - Concurrent CRC16 and CRC32 calculations
	    - Various data sizes

	  Verifies thread safety and performance.
	  Runtime: ~5 seconds

config TEST_STRESS_OSAL_MIXED
	bool "Mixed operations stress"
	default y
	help
	  Test mixed workload combining multiple operations.

	  Scenarios:
	    - 30 threads performing diverse operations
	    - Mutex, semaphore, memory, time, string ops
	    - Simulates real application workload

	  Verifies overall system stability under realistic load.
	  Runtime: ~10 seconds

endmenu

endif # TEST_STRESS_OSAL
