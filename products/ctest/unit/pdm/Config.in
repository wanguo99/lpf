# PDM Unit Test Configuration
#
# Fine-grained control for individual PDM test files.
# Each option corresponds to a single test_pdm_*.c file.

if TEST_PDM

menu "PDM Unit Tests"

config TEST_PDM_ALL
	bool "Enable all PDM unit tests"
	default y
	select TEST_PDM_PROTOCOL
	help
	  Enable all PDM unit tests at once.
	  Disabling this allows individual test selection below.

config TEST_PDM_PROTOCOL
	bool "PDM internal protocol tests"
	depends on PDM_PROTOCOL
	default y
	help
	  Test PDM internal protocol helpers.

	  Coverage:
	    - Protocol lifecycle and version helpers
	    - Sequence number management
	    - Header initialization and validation
	    - Device message encode/decode
	    - CRC-based corruption detection

	  Runtime: <100ms
	  Hardware: None
	  Dependencies: CONFIG_PDM_PROTOCOL
	  Tags: fast
	  Test file: test_pdm_protocol.c

endmenu

endif # TEST_PDM
