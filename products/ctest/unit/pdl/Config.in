# PDL Unit Test Configuration
#
# Fine-grained control for individual PDL test files.

if TEST_PDL

menu "PDL Unit Tests"

config TEST_PDL_ALL
	bool "Enable all PDL unit tests"
	default y
	select TEST_PDL_MCU
	help
	  Enable all implemented PDL unit tests at once.
	  Disabling this allows individual test selection below.

config TEST_PDL_MCU
	bool "MCU device driver tests"
	default y
	depends on PDL_MCU_SUPPORT
	help
	  Test PDL MCU device driver behavior for the implemented MCU path.

	  Coverage:
	    - MCU device initialization
	    - Command transmission
	    - Status query operations
	    - Firmware version retrieval
	    - Device reset and control
	    - Error reporting and handling

	  Runtime: <200ms
	  Hardware: Requires MCU hardware or simulation
	  Dependencies: CONFIG_PDL_MCU_SUPPORT
	  Tags: hardware
	  Test file: test_pdl_mcu.c

endmenu

endif # TEST_PDL
