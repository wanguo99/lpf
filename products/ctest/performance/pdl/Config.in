# PDL Performance Test Configuration
#
# Measures PDL device driver performance and protocol efficiency.
# Tests peripheral driver layer throughput and latency.

if TEST_PERFORMANCE_PDL

menu "PDL Performance Tests"

config TEST_PERF_PDL
	bool "PDL综合性能测试"
	default y
	help
	  PDL层综合性能测试套件。

	  测试内容：
	    - 外设驱动基础性能基准测试
	    - 协议处理性能测试
	    - 设备通信性能验证

	  运行时间: 3-5 秒
	  硬件要求: Mock设备或模拟环境
	  依赖项: CONFIG_PDL
	  标签: performance, pdl
	  测试文件: test_perf_pdl.c

config TEST_PERF_PDL_MCU
	bool "MCU device performance tests"
	default n
	help
	  MCU communication performance benchmarks.

	  Measures:
	    - Command execution latency
	    - Telemetry read throughput
	    - Bulk data transfer speed
	    - Protocol overhead analysis

	  Runtime: 2-4 seconds
	  Hardware: Mock MCU device
	  Dependencies: CONFIG_PDL_MCU
	  Tags: performance, pdl
	  Test file: test_perf_pdl_mcu.c

config TEST_PERF_PDL_PROTOCOL
	bool "Protocol encoding/decoding performance tests"
	default n
	help
	  PDL protocol layer performance benchmarks.

	  Measures:
	    - Message encoding speed
	    - Message decoding speed
	    - CRC calculation overhead
	    - Serialization/deserialization efficiency
	    - Protocol buffer reuse optimization

	  Runtime: 2-3 seconds
	  Hardware: None
	  Dependencies: CONFIG_PDL
	  Tags: performance, protocol
	  Test file: test_perf_pdl_protocol.c

endmenu

endif # TEST_PERFORMANCE_PDL
