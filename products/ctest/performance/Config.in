# Performance Test Configuration
#
# Performance tests measure throughput, latency, and resource usage
# under typical and high-load conditions.
#
# Organization:
#   - performance/Config.in (this file) - Entry point, sources layer configs
#   - performance/osal/Config.in - OSAL performance tests
#   - performance/hal/Config.in - HAL performance tests
#   - performance/pdl/Config.in - PDL performance tests
#   - performance/pconfig/Config.in - PCONFIG performance tests
#   - performance/aconfig/Config.in - ACONFIG performance tests

if TEST_PERFORMANCE

menu "Performance Tests"

config TEST_PERFORMANCE_ALL
	bool "Enable all performance tests"
	default y
	select TEST_PERFORMANCE_OSAL if TEST_OSAL
	select TEST_PERFORMANCE_HAL if TEST_HAL
	select TEST_PERFORMANCE_PDL if TEST_PDL
	select TEST_PERFORMANCE_PCONFIG if TEST_PCONFIG
	select TEST_PERFORMANCE_ACONFIG if TEST_ACONFIG
	help
	  Enable all performance tests at once.
	  Disabling this allows individual layer selection below.

	  Performance tests measure:
	    - Throughput (operations per second)
	    - Latency (min/max/avg/p99)
	    - Resource usage (CPU, memory)
	    - Scalability under load

	  Runtime: Varies by test (typically 1-10 seconds per test)
	  Tags: slow, performance

# Source layer-specific Config.in files
if TEST_OSAL
	source "products/ctest/performance/osal/Config.in"
endif

if TEST_HAL
	source "products/ctest/performance/hal/Config.in"
endif

if TEST_PDL
	source "products/ctest/performance/pdl/Config.in"
endif

if TEST_PCONFIG
	source "products/ctest/performance/pconfig/Config.in"
endif

if TEST_ACONFIG
	source "products/ctest/performance/aconfig/Config.in"
endif

endmenu

endif # TEST_PERFORMANCE
