	default n
	help
	  Build OSAL layer stress tests.

config TEST_STRESS_HAL
	bool "Build HAL stress tests"
	select HAL
	default n
	help
	  Build HAL layer stress tests.

config TEST_STRESS_PCONFIG
	bool "Build PCONFIG stress tests"
	depends on OSAL && HAL  # PCONFIG dependencies
	select PCONFIG
	default n
	help
	  Build PCONFIG layer stress tests.

	  Note: PCONFIG requires OSAL and HAL.

config TEST_STRESS_PDL
	bool "Build PDL stress tests"
	depends on OSAL && HAL && PCONFIG  # PDL dependencies
	select PDL
	default n
	help
	  Build PDL layer stress tests.

	  Note: PDL requires OSAL, HAL, and PCONFIG.

config TEST_STRESS_PRL
	bool "Build PRL stress tests"
	select PRL
	default n
	help
	  Build PRL layer stress tests.

config TEST_STRESS_ACONFIG
	bool "Build ACONFIG stress tests"
	select ACONFIG
	default n
	help
	  Build ACONFIG layer stress tests.

# Source fine-grained stress test configurations
source "products/ctest/stress/Config.in"

endif # TEST_STRESS

config TEST_SYSTEM
	bool "Build system tests"
	depends on BUILD_TESTING
	default n
	help
	  Build system tests for all modules.
	  System tests verify end-to-end functionality and module interactions.

if TEST_SYSTEM

config TEST_SYSTEM_OSAL
	bool "Build OSAL system tests"
	select OSAL
	default n
	help
	  Build OSAL layer system tests.

config TEST_SYSTEM_HAL
	bool "Build HAL system tests"
	select HAL
	default n
	help
	  Build HAL layer system tests.

config TEST_SYSTEM_PCONFIG
	bool "Build PCONFIG system tests"
	depends on OSAL && HAL  # PCONFIG dependencies
	select PCONFIG
	default n
	help
	  Build PCONFIG layer system tests.

	  Note: PCONFIG requires OSAL and HAL.

config TEST_SYSTEM_PDL
	bool "Build PDL system tests"
	depends on OSAL && HAL && PCONFIG  # PDL dependencies
	select PDL
	default n
	help
	  Build PDL layer system tests.

	  Note: PDL requires OSAL, HAL, and PCONFIG.

config TEST_SYSTEM_ACONFIG
	bool "Build ACONFIG system tests"
	select ACONFIG
	default n
	help
	  Build ACONFIG layer system tests.

config TEST_SYSTEM_ACONFIG
	bool "Build ACONFIG system tests"
	select ACONFIG
	default n
	help
	  Build ACONFIG layer system tests.

config TEST_INTEGRATION
	bool "Build integration tests"
	default n
	help
	  Build integration tests verifying interactions between modules.

# Source fine-grained system and integration test configurations
source "products/ctest/system/Config.in"

endif # TEST_SYSTEM
