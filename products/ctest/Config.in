# ============================================================================
# Core Modules Test Suite Configuration
# ============================================================================
# This test product provides comprehensive testing for all core SDK modules:
#   - OSAL (Operating System Abstraction Layer)
#   - HAL (Hardware Abstraction Layer)
#   - PDI (Peripheral Driver Interface)
#   - PCONFIG (Platform Configuration)
#   - ACONFIG (Application Configuration)
#
# Test categories:
#   - Unit: Individual component/function testing
#   - Performance: Benchmarking and profiling
#   - Stress: Stability and resource exhaustion testing
#   - System: Integration and end-to-end testing
# ============================================================================

config TEST_UNIT
	bool "Build unit tests"
	depends on BUILD_TESTING
	default n
	help
	  Build unit tests for all modules.
	  Unit tests verify individual functions and components in isolation.

if TEST_UNIT

config TEST_OSAL
	bool "Build OSAL unit tests"
	select OSAL
	default n
	help
	  Build OSAL layer unit tests.
	  This will automatically enable the OSAL module.

	  Fine-grained control over individual OSAL test files is available
	  in the OSAL Unit Tests submenu.

config TEST_HAL
	bool "Build HAL unit tests"
	depends on OSAL  # HAL depends on OSAL
	select HAL
	default n
	help
	  Build HAL layer unit tests.
	  This will automatically enable the HAL module.

	  Note: HAL requires OSAL, so enable OSAL first.

	  Fine-grained control over individual HAL test files is available
	  in the HAL Unit Tests submenu.

config TEST_PDI
	bool "Build PDI unit tests"
	depends on OSAL
	select PDI
	default n
	help
	  Build PDI userspace API unit tests.
	  This will automatically enable the PDI module.

	  PDI wraps the ioctl ABI exposed by the kernel PDM module. These
	  unit tests cover userspace API validation and do not require the
	  kernel module to be loaded.

	  Fine-grained control over individual PDI test files is available
	  in the PDI Unit Tests submenu.

config TEST_PDM
	bool "Build PDM internal unit tests"
	depends on PDM
	default n
	help
	  Build PDM internal unit tests.

	  These tests cover PDM-owned implementation details that are linked
	  into pdm.ko, such as the internal peripheral protocol. They are not
	  tests for the userspace PDI ioctl API.

	  Fine-grained control over individual PDM test files is available
	  in the PDM Unit Tests submenu.

config TEST_ACONFIG
	bool "Build ACONFIG unit tests"
	depends on OSAL  # ACONFIG dependency
	select ACONFIG
	default n
	help
	  Build ACONFIG layer unit tests.
	  This will automatically enable the ACONFIG module.

	  Note: ACONFIG requires OSAL, so enable OSAL first.

	  Fine-grained control over individual ACONFIG test files is available
	  in the ACONFIG Unit Tests submenu.

config TEST_PCONFIG
	bool "Build PCONFIG unit tests"
	depends on OSAL  # PCONFIG basic dependency
	select PCONFIG
	default n
	help
	  Build PCONFIG layer unit tests.
	  This will automatically enable the PCONFIG module.

	  Note: PCONFIG requires OSAL.

	  Fine-grained control over individual PCONFIG test files is available
	  in the PCONFIG Unit Tests submenu.

# Source fine-grained unit test configurations
source "products/ctest/unit/Config.in"

endif # TEST_UNIT

config TEST_PERFORMANCE
	bool "Build performance tests"
	depends on BUILD_TESTING
	default n
	help
	  Build performance tests for all modules.
	  Performance tests measure throughput, latency, and resource usage.

if TEST_PERFORMANCE

config TEST_PERFORMANCE_OSAL
	bool "Build OSAL performance tests"
	select OSAL
	default y
	help
	  Build OSAL layer performance tests.

config TEST_PERFORMANCE_HAL
	bool "Build HAL performance tests"
	select HAL
	default y
	help
	  Build HAL layer performance tests.

config TEST_PERFORMANCE_PCONFIG
	bool "Build PCONFIG performance tests"
	depends on OSAL  # PCONFIG dependency
	select PCONFIG
	default n
	help
	  Build PCONFIG layer performance tests.

	  Note: PCONFIG requires OSAL.

config TEST_PERFORMANCE_ACONFIG
	bool "Build ACONFIG performance tests"
	select ACONFIG
	default n
	help
	  Build ACONFIG layer performance tests.

# Source fine-grained performance test configurations
source "products/ctest/performance/Config.in"

endif # TEST_PERFORMANCE

config TEST_STRESS
	bool "Build stress tests"
	depends on BUILD_TESTING
	default n
	help
	  Build stress tests for all modules.
	  Stress tests verify system behavior under heavy load and extremes.

if TEST_STRESS

config TEST_STRESS_OSAL
	bool "Build OSAL stress tests"
	select OSAL
	default n
	help
	  Build OSAL layer stress tests.

config TEST_STRESS_HAL
	bool "Build HAL stress tests"
	select HAL
	default n
	help
	  Build HAL layer stress tests.

config TEST_STRESS_PCONFIG
	bool "Build PCONFIG stress tests"
	depends on OSAL  # PCONFIG dependency
	select PCONFIG
	default n
	help
	  Build PCONFIG layer stress tests.

	  Note: PCONFIG requires OSAL.

config TEST_STRESS_ACONFIG
	bool "Build ACONFIG stress tests"
	select ACONFIG
	default n
	help
	  Build ACONFIG layer stress tests.

# Source fine-grained stress test configurations
source "products/ctest/stress/Config.in"

endif # TEST_STRESS

config TEST_SYSTEM
	bool "Build system tests"
	depends on BUILD_TESTING
	default n
	help
	  Build system tests for all modules.
	  System tests verify end-to-end functionality and module interactions.

if TEST_SYSTEM

config TEST_SYSTEM_OSAL
	bool "Build OSAL system tests"
	select OSAL
	default n
	help
	  Build OSAL layer system tests.

config TEST_SYSTEM_HAL
	bool "Build HAL system tests"
	select HAL
	default n
	help
	  Build HAL layer system tests.

config TEST_SYSTEM_PCONFIG
	bool "Build PCONFIG system tests"
	depends on OSAL  # PCONFIG dependency
	select PCONFIG
	default n
	help
	  Build PCONFIG layer system tests.

	  Note: PCONFIG requires OSAL.

config TEST_SYSTEM_ACONFIG
	bool "Build ACONFIG system tests"
	select ACONFIG
	default n
	help
	  Build ACONFIG layer system tests.

config TEST_INTEGRATION
	bool "Build integration tests"
	default n
	help
	  Build integration tests verifying interactions between modules.

# Source fine-grained system and integration test configurations
source "products/ctest/system/Config.in"

endif # TEST_SYSTEM
