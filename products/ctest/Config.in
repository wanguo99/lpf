# ============================================================================
# Core Modules Test Suite Configuration
# ============================================================================
# This test product provides comprehensive testing for all core SDK modules:
#   - OSAL (Operating System Abstraction Layer)
#   - HAL (Hardware Abstraction Layer)
#   - PDL (Peripheral Driver Library)
#   - PRL (Peripheral Resource Library)
#   - PCONFIG (Platform Configuration)
#   - ACONFIG (Application Configuration)
#
# Test categories:
#   - Unit: Individual component/function testing
#   - Performance: Benchmarking and profiling
#   - Stress: Stability and resource exhaustion testing
#   - System: Integration and end-to-end testing
# ============================================================================

config TEST_UNIT
	bool "Build unit tests"
	depends on BUILD_TESTING
	default n
	help
	  Build unit tests for all modules.
	  Unit tests verify individual functions and components in isolation.

if TEST_UNIT

config TEST_OSAL
	bool "Build OSAL unit tests"
	select OSAL
	default n
	help
	  Build OSAL layer unit tests.
	  This will automatically enable the OSAL module.

	  Fine-grained control over individual OSAL test files is available
	  in the OSAL Unit Tests submenu.

config TEST_HAL
	bool "Build HAL unit tests"
	depends on OSAL  # HAL depends on OSAL
	select HAL
	default n
	help
	  Build HAL layer unit tests.
	  This will automatically enable the HAL module.

	  Note: HAL requires OSAL, so enable OSAL first.

	  Fine-grained control over individual HAL test files is available
	  in the HAL Unit Tests submenu.

config TEST_PDL
	bool "Build PDL unit tests"
	depends on OSAL && HAL && PCONFIG  # PDL dependencies
	select PDL
	default n
	help
	  Build PDL layer unit tests.
	  This will automatically enable the PDL module.

	  Note: PDL requires OSAL, HAL, and PCONFIG.

	  Fine-grained control over individual PDL test files is available
	  in the PDL Unit Tests submenu.

config TEST_ACONFIG
	bool "Build ACONFIG unit tests"
	depends on OSAL  # ACONFIG dependency
	select ACONFIG
	default n
	help
	  Build ACONFIG layer unit tests.
	  This will automatically enable the ACONFIG module.

	  Note: ACONFIG requires OSAL, so enable OSAL first.

config TEST_PRL
	bool "Build PRL unit tests"
	select PRL
	default n
	help
	  Build PRL layer unit tests.
	  This will automatically enable the PRL module.

	  Fine-grained control over individual PRL test files is available
	  in the PRL Unit Tests submenu.

config TEST_ACONFIG
	bool "Build ACONFIG unit tests"
	select ACONFIG
	default n
	help
	  Build ACONFIG layer unit tests.
	  This will automatically enable the ACONFIG module.

	  Fine-grained control over individual ACONFIG test files is available
	  in the ACONFIG Unit Tests submenu.

config TEST_PCONFIG
	bool "Build PCONFIG unit tests"
	depends on OSAL && HAL  # PCONFIG basic dependencies
	select PCONFIG
	select PDL  # PCONFIG runtime dependency
	default n
	help
	  Build PCONFIG layer unit tests.
	  This will automatically enable the PCONFIG and PDL modules.

	  Note: PCONFIG requires PDL for hardware ID detection.

	  Fine-grained control over individual PCONFIG test files is available
	  in the PCONFIG Unit Tests submenu.

# Source fine-grained unit test configurations
source "products/ctest/unit/Config.in"

endif # TEST_UNIT

config TEST_PERFORMANCE
	bool "Build performance tests"
	depends on BUILD_TESTING
	default n
	help
	  Build performance tests for all modules.
	  Performance tests measure throughput, latency, and resource usage.

if TEST_PERFORMANCE

config TEST_PERFORMANCE_OSAL
	bool "Build OSAL performance tests"
	select OSAL
	default y
	help
	  Build OSAL layer performance tests.

config TEST_PERFORMANCE_HAL
	bool "Build HAL performance tests"
	select HAL
	default y
	help
	  Build HAL layer performance tests.

config TEST_PERFORMANCE_PCONFIG
	bool "Build PCONFIG performance tests"
	depends on OSAL && HAL  # PCONFIG dependencies
	select PCONFIG
	default n
	help
	  Build PCONFIG layer performance tests.

	  Note: PCONFIG requires OSAL and HAL.

config TEST_PERFORMANCE_PDL
	bool "Build PDL performance tests"
	depends on OSAL && HAL && PCONFIG  # PDL dependencies
	select PDL
	default y
	help
	  Build PDL layer performance tests.

	  Note: PDL requires OSAL, HAL, and PCONFIG.

config TEST_PERFORMANCE_ACONFIG
	bool "Build ACONFIG performance tests"
	select ACONFIG
	default n
	help
	  Build ACONFIG layer performance tests.

# Source fine-grained performance test configurations
source "products/ctest/performance/Config.in"

endif # TEST_PERFORMANCE

