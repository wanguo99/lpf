# ACONFIG System Test Configuration
#
# Application configuration layer integration tests.
# Tests ACONFIG with underlying PCONFIG, PDL, and HAL components.

if TEST_SYSTEM_ACL

menu "ACONFIG System Tests"

config TEST_SYSTEM_ACONFIG_TELECOMMAND
	bool "Telecommand end-to-end tests"
	default n
	help
	  Telecommand processing through full stack.

	  Tests:
	    - TC reception → ACONFIG lookup → PDL execution
	    - Multi-step TC sequences
	    - TC parameter validation
	    - TC execution status tracking
	    - TC error handling and reporting

	  Verifies:
	    - Correct TC-to-device mapping
	    - Parameter translation accuracy
	    - Execution confirmation
	    - Error propagation to application

	  Runtime: 5-10 seconds
	  Hardware: Mock devices
	  Dependencies: CONFIG_ACL, CONFIG_PDL
	  Tags: integration, telecommand
	  Test file: test_system_aconfig_telecommand.c

config TEST_SYSTEM_ACONFIG_TELEMETRY
	bool "Telemetry end-to-end tests"
	default n
	help
	  Telemetry collection through full stack.

	  Tests:
	    - Device data → PDL read → ACONFIG format → TM packet
	    - Multi-device telemetry aggregation
	    - Telemetry timestamp synchronization
	    - High-frequency telemetry collection
	    - Telemetry buffer management

	  Verifies:
	    - Correct device-to-TM mapping
	    - Data format conversion accuracy
	    - Timestamp consistency
	    - No data loss under load

	  Runtime: 5-10 seconds
	  Hardware: Mock devices
	  Dependencies: CONFIG_ACL, CONFIG_PDL
	  Tags: integration, telemetry
	  Test file: test_system_aconfig_telemetry.c

config TEST_SYSTEM_ACONFIG_SCENARIO
	bool "Real-world scenario tests"
	default n
	help
	  End-to-end mission scenario simulations.

	  Tests:
	    - Power-on sequence (all devices)
	    - Normal operations (mixed TC/TM)
	    - Anomaly handling scenarios
	    - Safe mode transitions
	    - Power-off sequence

	  Verifies:
	    - Complete mission scenarios work
	    - Correct state machine transitions
	    - Error recovery in context
	    - System stability in real workflows

	  Runtime: 10-20 seconds
	  Hardware: Mock devices
	  Dependencies: CONFIG_ACL, CONFIG_PCL, CONFIG_PDL
	  Tags: integration, scenario, slow
	  Test file: test_system_aconfig_scenario.c

endmenu

endif # TEST_SYSTEM_ACL
