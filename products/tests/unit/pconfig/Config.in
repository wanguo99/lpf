# PCONFIG Unit Test Configuration
#
# Fine-grained control for individual PCONFIG test files.
# Each option corresponds to a single test_pconfig_*.c file.

if TEST_PCONFIG

menu "PCONFIG Unit Tests"

config TEST_PCONFIG_ALL
	bool "Enable all PCONFIG unit tests"
	default y
	select TEST_PCONFIG_API
	help
	  Enable all PCONFIG unit tests at once.
	  Disabling this allows individual test selection below.

config TEST_PCONFIG_API
	bool "PCONFIG API tests"
	default y
	help
	  Test PCONFIG API operations (init, query, device lookup, configuration).

	  Coverage:
	    - Platform configuration initialization
	    - Device configuration lookup by ID
	    - Device configuration lookup by name
	    - HAL device configuration queries
	    - PDL device configuration queries
	    - Configuration table iteration
	    - Configuration validation
	    - Runtime configuration updates

	  Runtime: <100ms
	  Hardware: None
	  Dependencies: CONFIG_PCONFIG
	  Tags: fast
	  Test file: test_pconfig_api.c

endmenu

endif # TEST_PCONFIG
