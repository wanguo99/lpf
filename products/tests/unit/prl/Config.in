# PRL Unit Test Configuration
#
# Fine-grained control for individual PRL test files.
# Each option corresponds to a single test_prl_*.c file.

if TEST_PRL

menu "PRL Unit Tests"

config TEST_PRL_ALL
	bool "Enable all PRL unit tests"
	default y
	select TEST_PRL_COMMON
	select TEST_PRL_DEVICE
	help
	  Enable all PRL unit tests at once.
	  Disabling this allows individual test selection below.

config TEST_PRL_COMMON
	bool "PRL common protocol tests"
	default y
	help
	  Test PRL common protocol operations (encode, decode, header, CRC).

	  Coverage:
	    - Protocol header encoding/decoding
	    - CRC16 calculation and validation
	    - Magic number and version validation
	    - Sequence number handling
	    - Timestamp generation and parsing
	    - Packet framing
	    - Error detection mechanisms

	  Runtime: <100ms
	  Hardware: None
	  Dependencies: CONFIG_PRL
	  Tags: fast
	  Test file: test_prl_common.c

config TEST_PRL_DEVICE
	bool "PRL device protocol tests"
	default y
	help
	  Test PRL device-specific protocol operations (MCU, CCM, PMC, GSC, POWER).

	  Coverage:
	    - MCU device protocol (commands, responses, telemetry)
	    - CCM device protocol (system management)
	    - PMC device protocol (payload management)
	    - GSC device protocol (ground station communication)
	    - POWER device protocol (power control)
	    - Device type identification
	    - Message type handling per device
	    - Cross-device communication patterns

	  Runtime: <200ms
	  Hardware: None
	  Dependencies: CONFIG_PRL
	  Tags: fast
	  Test file: test_prl_device.c

endmenu

endif # TEST_PRL
