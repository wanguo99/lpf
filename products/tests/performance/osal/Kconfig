# OSAL Performance Test Configuration
#
# Measures OSAL component performance under load.
# Tests measure throughput, latency, and scalability.

if TEST_PERFORMANCE_OSAL

menu "OSAL Performance Tests"

config TEST_PERF_OSAL_MUTEX
	bool "Mutex performance tests"
	default n
	help
	  Dedicated mutex performance tests.

	  Measures:
	    - Lock/unlock latency (uncontended)
	    - Lock contention overhead
	    - Trylock performance
	    - Recursive mutex overhead
	    - Priority inheritance impact

	  Runtime: 2-3 seconds
	  Hardware: None
	  Dependencies: CONFIG_OSAL
	  Tags: performance, mutex
	  Test file: test_perf_osal_mutex.c

config TEST_PERF_OSAL_THREAD
	bool "Thread performance tests"
	default n
	help
	  Thread creation, scheduling, and context switching performance.

	  Measures:
	    - Thread creation time
	    - Thread join overhead
	    - Context switch latency
	    - Thread-local storage access time
	    - Scheduler overhead

	  Runtime: 3-5 seconds
	  Hardware: None
	  Dependencies: CONFIG_OSAL
	  Tags: performance, threading
	  Test file: test_perf_osal_thread.c

config TEST_PERF_OSAL_SEMAPHORE
	bool "Semaphore performance tests"
	default n
	help
	  Semaphore performance benchmarks.

	  Measures:
	    - Post/wait latency
	    - Trywait overhead
	    - Timed wait performance
	    - Multi-thread contention

	  Runtime: 2-3 seconds
	  Hardware: None
	  Dependencies: CONFIG_OSAL
	  Tags: performance, ipc
	  Test file: test_perf_osal_semaphore.c

config TEST_PERF_OSAL_COND
	bool "Condition variable performance tests"
	default n
	help
	  Condition variable performance benchmarks.

	  Measures:
	    - Signal latency
	    - Broadcast overhead
	    - Wait/timed wait performance
	    - Predicate evaluation overhead

	  Runtime: 2-3 seconds
	  Hardware: None
	  Dependencies: CONFIG_OSAL
	  Tags: performance, ipc
	  Test file: test_perf_osal_cond.c

config TEST_PERF_OSAL_HEAP
	bool "Heap memory performance tests"
	default n
	help
	  Memory allocation/deallocation performance.

	  Measures:
	    - malloc/free throughput
	    - calloc performance
	    - realloc overhead
	    - Small vs large allocation patterns
	    - Memory fragmentation impact

	  Runtime: 2-4 seconds
	  Hardware: None
	  Dependencies: CONFIG_OSAL
	  Tags: performance, memory
	  Test file: test_perf_osal_heap.c

config TEST_PERF_OSAL_FILE
	bool "File I/O performance tests"
	default n
	help
	  File system operation performance.

	  Measures:
	    - Sequential read/write throughput
	    - Random access performance
	    - Open/close overhead
	    - Seek operation latency
	    - Sync/fsync impact

	  Runtime: 3-5 seconds
	  Hardware: Requires filesystem
	  Dependencies: CONFIG_OSAL
	  Tags: performance, filesystem, slow
	  Test file: test_perf_osal_file.c

config TEST_PERF_OSAL_ATOMIC
	bool "Atomic operation performance tests"
	default n
	help
	  Atomic operation throughput benchmarks.

	  Measures:
	    - Atomic load/store performance
	    - Atomic add/sub throughput
	    - Compare-and-swap latency
	    - Different sizes (8/16/32/64-bit)

	  Runtime: 1-2 seconds
	  Hardware: None
	  Dependencies: CONFIG_OSAL
	  Tags: performance, atomic
	  Test file: test_perf_osal_atomic.c

config TEST_PERF_OSAL_TIME
	bool "Time operation performance tests"
	default n
	help
	  Time and clock operation performance.

	  Measures:
	    - gettimeofday overhead
	    - clock_gettime latency
	    - Sleep accuracy and overhead
	    - Timer resolution

	  Runtime: 2-3 seconds
	  Hardware: None
	  Dependencies: CONFIG_OSAL
	  Tags: performance, timing
	  Test file: test_perf_osal_time.c

endmenu

endif # TEST_PERFORMANCE_OSAL
