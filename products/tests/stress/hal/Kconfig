# HAL Stress Test Configuration
#
# Tests HAL drivers under high load and concurrent access.
# Verifies driver stability and resource management under pressure.

if TEST_STRESS_HAL

menu "HAL Stress Tests"

config TEST_STRESS_HAL_CAN
	bool "CAN bus stress tests"
	default n
	help
	  CAN driver stress and concurrent access tests.

	  Tests:
	    - Transmit queue overflow
	    - Receive buffer flooding
	    - Concurrent send from many threads
	    - Rapid filter reconfiguration
	    - Bus-off recovery under load
	    - Error frame handling

	  Verifies:
	    - No message loss under load
	    - Buffer management correctness
	    - Thread-safe operations
	    - Recovery from error states

	  Runtime: 15-30 seconds
	  Hardware: CAN interface (mock or real)
	  Dependencies: CONFIG_HAL_CAN
	  Tags: stress, hardware, can
	  Test file: test_stress_hal_can.c

config TEST_STRESS_HAL_SERIAL
	bool "Serial port stress tests"
	default n
	help
	  UART/serial driver stress tests.

	  Tests:
	    - Continuous full-speed transmission
	    - Receive buffer overflow handling
	    - Concurrent read/write operations
	    - Flow control under pressure
	    - Parity/framing error injection

	  Verifies:
	    - No data corruption
	    - Buffer overflow protection
	    - Error recovery mechanisms
	    - Resource cleanup

	  Runtime: 15-30 seconds
	  Hardware: Serial port (loopback recommended)
	  Dependencies: CONFIG_HAL_SERIAL
	  Tags: stress, hardware, serial
	  Test file: test_stress_hal_serial.c

config TEST_STRESS_HAL_SPI
	bool "SPI bus stress tests"
	default n
	help
	  SPI driver stress and concurrent access tests.

	  Tests:
	    - High-frequency transfers
	    - Large buffer transfers (MB range)
	    - Concurrent access to multiple devices
	    - Rapid chip select toggling
	    - DMA error scenarios

	  Verifies:
	    - Data integrity under load
	    - Exclusive bus access enforcement
	    - Buffer management correctness
	    - DMA completion handling

	  Runtime: 10-20 seconds
	  Hardware: SPI devices (mock or real)
	  Dependencies: CONFIG_HAL_SPI
	  Tags: stress, hardware, spi
	  Test file: test_stress_hal_spi.c

config TEST_STRESS_HAL_I2C
	bool "I2C bus stress tests"
	default n
	help
	  I2C driver stress and error handling tests.

	  Tests:
	    - Rapid transactions
	    - Address collision scenarios
	    - Clock stretching timeouts
	    - NAK handling under load
	    - Multi-master conflicts

	  Verifies:
	    - Bus arbitration correctness
	    - Error recovery mechanisms
	    - Transaction atomicity
	    - Timeout handling

	  Runtime: 10-20 seconds
	  Hardware: I2C devices (mock or real)
	  Dependencies: CONFIG_HAL_I2C
	  Tags: stress, hardware, i2c
	  Test file: test_stress_hal_i2c.c

config TEST_STRESS_HAL_GPIO
	bool "GPIO stress tests"
	default n
	help
	  GPIO driver stress and concurrent access tests.

	  Tests:
	    - High-frequency pin toggling (MHz range)
	    - Concurrent access to many pins
	    - Interrupt storm handling (many IRQs/sec)
	    - Rapid configuration changes
	    - Edge detection under noise

	  Verifies:
	    - Pin state consistency
	    - Interrupt handler stability
	    - No missed interrupts (within reason)
	    - Debouncing effectiveness

	  Runtime: 10-20 seconds
	  Hardware: GPIO pins
	  Dependencies: CONFIG_HAL_GPIO
	  Tags: stress, hardware, gpio
	  Test file: test_stress_hal_gpio.c

config TEST_STRESS_HAL_WATCHDOG
	bool "Watchdog stress tests"
	default n
	help
	  Watchdog driver stress and edge case tests.

	  Tests:
	    - Rapid kick operations
	    - Timeout edge cases
	    - Concurrent configuration changes
	    - Reset during reconfiguration

	  Verifies:
	    - Timer accuracy under load
	    - Safe reconfiguration
	    - No false resets

	  Runtime: 10-20 seconds
	  Hardware: Watchdog timer
	  Dependencies: CONFIG_HAL_WATCHDOG
	  Tags: stress, hardware, watchdog
	  Test file: test_stress_hal_watchdog.c

config TEST_STRESS_HAL_CONCURRENT
	bool "Multi-driver concurrent access stress tests"
	default n
	help
	  Cross-driver stress tests (multiple HAL components).

	  Tests:
	    - Simultaneous CAN, Serial, SPI, I2C operations
	    - Interrupt priority conflicts
	    - Shared resource contention (DMA, clocks)
	    - System load impact on driver latency

	  Verifies:
	    - Driver independence (no side effects)
	    - System-wide stability under load
	    - Resource arbitration correctness

	  Runtime: 20-40 seconds
	  Hardware: Multiple devices
	  Dependencies: CONFIG_HAL
	  Tags: stress, hardware, integration, heavy
	  Test file: test_stress_hal_concurrent.c

endmenu

endif # TEST_STRESS_HAL
