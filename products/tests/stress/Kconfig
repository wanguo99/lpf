# Stress Test Configuration
#
# Stress tests push components to their limits to verify stability,
# robustness, and resource exhaustion handling under extreme conditions.
#
# Organization:
#   - stress/Kconfig (this file) - Entry point, sources layer configs
#   - stress/osal/Kconfig - OSAL stress tests
#   - stress/hal/Kconfig - HAL stress tests
#   - stress/pdl/Kconfig - PDL stress tests
#   - stress/pcl/Kconfig - PCL stress tests
#   - stress/acl/Kconfig - ACL stress tests

if TEST_STRESS

menu "Stress Tests"

config TEST_STRESS_ALL
	bool "Enable all stress tests"
	default y
	select TEST_STRESS_OSAL if TEST_OSAL
	select TEST_STRESS_HAL if TEST_HAL
	select TEST_STRESS_PDL if TEST_PDL
	select TEST_STRESS_PCL if TEST_PCL
	select TEST_STRESS_ACL if TEST_ACL
	help
	  Enable all stress tests at once.
	  Disabling this allows individual layer selection below.

	  Stress tests verify:
	    - Behavior under resource exhaustion
	    - Stability under high concurrency
	    - Memory leak detection under load
	    - Recovery from error conditions
	    - System limits (threads, files, connections)

	  Warning: Stress tests consume significant resources and may
	  take several minutes to complete. They may temporarily degrade
	  system performance.

	  Runtime: Varies by test (typically 10-60 seconds per test)
	  Tags: slow, stress, heavy

# Source layer-specific Kconfig files
if TEST_OSAL
	source "products/tests/stress/osal/Kconfig"
endif

if TEST_HAL
	source "products/tests/stress/hal/Kconfig"
endif

if TEST_PDL
	source "products/tests/stress/pdl/Kconfig"
endif

if TEST_PCL
	source "products/tests/stress/pcl/Kconfig"
endif

if TEST_ACL
	source "products/tests/stress/acl/Kconfig"
endif

endmenu

endif # TEST_STRESS
