# =============================================================================
# 测试框架核心库构建配置（非递归 Make）
# =============================================================================
# 此库提供测试运行器、注册表、菜单等核心功能
# 所有测试程序都需要链接此库
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 源文件列表
# -----------------------------------------------------------------------------
testcore_SRCS := \
	tests/core/main.c \
	tests/core/test_runner.c \
	tests/core/test_registry.c \
	tests/core/test_menu.c

# -----------------------------------------------------------------------------
# 2. 目标文件列表
# -----------------------------------------------------------------------------
testcore_OBJS := $(call srcs_to_objs,$(testcore_SRCS))

# -----------------------------------------------------------------------------
# 3. 编译标志
# -----------------------------------------------------------------------------
testcore_CFLAGS := \
	-Itests/include \
	-I$(STAGING_DIR)/include

# -----------------------------------------------------------------------------
# 4. 链接标志
# -----------------------------------------------------------------------------
testcore_LDFLAGS := -Wl,-soname,libtestcore.so.1

# -----------------------------------------------------------------------------
# 5. 目标库
# -----------------------------------------------------------------------------
testcore_TARGET := $(STAGING_DIR)/lib/libtestcore.so
testcore_STATIC := $(STAGING_DIR)/lib/libtestcore.a

# 添加到全局目标列表
ifeq ($(CONFIG_BUILD_TESTING),y)
ALL_TARGETS += $(testcore_TARGET)
endif

# -----------------------------------------------------------------------------
# 6. 构建规则
# -----------------------------------------------------------------------------
$(eval $(call build_shared_lib,$(testcore_TARGET),$(testcore_OBJS),$(testcore_LDFLAGS)))
$(eval $(call build_static_lib,$(testcore_STATIC),$(testcore_OBJS)))

# 为此模块的目标文件添加编译标志
$(testcore_OBJS): CFLAGS += $(testcore_CFLAGS)


# -----------------------------------------------------------------------------
# 7. 清理规则
# -----------------------------------------------------------------------------
CLEAN_TARGETS += $(testcore_OBJS) $(testcore_TARGET) $(testcore_STATIC)
