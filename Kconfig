mainmenu "EMS (Embedded Middleware System) Configuration"

config EMS_VERSION
	string
	default "1.0.0"

# ============================================================================
# Architecture and Platform Configuration
# ============================================================================

menu "Target Platform"

choice
	prompt "Target operating system"
	default OS_LINUX
	help
	  Select the target operating system type.
	  This affects OSAL (OS Abstraction Layer) implementation.

config OS_LINUX
	bool "Linux"
	help
	  Target Linux operating system.
	  Supports POSIX APIs, threads, sockets, etc.

config OS_WINDOWS
	bool "Windows"
	help
	  Target Windows operating system.
	  Uses Win32 APIs for threading, synchronization, etc.

config OS_RTOS
	bool "RTOS (Real-Time OS)"
	help
	  Target real-time operating system (FreeRTOS, RT-Thread, etc.).
	  Provides deterministic scheduling and minimal footprint.

config OS_MACOS
	bool "macOS"
	help
	  Target macOS operating system.
	  Supports POSIX APIs with macOS-specific extensions.

config OS_BARE
	bool "Bare Metal"
	help
	  No operating system (bare metal).
	  Direct hardware access without OS abstraction.
	  Requires custom startup code and hardware drivers.

endchoice

config OS
	string
	default "linux" if OS_LINUX
	default "windows" if OS_WINDOWS
	default "rtos" if OS_RTOS
	default "macos" if OS_MACOS
	default "bare" if OS_BARE
	help
	  Operating system name used by the build system.
	  This value can be overridden by the OS environment variable.

choice
	prompt "Target architecture"
	default ARCH_X86_64
	help
	  Select the target CPU architecture.

config ARCH_X86_64
	bool "x86_64 (64-bit Intel/AMD)"

config ARCH_ARM32
	bool "ARM32 (ARMv7-A)"

config ARCH_ARM64
	bool "ARM64 (ARMv8-A / AArch64)"

config ARCH_RISCV64
	bool "RISC-V 64-bit"

endchoice

config ARCH
	string
	default "x86_64" if ARCH_X86_64
	default "arm" if ARCH_ARM32
	default "arm64" if ARCH_ARM64
	default "riscv" if ARCH_RISCV64
	help
	  Architecture name used by the build system.
	  This value can be overridden by the ARCH environment variable.

config CROSS_COMPILE
	string "Cross-compiler prefix"
	default "" if ARCH_X86_64
	default "arm-linux-gnueabihf-" if ARCH_ARM32
	default "aarch64-linux-gnu-" if ARCH_ARM64
	default "riscv64-linux-gnu-" if ARCH_RISCV64
	help
	  Prefix for cross-compilation toolchain (e.g., "arm-linux-gnueabihf-").
	  Leave empty for native compilation.
	  This value can be overridden by the CROSS_COMPILE environment variable.

endmenu

# ============================================================================
# Build Configuration
# ============================================================================

menu "Build Options"

config BUILD_TYPE_DEBUG
	bool "Debug build"
	default n
	help
	  Enable debug symbols (-g), disable optimizations (-O0), and enable
	  verbose logging. Equivalent to CMAKE_BUILD_TYPE=Debug.
	  
	  If unsure, say N for production builds.

choice
	prompt "Optimization level"
	default OPT_O2 if !BUILD_TYPE_DEBUG
	default OPT_O0 if BUILD_TYPE_DEBUG
	help
	  Select compiler optimization level.

config OPT_O0
	bool "No optimization (-O0)"
	help
	  Disable all optimizations. Best for debugging with GDB.

config OPT_O2
	bool "Optimize for speed (-O2)"
	help
	  Standard optimization level. Good balance of speed and size.

config OPT_O3
	bool "Aggressive optimization (-O3)"
	help
	  Maximum speed optimization. May increase binary size.

config OPT_OS
	bool "Optimize for size (-Os)"
	help
	  Optimize for minimal binary size. Good for embedded systems.

endchoice

config LIBRARY_BUILD_TYPE_STATIC
	bool "Build static libraries (.a)"
	default n
	help
	  Build static libraries.
	  Static libraries are linked into executables at compile time.

	  Best for embedded systems with limited resources.

config LIBRARY_BUILD_TYPE_DYNAMIC
	bool "Build dynamic libraries (.so)"
	default y
	help
	  Build dynamic/shared libraries.
	  Shared libraries are loaded at runtime, reducing executable size
	  and allowing library updates without recompiling applications.

	  Best for systems with multiple applications sharing libraries.

comment "Note: You can enable both to build both static and dynamic libraries"

config INSTALL_HEADERS
	bool "Install development headers"
	default y
	help
	  Install public header files for library development.

endmenu

# ============================================================================
# Core Modules Configuration
# ============================================================================

source "core/Kconfig"

# ============================================================================
# Products Configuration
# ============================================================================

source "products/Kconfig"

# ============================================================================
# Test Configuration
# ============================================================================

menu "Test Configuration"

config BUILD_TESTING
	bool "Build unit tests"
	default y
	help
	  Build the test suite (ems-test, osal-test, hal-test, etc.).
	  Requires test framework to be available.

source "tests/Kconfig"

endmenu
