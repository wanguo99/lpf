# ============================================================================
# EMS SDK Root Configuration
# ============================================================================
# This is the root Kconfig file for the entire EMS SDK.
# It provides a unified configuration interface for:
#   - Product selection (which products to build)
#   - Core components configuration (OSAL, HAL, PCL, PDL, ACL)
#   - Product-specific configurations
# ============================================================================

mainmenu "EMS SDK Configuration"

# ============================================================================
# Configuration Templates (Quick Start)
# ============================================================================
# Load a predefined configuration template to quickly get started.
# You can further customize the configuration after loading a template.
# ============================================================================

menu "Configuration Templates"

choice
	prompt "Load configuration template"
	default TEMPLATE_NONE
	help
	  Quick start with a predefined configuration template.

	  Templates provide optimized configurations for different scenarios:
	  - RTOS Minimal: Ultra-compact for resource-constrained RTOS (<50KB RAM)
	  - Linux Minimal: Essential features for storage-limited Linux systems
	  - Linux Standard: Balanced configuration for typical Linux products
	  - Linux Full: All features enabled for development and testing

	  After loading a template, you can further customize individual options.

	  If you prefer manual configuration, select "None".

config TEMPLATE_NONE
	bool "None - Manual configuration"
	help
	  Configure all options manually.

	  Choose this if you want full control over every configuration option,
	  or if you're loading an existing defconfig file.

config TEMPLATE_RTOS_MINIMAL
	bool "RTOS Minimal - Ultra-compact (<50KB)"
	help
	  Optimized for RTOS with severe memory constraints.

	  Target: <50KB total footprint
	  Suitable for: Cortex-M MCUs with 32-64KB RAM

	  Features:
	  - OSAL: Basic IPC (mutex + semaphore), minimal file ops, threads
	  - HAL: Only essential drivers
	  - No network support
	  - No advanced features

	  Use case: Simple sensor nodes, actuator controllers

config TEMPLATE_LINUX_MINIMAL
	bool "Linux Minimal - Essential features (~100KB)"
	help
	  Minimal Linux configuration for storage-constrained systems.

	  Target: ~100KB total footprint
	  Suitable for: Embedded Linux with limited flash/RAM

	  Features:
	  - OSAL: Standard IPC, basic file ops, threads, limited network
	  - HAL: Common drivers (CAN, UART, GPIO)
	  - Basic PDL support
	  - 1-2 applications

	  Use case: Simple data collectors, edge gateways

config TEMPLATE_LINUX_STANDARD
	bool "Linux Standard - Balanced configuration (~200KB) [Recommended]"
	help
	  Recommended configuration for typical Linux-based products.

	  Target: ~200KB total footprint
	  Suitable for: AM625, i.MX6/8, Zynq and similar SoCs

	  Features:
	  - OSAL: Full IPC, complete file ops, threads, full network
	  - HAL: All drivers (CAN, UART, I2C, SPI, GPIO, Watchdog)
	  - PCL: Full peripheral configuration
	  - PDL: All peripheral drivers
	  - ACL: Application configuration layer
	  - Multiple applications

	  Use case: Satellite payloads, industrial controllers, IoT gateways

	  This is the recommended starting point for most projects.

config TEMPLATE_LINUX_FULL
	bool "Linux Full - All features (~300KB)"
	help
	  All features enabled for development and testing.

	  Target: ~300KB total footprint
	  Suitable for: Development, testing, feature-rich products

	  Features:
	  - All OSAL features including debug and statistics
	  - All HAL drivers and advanced features
	  - All PCL/PDL/ACL features
	  - All applications
	  - Debug logging and diagnostics

	  Use case: Development, testing, debugging, feature exploration

endchoice

config EXPERT
	bool "Expert mode - Show advanced options"
	default n
	help
	  Enable expert mode to access advanced configuration options.

	  When enabled, you can:
	  - Fine-tune individual file-level compilation
	  - Access debug and diagnostic options
	  - Configure resource limits precisely
	  - Override automatic dependency resolution

	  Warning: Incorrect advanced settings may result in build failures
	  or runtime errors. Only enable if you know what you're doing.

	  If unsure, say N.

endmenu

# ============================================================================
# Product Selection
# ============================================================================
# Select which products to build. Multiple products can be enabled
# simultaneously for parallel development and testing.
# ============================================================================

menu "Product Selection"

config PRODUCT_CCM
	bool "CCM Product"
	default n
	help
	  Enable CCM (Central Control Module) product.

	  CCM is a satellite payload control and data management system
	  designed for H200 platform with AM625 SoC.

	  If unsure, say N.

config PRODUCT_SAMPLE
	bool "Sample Product"
	default n
	help
	  Enable Sample product (demonstration and template).

	  Sample product provides a minimal working example showing
	  how to structure a product using the EMS SDK framework.

	  Useful for learning and as a starting point for new products.

endmenu

# ============================================================================
# Toolchain Configuration
# ============================================================================

menu "Toolchain Configuration"

config TOOLCHAIN_PATH
	string "Toolchain path"
	default ""
	help
	  Absolute path to the cross-compilation toolchain.
	  Leave empty to use system default compiler.

config TOOLCHAIN_PREFIX
	string "Toolchain prefix"
	default ""
	help
	  Toolchain prefix (e.g., aarch64-linux-gnu-).
	  Leave empty for native compilation.

endmenu

# ============================================================================
# Core Components Configuration
# ============================================================================
# Configure SDK core components that are shared across all products.
# These components provide fundamental abstractions and services.
# ============================================================================

menu "Core Components"

osource "$SDK_PATH/core/osal/Kconfig"
osource "$SDK_PATH/core/hal/Kconfig"
osource "$SDK_PATH/core/pcl/Kconfig"
osource "$SDK_PATH/core/pdl/Kconfig"
osource "$SDK_PATH/core/acl/Kconfig"

endmenu

# ============================================================================
# Product-Specific Configuration
# ============================================================================
# Each enabled product's configuration menu appears here.
# Product configurations are only shown if the product is enabled above.
# ============================================================================

menu "Product Configuration"

if PRODUCT_CCM
	osource "$SDK_PATH/products/ccm/Kconfig"
endif

if PRODUCT_SAMPLE
	osource "$SDK_PATH/products/sample/Kconfig"
endif

endmenu
