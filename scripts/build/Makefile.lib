# ============================================================================
# 库构建规则（静态库和动态库）
# ============================================================================
# 本文件被 Makefile.build 包含，提供库构建的专用规则

# ============================================================================
# 静态库构建规则
# ============================================================================

# 静态库规则模板
define STATIC_LIB_template
$(1): $(2)
	@mkdir -p $$(dir $$@)
	@echo "  AR      $$@"
	$(Q)$$(AR) rcs $$@ $$^
endef

# 为所有静态库目标生成规则
define register-static-lib
$(eval $(call STATIC_LIB_template,\
  $(LIB_OUTPUT_DIR)/$(1),\
  $(addprefix $(OBJ_OUTPUT_BASE)/,$(if $($(1)-objs),$($(1)-objs),$(obj-y)))))
endef

# ============================================================================
# 动态库构建规则
# ============================================================================

# 动态库规则模板
define DYNAMIC_LIB_template
$(1): $(2)
	@mkdir -p $$(dir $$@)
	@echo "  LD      $$@"
	$(Q)$$(CC) -shared $$(CFLAGS) $$(LDFLAGS) -o $$@ $$^ $$(LDLIBS)
endef

# 为所有动态库目标生成规则
define register-dynamic-lib
$(eval $(call DYNAMIC_LIB_template,\
  $(LIB_OUTPUT_DIR)/$(1),\
  $(addprefix $(OBJ_OUTPUT_BASE)/,$(if $($(1)-objs),$($(1)-objs),$(obj-y)))))
endef

# ============================================================================
# 库构建类型判断
# ============================================================================

# 根据配置决定是否构建静态库
BUILD_STATIC := $(CONFIG_LIBRARY_BUILD_TYPE_STATIC)
BUILD_DYNAMIC := $(CONFIG_LIBRARY_BUILD_TYPE_DYNAMIC)

# 注册静态库目标
ifeq ($(BUILD_STATIC),y)
  $(foreach target,$(obj-s),\
    $(eval $(target)-type := static)\
    $(eval TARGETS += $(target))\
    $(call register-static-lib,$(target)))
endif

# 注册动态库目标
ifeq ($(BUILD_DYNAMIC),y)
  $(foreach target,$(obj-d),\
    $(eval $(target)-type := dynamic)\
    $(eval TARGETS += $(target))\
    $(call register-dynamic-lib,$(target)))
endif

# ============================================================================
# 库目标路径注册
# ============================================================================

# 为每个库目标注册输出路径
$(foreach target,$(obj-s) $(obj-d),\
  $(eval $(target)-target-path := $(LIB_OUTPUT_DIR)/$(target))\
  $(if $(filter $(target),$(TARGETS)),$(eval all: $($(target)-target-path))))
