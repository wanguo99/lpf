# =============================================================================
# EMS Core 模块构建配置
# =============================================================================
# 此文件定义核心模块的构建顺序和依赖关系
# =============================================================================

# 核心模块构建顺序（按依赖关系排列）
# OSAL 是基础，必须最先构建
# HAL 依赖 OSAL
# PCL 依赖 OSAL 和 HAL
# PDL 依赖 OSAL、HAL 和 PCL
# ACL 依赖 OSAL 和 PDL

obj-$(CONFIG_OSAL) += osal/
obj-$(CONFIG_HAL)  += hal/
obj-$(CONFIG_PCL)  += pcl/
obj-$(CONFIG_PDL)  += pdl/
obj-$(CONFIG_ACL)  += acl/

# 模块依赖关系（确保正确的构建顺序）
hal/: osal/
pcl/: hal/ osal/
pdl/: pcl/ hal/ osal/
acl/: pdl/ pcl/ hal/ osal/
