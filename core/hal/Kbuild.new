# =============================================================================
# HAL (Hardware Abstraction Layer) 模块构建配置
# =============================================================================
# 此文件展示如何构建动态库和静态库
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 动态库构建示例
# -----------------------------------------------------------------------------
# 构建 libhal.so 动态库
so-$(CONFIG_HAL) += hal

# libhal.so 的源文件（编译为 .o）
hal-objs := hal_init.o

# 根据配置条件编译不同的驱动
hal-objs += $(if $(CONFIG_HAL_CAN),hal_can_linux.o)
hal-objs += $(if $(CONFIG_HAL_UART),hal_uart_linux.o)
hal-objs += $(if $(CONFIG_HAL_I2C),hal_i2c_linux.o)
hal-objs += $(if $(CONFIG_HAL_SPI),hal_spi_linux.o)
hal-objs += $(if $(CONFIG_HAL_GPIO),hal_gpio_linux.o)
hal-objs += $(if $(CONFIG_HAL_WATCHDOG),hal_watchdog_linux.o)

# 动态库编译标志（必须包含 -fPIC）
hal-cflags-y := -fPIC

# 动态库链接标志
hal-ldflags := -shared -Wl,-soname,libhal.so.1
hal-ldflags += -L$(objtree)/lib -losal

# -----------------------------------------------------------------------------
# 2. 静态库构建示例（可选）
# -----------------------------------------------------------------------------
# 如果需要同时提供静态库版本，可以这样定义：
# lib-$(CONFIG_HAL_STATIC) += hal_static
# hal_static-objs := $(hal-objs)

# -----------------------------------------------------------------------------
# 3. 编译标志配置
# -----------------------------------------------------------------------------
# 所有源文件的通用编译标志
ccflags-y += -I$(src)/include
ccflags-y += -I$(srctree)/core/osal/include
ccflags-$(CONFIG_DEBUG_HAL) += -DDEBUG_HAL

# 特定文件的编译标志
CFLAGS_hal_can_linux.o := -DCAN_DRIVER_VERSION=\"1.0\"

# -----------------------------------------------------------------------------
# 4. 头文件导出（用于 make headers_install）
# -----------------------------------------------------------------------------
header-y := hal.h
header-y += hal_can.h
header-y += hal_uart.h
header-y += hal_i2c.h
header-y += hal_spi.h
header-y += hal_gpio.h
header-y += hal_watchdog.h

# -----------------------------------------------------------------------------
# 5. 清理规则
# -----------------------------------------------------------------------------
clean-files := *.so *.so.* *.a
