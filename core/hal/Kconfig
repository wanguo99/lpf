# HAL (Hardware Abstraction Layer) Configuration

menuconfig HAL
	bool "HAL (Hardware Abstraction Layer)"
	default y
	help
	  Hardware Abstraction Layer provides unified hardware driver interfaces.
	  HAL depends on OSAL for system calls and platform abstraction.

	  If unsure, say Y.

if HAL

menu "HAL Driver Selection"

menuconfig HAL_CAN
	bool "CAN bus driver"
	default y
	help
	  Enable Controller Area Network (CAN) bus driver.
	  Supports SocketCAN interface on Linux.

	  If unsure, say Y.

if HAL_CAN

config HAL_CAN_FILTER
	bool "CAN filter support"
	default y
	help
	  Enable CAN message filtering capability.
	  Allows filtering CAN frames by ID.

config HAL_CAN_ERROR_HANDLING
	bool "CAN error handling"
	default y
	help
	  Enable CAN bus error detection and handling.
	  Reports bus-off, error-warning, and error-passive states.

config HAL_CAN_LOOPBACK
	bool "CAN loopback mode"
	default n
	help
	  Enable CAN loopback mode for testing.
	  Useful for development and debugging without physical CAN bus.

endif # HAL_CAN

menuconfig HAL_UART
	bool "UART driver"
	default y
	help
	  Enable Universal Asynchronous Receiver-Transmitter (UART) driver.
	  Provides serial communication interface.

	  If unsure, say Y.

if HAL_UART

config HAL_UART_FLOW_CONTROL
	bool "UART hardware flow control"
	default n
	help
	  Enable RTS/CTS hardware flow control.
	  Useful for high-speed serial communication.

config HAL_UART_RS485
	bool "RS485 mode support"
	default n
	help
	  Enable RS485 half-duplex mode support.
	  Automatically controls DE/RE signals.

endif # HAL_UART

menuconfig HAL_I2C
	bool "I2C bus driver"
	default n
	help
	  Enable Inter-Integrated Circuit (I2C) bus driver.
	  Supports master mode operation.

	  If unsure, say N.

if HAL_I2C

config HAL_I2C_SLAVE
	bool "I2C slave mode"
	default n
	help
	  Enable I2C slave mode support.
	  Allows device to act as I2C slave.

config HAL_I2C_10BIT_ADDR
	bool "I2C 10-bit addressing"
	default n
	help
	  Enable 10-bit I2C addressing mode.
	  Standard mode uses 7-bit addressing.

endif # HAL_I2C

menuconfig HAL_SPI
	bool "SPI bus driver"
	default n
	help
	  Enable Serial Peripheral Interface (SPI) driver.
	  Supports master mode operation.

	  If unsure, say N.

if HAL_SPI

config HAL_SPI_DMA
	bool "SPI DMA support"
	default n
	help
	  Enable DMA (Direct Memory Access) for SPI transfers.
	  Improves performance for large data transfers.

config HAL_SPI_SLAVE
	bool "SPI slave mode"
	default n
	help
	  Enable SPI slave mode support.
	  Allows device to act as SPI slave.

endif # HAL_SPI

menuconfig HAL_GPIO
	bool "GPIO driver"
	default y
	help
	  Enable General Purpose Input/Output (GPIO) driver.
	  Uses sysfs interface on Linux.

	  If unsure, say Y.

if HAL_GPIO

config HAL_GPIO_INTERRUPT
	bool "GPIO interrupt support"
	default y
	help
	  Enable GPIO interrupt/edge detection.
	  Supports rising, falling, and both edges.

config HAL_GPIO_DEBOUNCE
	bool "GPIO debounce support"
	default n
	help
	  Enable software debounce for GPIO inputs.
	  Filters out noise and glitches.

endif # HAL_GPIO

menuconfig HAL_WATCHDOG
	bool "Watchdog driver"
	default y
	help
	  Enable hardware watchdog timer driver.
	  Provides system reset on software hang.

	  If unsure, say Y.

if HAL_WATCHDOG

config HAL_WATCHDOG_PRETIMEOUT
	bool "Watchdog pretimeout support"
	default n
	help
	  Enable watchdog pretimeout notification.
	  Triggers interrupt before actual timeout.

endif # HAL_WATCHDOG

endmenu

menu "HAL Advanced Features"

config HAL_DEBUG
	bool "HAL debug logging"
	default n
	help
	  Enable verbose debug logging in HAL layer.
	  Useful for driver development and troubleshooting.

config HAL_STATISTICS
	bool "HAL statistics collection"
	default n
	help
	  Enable HAL driver statistics collection.
	  Tracks transfer counts, errors, and performance metrics.

config HAL_POWER_MANAGEMENT
	bool "HAL power management"
	default n
	help
	  Enable power management support in HAL drivers.
	  Allows drivers to enter low-power states.

endmenu

menu "HAL Build Configuration"

config HAL_BUILD_STATIC
	bool "Build static library (.a)"
	default y
	help
	  Build HAL as a static library (libhal.a).

config HAL_BUILD_SHARED
	bool "Build shared library (.so)"
	default y
	help
	  Build HAL as a shared library (libhal.so).

endmenu

endif # HAL
