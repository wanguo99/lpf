# HAL (Hardware Abstraction Layer) Configuration

menuconfig HAL
	bool "HAL (Hardware Abstraction Layer)"
	default n
	select OSAL
	help
	  Hardware Abstraction Layer provides unified hardware interfaces.
	  HAL depends on OSAL.

if HAL

# =============================================================================
# Platform Configuration
# =============================================================================

menu "Platform Configuration"

config PLATFORM_GENERIC_LINUX
	bool "Generic Linux platform"
	default y
	depends on OS_LINUX
	help
	  Enable generic Linux platform support.
	  Uses standard Linux drivers (SocketCAN, sysfs GPIO, etc).

endmenu

# =============================================================================
# Build Configuration
# =============================================================================

menu "Build Configuration"

config HAL_BUILD_STATIC
	bool "Build static library"
	default y
	help
	  Build libhal.a static library.

config HAL_BUILD_SHARED
	bool "Build shared library"
	default n
	help
	  Build libhal.so shared library.

endmenu

# =============================================================================
# Driver Configuration (Fine-grained per-driver control)
# =============================================================================

menu "Driver Configuration"

menuconfig HAL_CAN
	bool "CAN bus support"
	default y
	help
	  Enable CAN bus driver.

menuconfig HAL_UART
	bool "UART support"
	default y
	help
	  Enable UART/serial driver.

menuconfig HAL_I2C
	bool "I2C support"
	default y
	help
	  Enable I2C bus driver.

menuconfig HAL_SPI
	bool "SPI support"
	default y
	help
	  Enable SPI bus driver.

menuconfig HAL_GPIO
	bool "GPIO support"
	default y
	help
	  Enable GPIO driver.

menuconfig HAL_WATCHDOG
	bool "Watchdog support"
	default y
	help
	  Enable watchdog timer driver.

endmenu

# Platform-specific fine-grained configuration
source "core/hal/src/Kconfig.linux"
source "core/hal/src/Kconfig.macos"

# =============================================================================
# Advanced Features
# =============================================================================

menu "Advanced Features"

config HAL_DEBUG
	bool "Enable debug logging"
	default n
	help
	  Enable verbose debug logging in HAL.

config HAL_STATISTICS
	bool "Enable statistics"
	default n
	help
	  Enable HAL statistics collection.

config HAL_POWER_MANAGEMENT
	bool "Enable power management"
	default n
	help
	  Enable power management features.

endmenu

endif # HAL
