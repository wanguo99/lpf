# ============================================================================
# HAL Generic Linux Platform Configuration
# ============================================================================
# Fine-grained per-driver configuration for Generic Linux platform
# ============================================================================

if PLATFORM_GENERIC_LINUX

# ============================================================================
# CAN Bus Driver
# ============================================================================

if HAL_CAN

config HAL_CAN_LINUX
	bool "Linux SocketCAN driver"
	default y
	help
	  Enable Linux SocketCAN driver.
	  Source: src/linux/hal_can_linux.c

endif # HAL_CAN

# ============================================================================
# GPIO Driver
# ============================================================================

if HAL_GPIO

config HAL_GPIO_LINUX
	bool "Linux sysfs GPIO driver"
	default y
	help
	  Enable Linux sysfs GPIO driver.
	  Source: src/linux/hal_gpio_linux.c

endif # HAL_GPIO

# ============================================================================
# I2C Driver
# ============================================================================

if HAL_I2C

config HAL_I2C_LINUX
	bool "Linux I2C driver"
	default y
	help
	  Enable Linux I2C driver (/dev/i2c-*).
	  Source: src/linux/hal_i2c_linux.c

endif # HAL_I2C

# ============================================================================
# SPI Driver
# ============================================================================

if HAL_SPI

config HAL_SPI_LINUX
	bool "Linux SPI driver"
	default y
	help
	  Enable Linux SPI driver (/dev/spidev*).
	  Source: src/linux/hal_spi_linux.c

endif # HAL_SPI

# ============================================================================
# UART Driver
# ============================================================================

if HAL_UART

config HAL_UART_LINUX
	bool "Linux serial driver"
	default y
	help
	  Enable Linux serial driver (/dev/tty*).
	  Source: src/linux/hal_serial_linux.c

endif # HAL_UART

# ============================================================================
# Watchdog Driver
# ============================================================================

if HAL_WATCHDOG

config HAL_WATCHDOG_LINUX
	bool "Linux watchdog driver"
	default y
	help
	  Enable Linux watchdog driver (/dev/watchdog).
	  Source: src/linux/hal_watchdog_linux.c

endif # HAL_WATCHDOG

endif # PLATFORM_GENERIC_LINUX
