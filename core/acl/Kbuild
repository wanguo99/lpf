# =============================================================================
# ACL (Application Configuration Layer) 模块构建配置
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 构建目标配置
# -----------------------------------------------------------------------------
# 根据 Kconfig 配置决定构建静态库或动态库

# 静态库
lib-$(CONFIG_ACL_BUILD_STATIC) += acl

# 动态库
so-$(CONFIG_ACL_BUILD_SHARED) += acl

# -----------------------------------------------------------------------------
# 2. 源文件列表
# -----------------------------------------------------------------------------
acl-objs := \
	src/acl_api.o \
	src/acl_telemetry_cache.o

# -----------------------------------------------------------------------------
# 3. 编译标志
# -----------------------------------------------------------------------------
# 通用编译标志
ccflags-y += -I$(src)/include
ccflags-y += -I$(srctree)/core/pdl/include
ccflags-y += -I$(srctree)/core/pcl/include
ccflags-y += -I$(srctree)/core/hal/include
ccflags-y += -I$(srctree)/core/osal/include
ccflags-y += -I$(srctree)/include

# 动态库需要 -fPIC
acl-cflags-y := $(if $(CONFIG_ACL_BUILD_SHARED),-fPIC)

# 调试标志
ccflags-$(CONFIG_DEBUG_ACL) += -DDEBUG_ACL

# -----------------------------------------------------------------------------
# 4. 链接标志
# -----------------------------------------------------------------------------
# 动态库链接标志
acl-ldflags := $(if $(CONFIG_ACL_BUILD_SHARED),-shared -Wl$(comma)-soname$(comma)libacl.so.1)
acl-ldflags += -L$(objtree)/lib -lpdl -lpcl -lhal -losal

# -----------------------------------------------------------------------------
# 5. 头文件导出
# -----------------------------------------------------------------------------
header-y := acl.h acl_api.h acl_types.h

# -----------------------------------------------------------------------------
# 6. 清理规则
# -----------------------------------------------------------------------------
clean-files := *.so *.so.* *.a
