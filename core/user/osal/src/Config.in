# ============================================================================
# OSAL Linux User-Space Backend Configuration
# ============================================================================
# Fine-grained per-file configuration for the Linux user-space backend
# ============================================================================

if OSAL_OS_POSIX

# ============================================================================
# IPC (Inter-Process Communication)
# ============================================================================

if OSAL_IPC

config OSAL_IPC_ATOMIC
	bool "Atomic operations"
	default n
	help
	  Enable atomic operations support.
	  Source: inline header implementation

config OSAL_IPC_MUTEX
	bool "Mutex support"
	default n
	help
	  Enable mutex (mutual exclusion) support.
	  Source: src/ipc/osal_mutex.c

config OSAL_IPC_RWLOCK
	bool "Read-write lock support"
	default n
	help
	  Enable read-write lock support for read-heavy scenarios.
	  Allows multiple readers or single writer.
	  Source: src/ipc/osal_rwlock.c

config OSAL_IPC_SEMAPHORE
	bool "Semaphore support"
	default n
	help
	  Enable semaphore support.
	  Source: src/ipc/osal_semaphore.c

config OSAL_IPC_COND
	bool "Condition variable support"
	default n
	depends on OSAL_IPC_MUTEX
	help
	  Enable condition variable support.
	  Requires mutex support.
	  Source: src/ipc/osal_cond.c

config OSAL_IPC_SHM
	bool "Shared memory support"
	default n
	help
	  Enable shared memory support.
	  Source: src/ipc/osal_shm.c

config OSAL_IPC_SHM_CACHE
	bool "Shared memory cache"
	default n
	depends on OSAL_IPC_SHM
	help
	  Enable shared memory cache optimization.
	  Requires shared memory support.
	  Source: src/ipc/osal_shm_cache.c

endif # OSAL_IPC

# ============================================================================
# Library Functions
# ============================================================================

menu "Library Functions"

config OSAL_LIB_ERRNO
	bool "Error number handling"
	default n
	help
	  Enable errno operations.
	  Source: src/lib/osal_errno.c

config OSAL_LIB_HEAP
	bool "Heap memory management"
	default n
	help
	  Enable heap memory operations (malloc/free wrappers).
	  Source: src/lib/osal_heap.c

config OSAL_LIB_STDIO
	bool "Standard I/O"
	default n
	help
	  Enable standard I/O operations (printf wrappers).
	  Source: src/lib/osal_stdio.c

config OSAL_LIB_STRING
	bool "String operations"
	default n
	help
	  Enable string operations (safe string functions).
	  Source: src/lib/osal_string.c

endmenu

# ============================================================================
# System Operations
# ============================================================================

if OSAL_FILE

config OSAL_SYS_CLOCK
	bool "Clock operations"
	default n
	help
	  Enable clock operations (clock_gettime, etc).
	  Source: src/sys/osal_clock.c

config OSAL_SYS_ENV
	bool "Environment variables"
	default n
	help
	  Enable environment variable operations.
	  Source: src/sys/osal_env.c

config OSAL_SYS_FILE
	bool "File operations"
	default n
	help
	  Enable file I/O operations.
	  Source: src/sys/osal_file.c

config OSAL_SYS_PROCESS
	bool "Process management"
	default n
	help
	  Enable process management (fork, exec, etc).
	  Source: src/sys/osal_process.c

config OSAL_SYS_SCHED
	bool "Scheduler operations"
	default n
	help
	  Enable scheduler operations (priority, affinity).
	  Source: src/sys/osal_sched.c

config OSAL_SYS_SELECT
	bool "Select/poll operations"
	default n
	help
	  Enable select/poll I/O multiplexing.
	  Source: src/sys/osal_select.c

endif # OSAL_FILE

# ============================================================================
# Thread Support
# ============================================================================

if OSAL_THREAD

config OSAL_SYS_THREAD
	bool "Thread operations"
	default n
	help
	  Enable thread creation and management.
	  Source: src/sys/osal_thread.c

config OSAL_SYS_TIME
	bool "Time operations"
	default n
	help
	  Enable time operations (sleep, delay, etc).
	  Source: src/sys/osal_time.c

endif # OSAL_THREAD

# ============================================================================
# Signal Support
# ============================================================================

if OSAL_SIGNAL

config OSAL_SYS_SIGNAL
	bool "Signal handling"
	default n
	help
	  Enable signal handling operations.
	  Source: src/sys/osal_signal.c

endif # OSAL_SIGNAL

# ============================================================================
# Network Support
# ============================================================================

if OSAL_NETWORK

config OSAL_NET_SOCKET
	bool "Socket operations"
	default n
	help
	  Enable socket operations (TCP/UDP).
	  Source: src/net/osal_socket.c

config OSAL_NET_TERMIOS
	bool "Terminal I/O (termios)"
	default n
	help
	  Enable terminal I/O control.
	  Source: src/net/osal_termios.c

config OSAL_NET_PTY
	bool "Pseudo-terminal support"
	default n
	help
	  Enable pseudo-terminal creation support.
	  Source: src/net/osal_pty.c

endif # OSAL_NETWORK

# ============================================================================
# Utility Functions
# ============================================================================

menu "Utility Functions"

config OSAL_UTIL_LOG
	bool "Logging support"
	default n
	help
	  Enable logging utilities.
	  Source: src/util/osal_log.c

config OSAL_UTIL_VERSION
	bool "Version information"
	default n
	help
	  Enable version information.
	  Source: src/util/osal_version.c

endmenu

endif # OSAL_OS_POSIX
