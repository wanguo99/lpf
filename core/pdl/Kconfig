# PDL (Peripheral Driver Layer) Configuration

menuconfig PDL
	bool "PDL (Peripheral Driver Layer)"
	default n
	select OSAL
	select HAL
	select PCL
	help
	  Peripheral Driver Layer provides unified peripheral management.
	  PDL depends on OSAL, HAL, and PCL.

	  If unsure, say Y.

if PDL

menu "PDL Build Configuration"

config PDL_BUILD_STATIC
	bool "Build static library (.a)"
	default y
	help
	  Build PDL as a static library (libpdl.a).

config PDL_BUILD_SHARED
	bool "Build shared library (.so)"
	default n
	help
	  Build PDL as a shared library (libpdl.so).

endmenu

menuconfig PDL_SATELLITE_SUPPORT
	bool "Satellite peripheral support"
	default n
	select HAL_CAN
	select OSAL_NETWORK
	help
	  Enable satellite peripheral management via CAN bus.

	  Satellites are remote sensor/actuator modules connected
	  via CAN bus, providing distributed I/O capabilities.

	  Requires: HAL_CAN, OSAL_NETWORK

	  If unsure, say Y.

source "core/pdl/src/pdl_satellite/Kconfig"

menuconfig PDL_BMC_SUPPORT
	bool "BMC peripheral support"
	default n
	select HAL_UART
	select OSAL_NETWORK
	help
	  Enable BMC (Baseboard Management Controller) peripheral support via UART/Ethernet.

	  BMC provides server management functions including power control,
	  sensor monitoring, and remote console access.

	  Requires: HAL_UART, OSAL_NETWORK

	  If unsure, say Y.

source "core/pdl/src/pdl_bmc/Kconfig"

menuconfig PDL_MCU_SUPPORT
	bool "MCU peripheral support"
	default n
	help
	  Enable MCU peripheral support via CAN or UART.

	  MCU peripherals are microcontroller-based modules providing
	  specialized control and monitoring functions.

	  You can enable CAN-based or UART-based MCU support below.

	  If unsure, say Y.

if PDL_MCU_SUPPORT

config PDL_MCU_CAN_SUPPORT
	bool "MCU peripheral via CAN"
	default y
	select HAL_CAN
	select OSAL_NETWORK
	help
	  Enable MCU peripheral support via CAN bus.
	  Automatically enables HAL_CAN and OSAL_NETWORK.

config PDL_MCU_UART_SUPPORT
	bool "MCU peripheral via UART"
	default n
	select HAL_UART
	select OSAL_NETWORK
	help
	  Enable MCU peripheral support via UART.
	  Automatically enables HAL_UART and OSAL_NETWORK.

endif # PDL_MCU_SUPPORT

source "core/pdl/src/pdl_mcu/Kconfig"

menuconfig PDL_WATCHDOG_SUPPORT
	bool "Watchdog peripheral support"
	default n
	select HAL_WATCHDOG
	select OSAL_THREAD
	help
	  Enable watchdog peripheral support.

	  Provides hardware watchdog management for system reliability,
	  including automatic reset on software hang.

	  Requires: HAL_WATCHDOG, OSAL_THREAD

	  If unsure, say Y.

endif # PDL
