# PDL MCU 驱动配置

if PDL_MCU_SUPPORT

config PDL_MCU_CAN_SUPPORT
	bool "MCU peripheral via CAN"
	default y
	select HAL_CAN
	select OSAL_NETWORK
	help
	  Enable MCU peripheral support via CAN bus.

	  CAN-based MCU communication provides:
	  - Multi-drop network (multiple MCUs on one bus)
	  - Robust error detection (CRC, bit stuffing)
	  - Priority-based arbitration
	  - Up to 1 Mbps data rate

	  Memory footprint: ~6KB

	  Use cases:
	  - Automotive-style distributed control
	  - Industrial automation networks
	  - Systems with multiple MCU modules

	  Dependencies: HAL_CAN, OSAL_NETWORK

	  Recommended: Enable for CAN-based systems

config PDL_MCU_UART_SUPPORT
	bool "MCU peripheral via UART"
	default n
	select HAL_UART
	select OSAL_NETWORK
	help
	  Enable MCU peripheral support via UART.

	  UART-based MCU communication provides:
	  - Simple point-to-point connection
	  - Lower cost (no CAN transceiver needed)
	  - Flexible baud rates
	  - Easy debugging (can monitor with serial terminal)

	  Memory footprint: ~5KB

	  Use cases:
	  - Single MCU module systems
	  - Cost-sensitive designs
	  - Debug and development

	  Dependencies: HAL_UART, OSAL_NETWORK

	  Recommended: Enable for UART-based systems

menu "MCU Driver Configuration (Expert)"
	visible if EXPERT

config PDL_MCU
	bool "MCU core driver"
	default y if PDL_MCU_CAN_SUPPORT || PDL_MCU_UART_SUPPORT
	help
	  Enable MCU core driver functions.
	  Source: src/pdl_mcu/pdl_mcu.c

	  Automatically enabled when transport is selected.

config PDL_MCU_CAN
	bool "MCU CAN transport"
	default y if PDL_MCU_CAN_SUPPORT
	depends on HAL_CAN
	help
	  Enable MCU CAN bus transport.
	  Source: src/pdl_mcu/pdl_mcu_can.c

config PDL_MCU_SERIAL
	bool "MCU serial transport"
	default y if PDL_MCU_UART_SUPPORT
	depends on HAL_UART
	help
	  Enable MCU serial (UART) transport.
	  Source: src/pdl_mcu/pdl_mcu_serial.c

config PDL_MCU_PROTOCOL
	bool "MCU protocol handler"
	default y if PDL_MCU_CAN_SUPPORT || PDL_MCU_UART_SUPPORT
	help
	  Enable MCU communication protocol handler.
	  Source: src/pdl_mcu/pdl_mcu_protocol.c

endmenu

endif # PDL_MCU_SUPPORT
