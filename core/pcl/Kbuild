# =============================================================================
# PCL (Peripheral Configuration Library) 模块构建配置
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 构建目标配置
# -----------------------------------------------------------------------------
# 根据 Kconfig 配置决定构建静态库或动态库

# 静态库
lib-$(CONFIG_PCL_BUILD_STATIC) += pcl

# 动态库
so-$(CONFIG_PCL_BUILD_SHARED) += pcl

# -----------------------------------------------------------------------------
# 2. 源文件列表
# -----------------------------------------------------------------------------
pcl-objs := \
	src/pcl_api.o \
	src/pcl_register.o

# -----------------------------------------------------------------------------
# 3. 编译标志
# -----------------------------------------------------------------------------
# 通用编译标志
ccflags-y += -I$(src)/include
ccflags-y += -I$(src)/include/api
ccflags-y += -I$(srctree)/core/hal/include
ccflags-y += -I$(srctree)/core/osal/include
ccflags-y += -I$(srctree)/include

# 动态库需要 -fPIC
pcl-cflags-y := $(if $(CONFIG_PCL_BUILD_SHARED),-fPIC)

# 调试标志
ccflags-$(CONFIG_DEBUG_PCL) += -DDEBUG_PCL

# -----------------------------------------------------------------------------
# 4. 链接标志
# -----------------------------------------------------------------------------
# 动态库链接标志
pcl-ldflags := $(if $(CONFIG_PCL_BUILD_SHARED),-shared -Wl$(comma)-soname$(comma)libpcl.so.1)
pcl-ldflags += -L$(objtree)/lib -lhal -losal

# -----------------------------------------------------------------------------
# 5. 头文件导出
# -----------------------------------------------------------------------------
header-y := pcl.h pcl_api.h

# -----------------------------------------------------------------------------
# 6. 清理规则
# -----------------------------------------------------------------------------
clean-files := *.so *.so.* *.a
