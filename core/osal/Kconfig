# OSAL (Operating System Abstraction Layer) Configuration

config OSAL
	bool "OSAL (Operating System Abstraction Layer)"
	default y
	help
	  Operating System Abstraction Layer provides unified OS interfaces.
	  OSAL is the foundation layer required by all other modules.

if OSAL

config OSAL_MAX_TASKS
	int "Maximum number of tasks"
	default 64
	range 1 256
	help
	  Maximum number of concurrent tasks supported by OSAL.

config OSAL_MAX_QUEUES
	int "Maximum number of queues"
	default 32
	range 1 128
	help
	  Maximum number of message queues.

config OSAL_MAX_MUTEXES
	int "Maximum number of mutexes"
	default 32
	range 1 128
	help
	  Maximum number of mutex locks.

config OSAL_DEBUG_LOGGING
	bool "Enable debug logging"
	default n
	help
	  Enable verbose debug logging in OSAL layer.

choice
	prompt "OSAL library type"
	default OSAL_LIB_TYPE_DEFAULT
	help
	  Select the library type for OSAL.
	  This overrides the global BUILD_SHARED_LIBS setting.

config OSAL_LIB_TYPE_DEFAULT
	bool "Use global setting"
	help
	  Use the global BUILD_SHARED_LIBS setting.

config OSAL_LIB_TYPE_SHARED
	bool "Shared library (.so)"
	help
	  Build OSAL as a shared library.

config OSAL_LIB_TYPE_STATIC
	bool "Static library (.a)"
	help
	  Build OSAL as a static library.

config OSAL_LIB_TYPE_BOTH
	bool "Both shared and static"
	help
	  Build both shared and static versions of OSAL.

endchoice

endif # OSAL
