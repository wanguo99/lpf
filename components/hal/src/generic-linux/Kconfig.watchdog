# HAL Watchdog 驱动配置

if HAL_WATCHDOG

config HAL_WATCHDOG_LINUX
	bool "Watchdog Linux driver"
	default y
	depends on PLATFORM_GENERIC_LINUX
	help
	  Enable Watchdog driver for Linux.
	  Source: src/generic-linux/hal_watchdog_linux.c

config HAL_WATCHDOG_PRETIMEOUT
	bool "Watchdog pretimeout"
	default y
	help
	  Enable watchdog pretimeout notification.

endif # HAL_WATCHDOG
