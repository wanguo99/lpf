# HAL I2C 驱动配置

if HAL_I2C

config HAL_I2C_LINUX
	bool "I2C Linux driver"
	default y
	depends on PLATFORM_GENERIC_LINUX
	help
	  Enable I2C driver for Linux.
	  Source: src/generic-linux/hal_i2c_linux.c

config HAL_I2C_SLAVE
	bool "I2C slave mode"
	default y
	help
	  Enable I2C slave mode support.

config HAL_I2C_10BIT_ADDR
	bool "I2C 10-bit addressing"
	default y
	help
	  Enable 10-bit I2C addressing.

endif # HAL_I2C
