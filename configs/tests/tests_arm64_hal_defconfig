# ============================================================================
# ARM64 HAL Test Configuration
# ============================================================================
# 专注于 HAL 层的 ARM64 平台测试配置
# 包含完整的 HAL 驱动和测试，基于 ARM64 架构
# ============================================================================

# Architecture and OS
CONFIG_OS_LINUX=y
CONFIG_ARCH_ARM64=y

# Platform
CONFIG_PLATFORM_LINUX=y

# Core Components - HAL Stack
CONFIG_OSAL=y
CONFIG_HAL=y
CONFIG_TEST_FRAMEWORK=y

# Build Configuration - Shared Libraries for Testing
CONFIG_OSAL_BUILD_SHARED=y
CONFIG_HAL_BUILD_SHARED=y

# HAL Drivers - All Enabled
CONFIG_HAL_CAN=y
CONFIG_HAL_UART=y
CONFIG_HAL_I2C=y
CONFIG_HAL_SPI=y
CONFIG_HAL_GPIO=y
CONFIG_HAL_WATCHDOG=y

# HAL Linux Drivers - All Enabled
CONFIG_HAL_CAN_LINUX=y
CONFIG_HAL_GPIO_LINUX=y
CONFIG_HAL_I2C_LINUX=y
CONFIG_HAL_SPI_LINUX=y
CONFIG_HAL_UART_LINUX=y
CONFIG_HAL_WATCHDOG_LINUX=y

# OSAL Features - Required for HAL
CONFIG_OSAL_IPC=y
CONFIG_OSAL_FILE=y
CONFIG_OSAL_THREAD=y
CONFIG_OSAL_NETWORK=y

# OSAL IPC - Required for HAL
CONFIG_OSAL_IPC_MUTEX=y
CONFIG_OSAL_IPC_SEMAPHORE=y
CONFIG_OSAL_IPC_ATOMIC=y

# OSAL Library - Required for HAL
CONFIG_OSAL_LIB_ERRNO=y
CONFIG_OSAL_LIB_HEAP=y
CONFIG_OSAL_LIB_STRING=y
CONFIG_OSAL_LIB_STDIO=y

# OSAL System - Required for HAL
CONFIG_OSAL_SYS_CLOCK=y
CONFIG_OSAL_SYS_FILE=y
CONFIG_OSAL_SYS_PROCESS=y
CONFIG_OSAL_SYS_THREAD=y
CONFIG_OSAL_SYS_TIME=y
CONFIG_OSAL_SYS_SELECT=y
CONFIG_OSAL_SYS_POLL=y

# OSAL Network - Required for HAL
CONFIG_OSAL_NET_SOCKET=y
CONFIG_OSAL_NET_TERMIOS=y

# OSAL Utility - Required for HAL
CONFIG_OSAL_UTIL_LOG=y

# Testing - HAL Only
CONFIG_BUILD_TESTING=y
CONFIG_TEST_UNIT=y

# HAL Unit Tests - All Enabled
CONFIG_TEST_HAL=y
CONFIG_TEST_HAL_ALL=y
CONFIG_TEST_HAL_CAN=y
CONFIG_TEST_HAL_GPIO=y
CONFIG_TEST_HAL_I2C=y
CONFIG_TEST_HAL_SERIAL=y
CONFIG_TEST_HAL_SPI=y
CONFIG_TEST_HAL_WATCHDOG=y

# Other test modules disabled
# CONFIG_TEST_OSAL is not set
# CONFIG_TEST_PDL is not set
# CONFIG_TEST_PRL is not set
# CONFIG_TEST_PCONFIG is not set
# CONFIG_TEST_ACONFIG is not set
# CONFIG_TEST_PERFORMANCE is not set
# CONFIG_TEST_STRESS is not set
# CONFIG_TEST_SYSTEM is not set

# Other Modules - Disabled
# CONFIG_PCL is not set
# CONFIG_PDL is not set
# CONFIG_PRL is not set
# CONFIG_ACL is not set

# Products - Disabled
# CONFIG_PRODUCT_CCM is not set
