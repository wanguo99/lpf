# ============================================================================
# PRL Protocol Test Configuration
# ============================================================================
# PRL 协议层测试配置
# 用于测试所有设备协议的编解码功能
# ============================================================================

# Architecture and OS
CONFIG_OS_LINUX=y
CONFIG_ARCH_ARM64=y
CONFIG_OSAL_OS_POSIX=y

# Platform
CONFIG_PLATFORM_LINUX=y

# Core Components - OSAL + PRL
CONFIG_OSAL=y
CONFIG_TEST_FRAMEWORK=y
CONFIG_PRL=y

# Build Configuration
CONFIG_OSAL_BUILD_SHARED=y
CONFIG_PRL_BUILD_SHARED=y

# PRL Protocols - All Enabled for Testing
CONFIG_PRL_MCU=y
CONFIG_PRL_CCM=y
CONFIG_PRL_PMC=y
CONFIG_PRL_GSC=y
CONFIG_PRL_POWER=y

# PRL Features - All Enabled for Testing
CONFIG_PRL_CRC_CHECK=y
CONFIG_PRL_SEQUENCE_CHECK=y
CONFIG_PRL_TIMESTAMP_CHECK=y
CONFIG_PRL_MAX_PAYLOAD_SIZE=4096

# OSAL Features - Required for PRL
CONFIG_OSAL_IPC=y
CONFIG_OSAL_THREAD=y
CONFIG_OSAL_NETWORK=y
CONFIG_OSAL_FILE=y

# OSAL IPC
CONFIG_OSAL_IPC_ATOMIC=y
CONFIG_OSAL_IPC_MUTEX=y

# OSAL Library
CONFIG_OSAL_LIB_ERRNO=y
CONFIG_OSAL_LIB_HEAP=y
CONFIG_OSAL_LIB_STDIO=y
CONFIG_OSAL_LIB_STRING=y

# OSAL System
CONFIG_OSAL_SYS_CLOCK=y
CONFIG_OSAL_SYS_ENV=y
CONFIG_OSAL_SYS_FILE=y
CONFIG_OSAL_SYS_PROCESS=y
CONFIG_OSAL_SYS_SCHED=y
CONFIG_OSAL_SYS_SELECT=y
CONFIG_OSAL_SYS_THREAD=y
CONFIG_OSAL_SYS_TIME=y

# OSAL Network
CONFIG_OSAL_NET_SOCKET=y

# OSAL Utility
CONFIG_OSAL_UTIL_LOG=y
CONFIG_OSAL_UTIL_VERSION=y

# Testing - Enabled
CONFIG_BUILD_TESTING=y
CONFIG_TEST_UNIT=y

# PRL Unit Tests - All Enabled
CONFIG_TEST_PRL=y
CONFIG_TEST_PRL_ALL=y
CONFIG_TEST_PRL_COMMON=y
CONFIG_TEST_PRL_DEVICE=y

# Other test modules disabled
# CONFIG_TEST_OSAL is not set
# CONFIG_TEST_HAL is not set
# CONFIG_TEST_PDL is not set
# CONFIG_TEST_PCONFIG is not set
# CONFIG_TEST_ACONFIG is not set
# CONFIG_TEST_PERFORMANCE is not set
# CONFIG_TEST_STRESS is not set
# CONFIG_TEST_SYSTEM is not set

# Products - All Disabled
# CONFIG_PRODUCT_CCM is not set

# HAL - Disabled
# CONFIG_HAL is not set

# PDL - Disabled
# CONFIG_PDL is not set
