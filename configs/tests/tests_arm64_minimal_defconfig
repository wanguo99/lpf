# ============================================================================
# Minimal Configuration
# ============================================================================
# 最小化配置，仅包含核心功能
# 用于资源受限的嵌入式系统或快速原型验证
# ============================================================================

# Architecture and OS
CONFIG_OS_LINUX=y
CONFIG_ARCH_ARM64=y
CONFIG_OSAL_OS_POSIX=y

# Platform
CONFIG_PLATFORM_LINUX=y

# Core Components - Minimal
CONFIG_OSAL=y
CONFIG_TEST_FRAMEWORK=y

# Build Configuration - Static Libraries for Minimal Size
# CONFIG_OSAL_BUILD_SHARED is not set

# OSAL Features - Required for Test Framework
CONFIG_OSAL_THREAD=y
CONFIG_OSAL_FILE=y

# OSAL IPC - Required for Test Framework
CONFIG_OSAL_IPC=y
CONFIG_OSAL_IPC_MUTEX=y
CONFIG_OSAL_IPC_ATOMIC=y

# OSAL Library - Required for Test Framework
CONFIG_OSAL_LIB_ERRNO=y
CONFIG_OSAL_LIB_HEAP=y
CONFIG_OSAL_LIB_STDIO=y
CONFIG_OSAL_LIB_STRING=y

# OSAL System - Required for Test Framework
CONFIG_OSAL_SYS_CLOCK=y
CONFIG_OSAL_SYS_FILE=y
CONFIG_OSAL_SYS_PROCESS=y
CONFIG_OSAL_SYS_THREAD=y
CONFIG_OSAL_SYS_TIME=y

# OSAL Utility - Required for Test Framework
CONFIG_OSAL_UTIL_LOG=y
CONFIG_OSAL_UTIL_VERSION=y

# Testing - Enabled with Fast Tests Only
CONFIG_BUILD_TESTING=y
CONFIG_TEST_UNIT=y

# OSAL Unit Tests - Fast Tests Only (exclude stress and socket)
CONFIG_TEST_OSAL=y
# CONFIG_TEST_OSAL_ALL is not set
CONFIG_TEST_OSAL_ATOMIC=y
CONFIG_TEST_OSAL_CLOCK=y
CONFIG_TEST_OSAL_ERRNO=y
CONFIG_TEST_OSAL_LOG=y
CONFIG_TEST_OSAL_MUTEX=y
CONFIG_TEST_OSAL_STRING=y
CONFIG_TEST_OSAL_TIME=y
CONFIG_TEST_OSAL_VERSION=y
# CONFIG_TEST_OSAL_COND is not set
# CONFIG_TEST_OSAL_ENV is not set
# CONFIG_TEST_OSAL_FILE is not set
# CONFIG_TEST_OSAL_HEAP is not set
# CONFIG_TEST_OSAL_PROCESS is not set
# CONFIG_TEST_OSAL_RWLOCK is not set
# CONFIG_TEST_OSAL_SCHED is not set
# CONFIG_TEST_OSAL_SEMAPHORE is not set
# CONFIG_TEST_OSAL_SHM is not set
# CONFIG_TEST_OSAL_SIGNAL is not set
# CONFIG_TEST_OSAL_SOCKET is not set
# CONFIG_TEST_OSAL_STRESS is not set
# CONFIG_TEST_OSAL_THREAD is not set

# Other test categories disabled for minimal config
# CONFIG_TEST_HAL is not set
# CONFIG_TEST_PDL is not set
# CONFIG_TEST_PRL is not set
# CONFIG_TEST_PCONFIG is not set
# CONFIG_TEST_ACONFIG is not set
# CONFIG_TEST_PERFORMANCE is not set
# CONFIG_TEST_STRESS is not set
# CONFIG_TEST_SYSTEM is not set

# Products - All Disabled
# CONFIG_PRODUCT_CCM is not set

# HAL - Disabled
# CONFIG_HAL is not set

# PDL - Disabled
# CONFIG_PDL is not set

# PRL - Disabled
# CONFIG_PRL is not set
