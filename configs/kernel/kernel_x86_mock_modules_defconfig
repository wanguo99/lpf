# ============================================================================
# x86 kernel module build configuration with mock SoC backend
# ============================================================================

CONFIG_PROJECT_NAME="x86_mock_modules"
CONFIG_PROJECT_VERSION="1.0.0"

CONFIG_LINUX_ONLY=y
CONFIG_OS_LINUX=y
CONFIG_ARCH_X86_64=y
CONFIG_PLATFORM_LINUX=y

CONFIG_OSAL=m
CONFIG_LPF_CORE=m
CONFIG_LPF_SOC_ADAPTER_MOCK=y
CONFIG_LPF_RUNTIME=y
CONFIG_LPF_CONFIGS=m
CONFIG_LPF_CONFIG_KERNEL_X86_MOCK_MODULES=y

CONFIG_LPF_HW_CAN=y
CONFIG_LPF_HW_UART=y
CONFIG_LPF_HW_I2C=y
CONFIG_LPF_HW_SPI=y
CONFIG_LPF_HW_GPIO=y
CONFIG_LPF_HW_PWM=y
CONFIG_LPF_HW_MOCK_SELFTEST=m
CONFIG_LPF_DUMMY_SERVICE_SELFTEST=m
CONFIG_LPF_CONFIG_OF_SELFTEST=y

CONFIG_LPF_MCU_SERVICE=y
CONFIG_LPF_MCU_MAX_DEVICES=4
CONFIG_LPF_MCU_TRANSPORT_CAN=y
CONFIG_LPF_MCU_TRANSPORT_UART=y
CONFIG_LPF_LED_SERVICE=y
CONFIG_LPF_LED_MAX_DEVICES=8
CONFIG_LPF_PROTOCOL=y
CONFIG_LPF_PROTOCOL_MCU=y
CONFIG_LPF_PROTOCOL_CRC_CHECK=y
CONFIG_LPF_PROTOCOL_SEQUENCE_CHECK=y
CONFIG_LPF_PROTOCOL_MAX_PAYLOAD_SIZE=4096
