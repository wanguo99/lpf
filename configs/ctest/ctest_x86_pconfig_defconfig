# ============================================================================
# PCONFIG Test Configuration
# ============================================================================
# PCONFIG (Platform Configuration Layer) 测试配置
# 用于测试平台配置层功能
# ============================================================================

# Architecture and OS
CONFIG_OS_LINUX=y
CONFIG_ARCH_X86_64=y

# Platform
CONFIG_PLATFORM_LINUX=y
CONFIG_PROJECT_H200_AM625=y

CONFIG_OSAL=y
CONFIG_TEST_FRAMEWORK=y
CONFIG_HAL=y
CONFIG_PDL=y
CONFIG_PCONFIG=y

# Build Configuration
CONFIG_OSAL_BUILD_SHARED=y
CONFIG_HAL_BUILD_SHARED=y
CONFIG_PDL_BUILD_SHARED=y
CONFIG_PCONFIG_BUILD_SHARED=y

# OSAL Features - Required
CONFIG_OSAL_IPC=y
CONFIG_OSAL_FILE=y
CONFIG_OSAL_THREAD=y

# OSAL IPC
CONFIG_OSAL_IPC_ATOMIC=y
CONFIG_OSAL_IPC_MUTEX=y
CONFIG_OSAL_IPC_RWLOCK=y

# OSAL Library
CONFIG_OSAL_LIB_ERRNO=y
CONFIG_OSAL_LIB_HEAP=y
CONFIG_OSAL_LIB_STDIO=y
CONFIG_OSAL_LIB_STRING=y

# OSAL Network
CONFIG_OSAL_NET_SOCKET=y
CONFIG_OSAL_NET_TERMIOS=y

# OSAL System - Enable All
CONFIG_OSAL_SYS_CLOCK=y
CONFIG_OSAL_SYS_ENV=y
CONFIG_OSAL_SYS_FILE=y
CONFIG_OSAL_SYS_PROCESS=y
CONFIG_OSAL_SYS_SCHED=y
CONFIG_OSAL_SYS_SELECT=y
CONFIG_OSAL_SYS_THREAD=y
CONFIG_OSAL_SYS_TIME=y

# OSAL Utility
CONFIG_OSAL_UTIL_LOG=y
CONFIG_OSAL_UTIL_VERSION=y

# Testing - Enabled
CONFIG_BUILD_TESTING=y
CONFIG_TEST_UNIT=y

# PCONFIG Unit Tests - All Enabled
CONFIG_TEST_PCONFIG=y
CONFIG_TEST_PCONFIG_ALL=y
CONFIG_TEST_PCONFIG_API=y

# Other test modules disabled
# CONFIG_TEST_OSAL is not set
# CONFIG_TEST_HAL is not set
# CONFIG_TEST_PDL is not set
# CONFIG_TEST_ACONFIG is not set
# CONFIG_TEST_PERFORMANCE is not set
# CONFIG_TEST_STRESS is not set
# CONFIG_TEST_SYSTEM is not set

# Products - All Disabled

# HAL - Disabled

# PDL - Disabled


# HAL Features - Enable basic features
CONFIG_HAL_CAN=y
CONFIG_HAL_GPIO=y
CONFIG_HAL_I2C=y
CONFIG_HAL_SPI=y
CONFIG_HAL_UART=y

# PDL Features - Enable basic modules
CONFIG_PDL_MCU_SUPPORT=y
