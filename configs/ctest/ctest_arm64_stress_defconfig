# ============================================================================
# Stress Test Configuration
# ============================================================================
# All core modules, all products, and all applications enabled.
# Used for stress and performance testing.
# ============================================================================

# Product Selection - All Products
CONFIG_PRODUCT_CCM=y

# Core Components - Full Stack
CONFIG_OSAL=y
CONFIG_TEST_FRAMEWORK=y
CONFIG_HAL=y
CONFIG_PCONFIG=y
CONFIG_PDL=y
CONFIG_ACONFIG=y

# Architecture and OS
CONFIG_OS_LINUX=y
CONFIG_ARCH_ARM64=y
CONFIG_OSAL_OS_POSIX=y

# Platform
CONFIG_PLATFORM_LINUX=y

# CCM Platform
CONFIG_PROJECT_H200_AM625=y

# Build Configuration - Dynamic Libraries
CONFIG_OSAL_BUILD_SHARED=y
CONFIG_HAL_BUILD_SHARED=y
CONFIG_PCONFIG_BUILD_SHARED=y
CONFIG_PDL_BUILD_SHARED=y
CONFIG_ACONFIG_BUILD_SHARED=y

# HAL Drivers - All Enabled
CONFIG_HAL_CAN=y
CONFIG_HAL_UART=y
CONFIG_HAL_I2C=y
CONFIG_HAL_SPI=y
CONFIG_HAL_GPIO=y

# HAL Linux Drivers - All Enabled
CONFIG_HAL_CAN_LINUX=y
CONFIG_HAL_GPIO_LINUX=y
CONFIG_HAL_I2C_LINUX=y
CONFIG_HAL_SPI_LINUX=y
CONFIG_HAL_UART_LINUX=y

# PDL Sub-modules - All Enabled
CONFIG_PDL_SATELLITE_SUPPORT=y
CONFIG_PDL_BMC_SUPPORT=y
CONFIG_PDL_MCU_SUPPORT=y

# PDL Satellite Drivers - All Enabled
CONFIG_PDL_SATELLITE=y
CONFIG_PDL_SATELLITE_CAN=y

# PDL BMC Drivers - All Enabled
CONFIG_PDL_BMC=y
CONFIG_PDL_BMC_IPMI=y
CONFIG_PDL_BMC_REDFISH=y
CONFIG_PDL_BMC_TRANSPORT=y

# PDL MCU Drivers - All Enabled
CONFIG_PDL_MCU=y
CONFIG_PDL_MCU_CAN_SUPPORT=y
CONFIG_PDL_MCU_UART_SUPPORT=y
CONFIG_PDL_MCU_CAN=y
CONFIG_PDL_MCU_SERIAL=y
CONFIG_PDL_MCU_PROTOCOL=y

# CCM Libraries - All Enabled
CONFIG_LIBCCM=y

# CCM Applications - All Enabled
CONFIG_APP_COLLECTOR=y
CONFIG_APP_COMM=y
CONFIG_APP_LOGGER=y
CONFIG_APP_HEALTH=y
CONFIG_APP_SUPERVISOR=y

# OSAL Features - All Enabled
CONFIG_OSAL_IPC=y
CONFIG_OSAL_FILE=y
CONFIG_OSAL_THREAD=y
CONFIG_OSAL_NETWORK=y
CONFIG_OSAL_SIGNAL=y

# OSAL IPC - All Enabled
CONFIG_OSAL_IPC_ATOMIC=y
CONFIG_OSAL_IPC_MUTEX=y
CONFIG_OSAL_IPC_SEMAPHORE=y
CONFIG_OSAL_IPC_COND=y
CONFIG_OSAL_IPC_SHM=y
CONFIG_OSAL_IPC_SHM_CACHE=y

# OSAL Library - All Enabled
CONFIG_OSAL_LIB_ERRNO=y
CONFIG_OSAL_LIB_HEAP=y
CONFIG_OSAL_LIB_STDIO=y
CONFIG_OSAL_LIB_STRING=y

# OSAL System - All Enabled
CONFIG_OSAL_SYS_CLOCK=y
CONFIG_OSAL_SYS_ENV=y
CONFIG_OSAL_SYS_FILE=y
CONFIG_OSAL_SYS_PROCESS=y
CONFIG_OSAL_SYS_SCHED=y
CONFIG_OSAL_SYS_SELECT=y
CONFIG_OSAL_SYS_SIGNAL=y
CONFIG_OSAL_SYS_THREAD=y
CONFIG_OSAL_SYS_TIME=y

# OSAL Network - All Enabled
CONFIG_OSAL_NET_SOCKET=y
CONFIG_OSAL_NET_TERMIOS=y

# OSAL Utility - All Enabled
CONFIG_OSAL_UTIL_LOG=y
CONFIG_OSAL_UTIL_VERSION=y

# Testing
CONFIG_BUILD_TESTING=y
CONFIG_TEST_STRESS=y

# OSAL Stress Tests - All Enabled
CONFIG_TEST_STRESS_OSAL=y
CONFIG_TEST_STRESS_OSAL_THREAD=y
CONFIG_TEST_STRESS_OSAL_MEMORY=y
CONFIG_TEST_STRESS_OSAL_IPC=y

# HAL Stress Tests - All Enabled
CONFIG_TEST_STRESS_HAL=y
CONFIG_TEST_STRESS_HAL_CONCURRENT=y
CONFIG_TEST_STRESS_HAL_HIGH_LOAD=y

# PDL Stress Tests - All Enabled
CONFIG_TEST_STRESS_PDL=y
CONFIG_TEST_STRESS_PDL_DEVICE=y

# Other test categories disabled
# CONFIG_TEST_UNIT is not set
# CONFIG_TEST_PERFORMANCE is not set
# CONFIG_TEST_SYSTEM is not set
