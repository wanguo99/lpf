#
# ARM32 RTOS Minimal Configuration
# Target: ARM32 (ARMv7-A) with RTOS
# Purpose: Minimal footprint for RTOS/bare-metal embedded systems
# Optimization: -Os for smallest binary size
# Libraries: Static libraries only (no dynamic linking in RTOS)
#

# ============================================================================
# Build Options
# ============================================================================
CONFIG_OPT_OS=y
CONFIG_LIBRARY_BUILD_TYPE_STATIC=y

# ============================================================================
# Target Platform
# ============================================================================
CONFIG_ARCH_ARM32=y
CONFIG_OS_RTOS=y
CONFIG_CROSS_COMPILE="arm-none-eabi-"

# ============================================================================
# OSAL (Operating System Abstraction Layer)
# ============================================================================
CONFIG_OSAL=y
CONFIG_OSAL_BUILD_STATIC=y

# OSAL Features (Minimal - no file/network in RTOS)
CONFIG_OSAL_IPC=y
CONFIG_OSAL_THREAD=y
CONFIG_OSAL_TIME=y

# OSAL Resource Limits (Minimal for RTOS)
CONFIG_OSAL_MAX_TASKS=16
CONFIG_OSAL_MAX_QUEUES=8
CONFIG_OSAL_MAX_MUTEXES=8

# ============================================================================
# HAL (Hardware Abstraction Layer)
# ============================================================================
CONFIG_HAL=y
CONFIG_HAL_BUILD_STATIC=y
CONFIG_PLATFORM_CUSTOM=y

# HAL Drivers (Essential only - direct hardware access)
CONFIG_HAL_UART=y

CONFIG_HAL_GPIO=y

CONFIG_HAL_WATCHDOG=y

# ============================================================================
# PCL (Protocol Control Layer)
# ============================================================================
CONFIG_PCL=y
CONFIG_PCL_BUILD_STATIC=y

# ============================================================================
# PDL (Protocol Data Layer)
# ============================================================================
CONFIG_PDL=y
CONFIG_PDL_BUILD_STATIC=y

# ============================================================================
# ACL (Application Control Layer)
# ============================================================================
CONFIG_ACL=y
CONFIG_ACL_BUILD_STATIC=y

# ============================================================================
# Products - CCM
# ============================================================================
CONFIG_PRODUCT_CCM=y
CONFIG_PROJECT_H200_AM625=y

# CCM Applications (Minimal - supervisor only)
CONFIG_BUILD_CCM_SUPERVISOR=y
