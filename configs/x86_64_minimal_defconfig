#
# EMS x86_64 Minimal Configuration
# Target: x86_64 Linux
# Purpose: Minimal footprint for resource-constrained systems
# Optimization: -Os for smallest binary size
# Libraries: Static libraries only
#

# ============================================================================
# Build Options
# ============================================================================
CONFIG_OPT_OS=y
CONFIG_LIBRARY_BUILD_TYPE_STATIC=y
CONFIG_LIBRARY_BUILD_TYPE_DYNAMIC=y

# ============================================================================
# Target Platform
# ============================================================================
CONFIG_ARCH_X86_64=y
CONFIG_OS_LINUX=y
CONFIG_CROSS_COMPILE=""

# ============================================================================
# OSAL (Operating System Abstraction Layer)
# ============================================================================
CONFIG_OSAL=y
CONFIG_OSAL_BUILD_STATIC=y
CONFIG_OSAL_BUILD_SHARED=y

# OSAL Features (Minimal - only essential)
CONFIG_OSAL_FILE=y
CONFIG_OSAL_IPC=y
CONFIG_OSAL_THREAD=y

# OSAL Resource Limits (Minimal)
CONFIG_OSAL_MAX_TASKS=32
CONFIG_OSAL_MAX_QUEUES=16
CONFIG_OSAL_MAX_MUTEXES=16

# OSAL 细粒度配置（最小集）
CONFIG_OSAL_IPC_MUTEX=y
CONFIG_OSAL_IPC_SEMAPHORE=y
CONFIG_OSAL_FILE_FILE=y
CONFIG_OSAL_FILE_PROCESS=y
CONFIG_OSAL_THREAD_THREAD=y
CONFIG_OSAL_THREAD_TIME=y

# ============================================================================
# HAL (Hardware Abstraction Layer)
# ============================================================================
CONFIG_HAL=y
CONFIG_HAL_BUILD_STATIC=y
CONFIG_HAL_BUILD_SHARED=y
CONFIG_PLATFORM_GENERIC_LINUX=y

# HAL Drivers (Essential only)
CONFIG_HAL_UART=y
CONFIG_HAL_UART_LINUX=y

CONFIG_HAL_WATCHDOG=y
CONFIG_HAL_WATCHDOG_LINUX=y

# ============================================================================
# PCL (Protocol Control Layer)
# ============================================================================
CONFIG_PCL=y
CONFIG_PCL_BUILD_STATIC=y
CONFIG_PCL_BUILD_SHARED=y

# PCL 细粒度配置
CONFIG_PCL_API=y
CONFIG_PCL_REGISTER=y

# ============================================================================
# PDL (Protocol Data Layer)
# ============================================================================
CONFIG_PDL=y
CONFIG_PDL_BUILD_STATIC=y
CONFIG_PDL_BUILD_SHARED=y

# ============================================================================
# ACL (Application Control Layer)
# ============================================================================
CONFIG_ACL=y
CONFIG_ACL_BUILD_STATIC=y
CONFIG_ACL_BUILD_SHARED=y

# ACL 细粒度配置
CONFIG_ACL_API=y
CONFIG_ACL_TELEMETRY_CACHE=y

# ============================================================================
# Products - CCM
# ============================================================================
CONFIG_PRODUCT_CCM=y
CONFIG_PROJECT_H200_AM625=y

# CCM Applications (Essential only)
CONFIG_BUILD_CCM_SUPERVISOR=y
CONFIG_BUILD_CCM_LOGGER=y
