# LPF Core Configuration

menuconfig LPF_CORE
	tristate "LPF core device model"
	default m
	depends on OSAL
	depends on LPF_CONFIGS
	depends on m
	help
	  LPF Core owns the framework device and driver registry used by
	  peripheral services. It provides a stable LPF device model above
	  kernel-version and SoC-specific adapter layers, plus snapshot device
	  discovery by stable name and capability.

	  It also contains the initial kernel compatibility wrappers and
	  selected SoC adapter used by LPF hardware access paths.

	  Required by the LPF runtime and services.

	  If unsure, say Y when enabling LPF peripheral services.

if LPF_CORE

config LPF_INSTANCE_DEVNODE_MODE
	string "LPF instance device node mode"
	default "0660"
	help
	  Octal permission mode applied to per-instance LPF misc device nodes
	  under /dev/lpf/, such as /dev/lpf/mcu0 and /dev/lpf/led0.

	  Product builds should keep this conservative and assign device group
	  ownership with udev, devtmpfs policy, or the product init system.
	  Development-only builds that intentionally need broad local access can
	  override this to "0666".

choice
	prompt "Default LPF SoC adapter"
	default LPF_SOC_ADAPTER_GENERIC_LINUX
	help
	  Select the SoC adapter registered by LPF Core during module
	  initialization. Product builds should normally use the generic Linux
	  backend or a future SoC-specific backend. Test builds can select the
	  mock backend to validate LPF HW and peripheral-service paths without
	  live hardware.

config LPF_SOC_ADAPTER_GENERIC_LINUX
	bool "Generic Linux SoC adapter"
	help
	  Use standard Linux kernel subsystem wrappers for GPIO, PWM, I2C, SPI,
	  CAN, and serial access.

config LPF_SOC_ADAPTER_MOCK
	bool "Mock SoC adapter"
	help
	  Use an in-kernel mock backend for GPIO, PWM, I2C, SPI, CAN, and
	  serial access. This is intended for framework tests and development
	  builds that need deterministic behavior without real peripherals.

endchoice

menu "LPF Protocol Configuration"

config LPF_PROTOCOL
	bool "LPF peripheral protocol support"
	default n
	help
	  Enable the LPF-owned protocol encoder/decoder used by peripheral
	  services that need framed communication.

	  The protocol layer is part of LPF infrastructure and is linked into
	  lpf_core.ko so services hosted by the integrated LPF peripheral
	  runtime can share the same packet framing implementation.

config LPF_PROTOCOL_MCU
	bool "MCU protocol messages"
	default n
	depends on LPF_PROTOCOL
	help
	  Enable MCU message definitions for the LPF peripheral protocol.

config LPF_PROTOCOL_CRC_CHECK
	bool "Enable CRC16 checksum"
	default y
	depends on LPF_PROTOCOL
	help
	  Enable CRC16-CCITT checksum support for protocol packets.

config LPF_PROTOCOL_SEQUENCE_CHECK
	bool "Enable sequence number check"
	default y
	depends on LPF_PROTOCOL
	help
	  Enable sequence number helpers for packet ordering.

config LPF_PROTOCOL_MAX_PAYLOAD_SIZE
	int "Maximum protocol payload size (bytes)"
	default 4096
	range 256 65536
	depends on LPF_PROTOCOL
	help
	  Maximum payload size for LPF protocol packets.

endmenu

menuconfig LPF_RUNTIME
	bool "LPF integrated peripheral runtime"
	default y
	depends on LPF_CORE
	help
	  Link the integrated LPF runtime into lpf_core.ko. This runtime hosts
	  the reusable LPF peripheral services selected below and the runtime
	  configuration backend used to create LPF devices. It keeps framework
	  services in one core/driver module instead of splitting one kernel
	  module per peripheral. Static platform configuration can be provided
	  by the separate lpf_configs.ko module or by Device Tree.

	  If unsure, say Y when enabling LPF peripheral services.

if LPF_RUNTIME

source "kernel/lpf-core/hw/Config.in"

menuconfig LPF_MCU_SERVICE
	bool "LPF MCU peripheral service"
	default n
	depends on LPF_RUNTIME
	select LPF_PROTOCOL
	select LPF_PROTOCOL_MCU
	select LPF_HW_CAN
	select LPF_HW_UART
	help
	  Enable the LPF MCU peripheral service. MCU instances are created from
	  normalized LPF_CONFIG entries and exposed through LPF device lifecycle,
	  /dev/lpf/mcuN, sysfs attributes, and debugfs commands.

source "kernel/lpf-core/peripheral/mcu/Config.in"

menuconfig LPF_LED_SERVICE
	bool "LPF LED peripheral service"
	default n
	depends on LPF_RUNTIME
	select LPF_HW_GPIO
	select LPF_HW_PWM
	help
	  Enable the LPF LED peripheral service. LED instances are created from
	  normalized LPF_CONFIG entries and exposed through LPF device lifecycle,
	  /dev/lpf/ledN, sysfs attributes, and debugfs commands.

source "kernel/lpf-core/peripheral/led/Config.in"

endif # LPF_RUNTIME

menu "LPF Core Test Configuration"

config LPF_DUMMY_SERVICE_SELFTEST
	tristate "Build LPF dummy service self-test module"
	default n
	depends on LPF_CORE && LPF_SOC_ADAPTER_MOCK
	depends on m
	help
	  Build lpf_dummy_service_selftest.ko. Loading this module registers
	  a temporary dummy LPF driver and device to validate LPF Core
	  lifecycle, discovery, capability lookup, state/error transitions,
	  event delivery, and removal cleanup without requiring live hardware.

endmenu

endif # LPF_CORE
