# PDM Core Configuration

menuconfig PDM_CORE
	tristate "PDM core device model"
	default m
	depends on OSAL
	# depends on PDM_CONFIGS  # 已删除：不再依赖 pdm_configs
	depends on m
	help
	  PDM Core owns the framework device and driver registry used by
	  peripheral services. It provides a stable PDM device model above
	  kernel-version and SoC-specific adapter layers, plus snapshot device
	  discovery by stable name and capability.

	  Device configuration now uses Device Tree exclusively.

	  It also contains the initial kernel compatibility wrappers and
	  selected SoC adapter used by PDM hardware access paths.

	  Required by the PDM runtime and services.

	  If unsure, say Y when enabling PDM peripheral services.

if PDM_CORE

config PDM_INSTANCE_DEVNODE_MODE
	string "PDM instance device node mode"
	default "0660"
	help
	  Octal permission mode applied to per-instance PDM misc device nodes
	  under /dev/pdm/, such as /dev/pdm/mcu0 and /dev/pdm/led0.

	  Product builds should keep this conservative and assign device group
	  ownership with udev, devtmpfs policy, or the product init system.
	  Development-only builds that intentionally need broad local access can
	  override this to "0666".

choice
	prompt "Default PDM SoC adapter"
	default PDM_SOC_ADAPTER_GENERIC_LINUX
	help
	  Select the SoC adapter registered by PDM Core during module
	  initialization. Product builds should normally use the generic Linux
	  backend or a future SoC-specific backend. Test builds can select the
	  mock backend to validate PDM HW and peripheral-service paths without
	  live hardware.

config PDM_SOC_ADAPTER_GENERIC_LINUX
	bool "Generic Linux SoC adapter"
	help
	  Use standard Linux kernel subsystem wrappers for GPIO, PWM, I2C, SPI,
	  CAN, and serial access.

config PDM_SOC_ADAPTER_MOCK
	bool "Mock SoC adapter"
	help
	  Use an in-kernel mock backend for GPIO, PWM, I2C, SPI, CAN, and
	  serial access. This is intended for framework tests and development
	  builds that need deterministic behavior without real peripherals.

endchoice

menu "PDM Protocol Configuration"

config PDM_PROTOCOL
	bool "PDM peripheral protocol support"
	default n
	help
	  Enable the PDM-owned protocol encoder/decoder used by peripheral
	  services that need framed communication.

	  The protocol layer is part of PDM infrastructure and is linked into
	  pdm_core.ko so services hosted by the integrated PDM peripheral
	  runtime can share the same packet framing implementation.

config PDM_PROTOCOL_MCU
	bool "MCU protocol messages"
	default n
	depends on PDM_PROTOCOL
	help
	  Enable MCU message definitions for the PDM peripheral protocol.

config PDM_PROTOCOL_CRC_CHECK
	bool "Enable CRC16 checksum"
	default y
	depends on PDM_PROTOCOL
	help
	  Enable CRC16-CCITT checksum support for protocol packets.

config PDM_PROTOCOL_SEQUENCE_CHECK
	bool "Enable sequence number check"
	default y
	depends on PDM_PROTOCOL
	help
	  Enable sequence number helpers for packet ordering.

config PDM_PROTOCOL_MAX_PAYLOAD_SIZE
	int "Maximum protocol payload size (bytes)"
	default 4096
	range 256 65536
	depends on PDM_PROTOCOL
	help
	  Maximum payload size for PDM protocol packets.

endmenu

menuconfig PDM_RUNTIME
	bool "PDM integrated peripheral runtime"
	default y
	depends on PDM_CORE
	help
	  Link the integrated PDM runtime into pdm_core.ko. This runtime hosts
	  the reusable PDM peripheral services selected below and the runtime
	  configuration backend used to create PDM devices. It keeps framework
	  services in one core/driver module instead of splitting one kernel
	  module per peripheral. Static platform configuration can be provided
	  by the separate pdm_configs.ko module or by Device Tree.

	  If unsure, say Y when enabling PDM peripheral services.

if PDM_RUNTIME

source "kernel/pdm-core/hw/Config.in"

menuconfig PDM_MCU_SERVICE
	bool "PDM MCU peripheral service"
	default n
	depends on PDM_RUNTIME
	select PDM_PROTOCOL
	select PDM_PROTOCOL_MCU
	select PDM_HW_CAN
	select PDM_HW_UART
	help
	  Enable the PDM MCU peripheral service. MCU instances are created from
	  normalized PDM_CONFIG entries and exposed through PDM device lifecycle,
	  /dev/pdm/mcuN, sysfs attributes, and debugfs commands.

source "kernel/pdm-core/peripheral/mcu/Config.in"

menuconfig PDM_LED_SERVICE
	bool "PDM LED peripheral service"
	default n
	depends on PDM_RUNTIME
	select PDM_HW_GPIO
	select PDM_HW_PWM
	help
	  Enable the PDM LED peripheral service. LED instances are created from
	  normalized PDM_CONFIG entries and exposed through PDM device lifecycle,
	  /dev/pdm/ledN, sysfs attributes, and debugfs commands.

source "kernel/pdm-core/peripheral/led/Config.in"

endif # PDM_RUNTIME

menu "PDM Core Test Configuration"

config PDM_DUMMY_SERVICE_SELFTEST
	tristate "Build PDM dummy service self-test module"
	default n
	depends on PDM_CORE && PDM_SOC_ADAPTER_MOCK
	depends on m
	help
	  Build pdm_dummy_service_selftest.ko. Loading this module registers
	  a temporary dummy PDM driver and device to validate PDM Core
	  lifecycle, discovery, capability lookup, state/error transitions,
	  event delivery, and removal cleanup without requiring live hardware.

endmenu

endif # PDM_CORE
