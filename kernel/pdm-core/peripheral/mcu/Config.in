# LPF MCU service configuration

if LPF_MCU_SERVICE

config LPF_MCU_MAX_DEVICES
	int "Maximum number of MCU devices"
	default 4
	range 1 16
	help
	  Maximum number of MCU devices that can be managed simultaneously.
	  Each device requires approximately 200 bytes of RAM.

config LPF_MCU_TRANSPORT_CAN
	bool "LPF MCU CAN transport"
	default y
	depends on LPF_HW_CAN
	help
	  Enable the CAN-backed transport implementation used by the LPF MCU
	  service for LPF_CONFIG_MCU_INTERFACE_CAN entries.

config LPF_MCU_TRANSPORT_UART
	bool "LPF MCU UART transport"
	default y
	depends on LPF_HW_UART
	help
	  Enable the UART-backed transport implementation used by the LPF MCU
	  service for LPF_CONFIG_MCU_INTERFACE_SERIAL entries.

endif # LPF_MCU_SERVICE
