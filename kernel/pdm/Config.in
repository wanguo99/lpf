# PDM (Peripheral Driver Module) Configuration

menuconfig PDM
	bool "PDM (Peripheral Driver Module)"
	default n
	depends on OSAL && LPF_CORE && HAL && PCONFIG
	help
	  Peripheral Driver Module provides high-level peripheral management
	  and protocol handling.

	  PDM sits above HAL and provides:
	  - Protocol-aware peripheral drivers
	  - Device abstraction and discovery through /dev/pdm_ctl
	  - State management and error handling
	  - Unified API for complex peripherals

	  Architecture:
	  PDM uses HAL for low-level hardware access and PCONFIG for
	  hardware configuration, providing application-level APIs
	  for managing peripheral subsystems.

	  Memory footprint: ~15KB base + per-peripheral drivers

	  Supported peripherals:
	  - MCU peripherals
	  - LED peripherals

	  Dependencies: OSAL, LPF Core, HAL, PCONFIG

	  Note: Enable OSAL, LPF Core, HAL, and PCONFIG first in
	  "Core Modules" menu.

	  Recommended: Enable for systems with peripheral management

	  If unsure, say Y.

if PDM

menuconfig PDM_MCU_SUPPORT
	bool "MCU peripheral support"
	default n
	select PDM_PROTOCOL
	select PDM_PROTOCOL_MCU
	select HAL_CAN
	select HAL_UART
	help
	  Enable MCU (Microcontroller) peripheral support.

	  MCU peripherals are microcontroller-based modules that provide
	  specialized control and monitoring functions, offloading tasks
	  from the main processor.

	  Typical MCU functions:
	  - Real-time sensor data acquisition
	  - PWM control for motors/actuators
	  - Analog signal processing
	  - Low-level protocol handling

	  Communication options:
	  - CAN bus (for robust, multi-drop networks)
	  - UART (for point-to-point connections)

	  Memory footprint: ~8KB base + protocol overhead

	  You can enable CAN-based or UART-based MCU support in the submenu.

	  Kernel module builds link the MCU core and use the CAN/UART
	  transport symbols exported by hal.ko.

	  If unsure, say Y.

source "kernel/pdm/src/mcu/Config.in"

menuconfig PDM_LED_SUPPORT
	bool "LED peripheral support"
	default n
	select HAL_GPIO
	select HAL_PWM
	help
	  Enable LED peripheral support.

	  LED peripherals can be controlled through GPIO or PWM according to
	  PConfig entries. The driver exposes /dev/pdm_led for userspace PDI.

source "kernel/pdm/src/led/Config.in"

menu "PDM Protocol Configuration"

config PDM_PROTOCOL
	bool "PDM internal protocol support"
	default n
	help
	  Enable the PDM-owned protocol encoder/decoder used by peripheral
	  driver modules.

	  This is not a standalone framework layer or user ABI. It is linked
	  into pdm.ko when a PDM peripheral requires framed communication.

config PDM_PROTOCOL_MCU
	bool "MCU protocol messages"
	default n
	help
	  Enable MCU message definitions for the PDM internal protocol.

config PDM_PROTOCOL_CRC_CHECK
	bool "Enable CRC16 checksum"
	default y
	depends on PDM_PROTOCOL
	help
	  Enable CRC16-CCITT checksum support for protocol packets.

config PDM_PROTOCOL_SEQUENCE_CHECK
	bool "Enable sequence number check"
	default y
	depends on PDM_PROTOCOL
	help
	  Enable sequence number helpers for packet ordering.

config PDM_PROTOCOL_MAX_PAYLOAD_SIZE
	int "Maximum protocol payload size (bytes)"
	default 4096
	range 256 65536
	depends on PDM_PROTOCOL
	help
	  Maximum payload size for PDM internal protocol packets.

endmenu

endif # PDM
