# PDM Module Configuration

menuconfig PDM
	tristate "PDM kernel device model"
	default m
	depends on m
	help
	  PDM provides a Linux bus_type implementation for PDM devices.
	  Device configuration uses Device Tree exclusively.

	  If unsure, say Y when enabling PDM peripheral services.

if PDM


menu "PDM logging"

config PDM_LOGGING_ENABLE
	bool "Enable PDM kernel logging"
	default y
	help
	  Enable LOG_* output inside pdm.ko. When disabled, PDM logging calls
	  are compiled out of the module.

if PDM_LOGGING_ENABLE

choice
	prompt "PDM kernel log level"
	default PDM_LOG_LEVEL_INFO if BUILD_TYPE_DEBUG
	default PDM_LOG_LEVEL_WARN if BUILD_TYPE_RELEASE
	default PDM_LOG_LEVEL_INFO
	help
	  Select the minimum PDM log priority compiled into pdm.ko.

config PDM_LOG_LEVEL_FATAL
	bool "FATAL - fatal errors only"

config PDM_LOG_LEVEL_ERROR
	bool "ERROR - errors and above"

config PDM_LOG_LEVEL_WARN
	bool "WARN - warnings and above"

config PDM_LOG_LEVEL_INFO
	bool "INFO - informational and above"

config PDM_LOG_LEVEL_DEBUG
	bool "DEBUG - debug and above"

endchoice

endif # PDM_LOGGING_ENABLE

endmenu

menu "Target kernel feature availability"

config PDM_TARGET_HAS_CAN_RAW
	bool "Target kernel provides CAN RAW sockets"
	default y
	help
	  Enable this when the target kernel has PF_CAN RAW socket support.
	  Disable it for kernels built without CONFIG_CAN_RAW so CAN backends
	  cannot be selected accidentally.

config PDM_TARGET_HAS_SERIAL_DEV_BUS
	bool "Target kernel provides UART serdev"
	default y
	help
	  Enable this when the target kernel has CONFIG_SERIAL_DEV_BUS.

config PDM_TARGET_HAS_I2C
	bool "Target kernel provides I2C client support"
	default y
	help
	  Enable this when the target kernel has CONFIG_I2C.

config PDM_TARGET_HAS_SPI
	bool "Target kernel provides SPI client support"
	default y
	help
	  Enable this when the target kernel has CONFIG_SPI.

config PDM_TARGET_HAS_GPIOLIB
	bool "Target kernel provides gpiolib"
	default y
	help
	  Enable this when the target kernel has CONFIG_GPIOLIB.

config PDM_TARGET_HAS_PWM
	bool "Target kernel provides PWM support"
	default y
	help
	  Enable this when the target kernel has CONFIG_PWM.

endmenu

config PDM_MANAGER_DEVNODE_MODE
	string "PDM manager device node mode"
	default "0660"
	help
	  Octal permission mode applied to /dev/pdm_manager. Production
	  builds should use group ownership through udev, devtmpfs policy,
	  or the product init system instead of world-writable access.

config PDM_INSTANCE_DEVNODE_MODE
	string "PDM instance device node mode"
	default "0660"
	help
	  Octal permission mode applied to per-instance PDM character device nodes
	  under /dev/pdm/, such as /dev/pdm/mcu0 and /dev/pdm/led0.

	  Product builds should keep this conservative and assign device group
	  ownership with udev, devtmpfs policy, or the product init system.
	  Development-only builds that intentionally need broad local access can
	  override this to "0666".

config PDM_DIAG_CONTROL
	bool "Writable PDM proc/debugfs diagnostic controls"
	default n
	help
	  Build writable /proc/pdm and debugfs control files for MCU/LED
	  diagnostics. This is intended for development and factory bring-up.
	  Product builds should leave it disabled and rely on /dev/pdm_manager
	  plus read-only sysfs attributes for diagnostics.

config PDM_MOCK_DEVICES
	bool "Synthetic PDM devices for module smoke tests"
	default n
	help
	  Create in-kernel mock PDM MCU and LED devices when pdm.ko loads.
	  This is intended for x86 smoke tests that do not have Device Tree
	  PDM child nodes. Product builds should leave this disabled.

config PDM_MCU_CAN
	bool "PDM MCU CAN RAW transport"
	default y
	depends on PDM_TARGET_HAS_CAN_RAW
	help
	  Enable the CAN RAW transport backend for MCU devices bound to a CAN
	  controller through a Device Tree phandle. Enable this only when the
	  target kernel provides CONFIG_CAN_RAW.

config PDM_MCU_UART_SERDEV
	bool "PDM MCU UART serdev transport"
	default y
	depends on PDM_TARGET_HAS_SERIAL_DEV_BUS
	help
	  Register a serdev client driver for MCU devices described below a UART
	  controller node. Enable this only when the target kernel provides
	  CONFIG_SERIAL_DEV_BUS. UART path-based fallback is not supported.

config PDM_MCU_I2C
	bool "PDM MCU I2C transport"
	default y
	depends on PDM_TARGET_HAS_I2C
	help
	  Register an I2C client driver for MCU devices described below an I2C
	  controller node. Enable this only when the target kernel provides
	  CONFIG_I2C.

config PDM_MCU_SPI
	bool "PDM MCU SPI transport"
	default y
	depends on PDM_TARGET_HAS_SPI
	help
	  Register an SPI client driver for MCU devices described below an SPI
	  controller node. Enable this only when the target kernel provides
	  CONFIG_SPI.

config PDM_LED_GPIO
	bool "PDM LED GPIO backend"
	default y
	depends on PDM_TARGET_HAS_GPIOLIB
	help
	  Enable the GPIO control backend for LED devices described under the
	  PDM bus controller with compatible "pdm,led-gpio". Enable this only
	  when the target kernel provides CONFIG_GPIOLIB.

config PDM_LED_PWM
	bool "PDM LED PWM backend"
	default y
	depends on PDM_TARGET_HAS_PWM
	help
	  Enable the PWM control backend for LED devices described under the
	  PDM bus controller with compatible "pdm,led-pwm". Enable this only
	  when the target kernel provides CONFIG_PWM.

endif # PDM
