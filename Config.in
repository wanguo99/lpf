# ============================================================================
# ES-Middleware SDK Root Configuration
# ============================================================================
# This is the root Config.in file for the entire ES-Middleware SDK.
# It provides a unified configuration interface for:
#   - Product selection (which products to build)
#   - Core components configuration (OSAL, HAL, PCL, PDL, ACL)
#   - Product-specific configurations
# ============================================================================

mainmenu "ES-Middleware SDK Configuration"

config ES_MIDDLEWARE_VERSION
	string
	default "1.0.0"

# ============================================================================
# Configuration Templates (Quick Start)
# ============================================================================
# Load a predefined configuration template to quickly get started.
# You can further customize the configuration after loading a template.
# ============================================================================

menu "Configuration Templates"

choice
	prompt "Load configuration template"
	default TEMPLATE_NONE
	help
	  Quick start with a predefined configuration template.

	  Templates provide optimized configurations for different scenarios:
	  - RTOS Minimal: Ultra-compact for resource-constrained RTOS
	  - Linux Minimal: Essential features for storage-limited Linux
	  - Linux Standard: Balanced configuration for typical Linux
	  - Linux Full: All features enabled for development and testing

	  After loading a template, customize individual options as needed.

	  If you prefer manual configuration, select "None".

config TEMPLATE_NONE
	bool "None - Manual configuration"
	help
	  Configure all options manually.

	  Choose this if you want full control over every configuration option,
	  or if you're loading an existing defconfig file.

config TEMPLATE_RTOS_MINIMAL
	bool "RTOS Minimal - Ultra-compact (<50KB)"
	help
	  Optimized for RTOS with severe memory constraints.

	  Target: <50KB total footprint
	  Suitable for: Cortex-M MCUs with 32-64KB RAM

	  Features:
	  - OSAL: Basic IPC (mutex + semaphore), minimal file ops, threads
	  - HAL: Only essential drivers
	  - No network support
	  - No advanced features

	  Use case: Simple sensor nodes, actuator controllers

config TEMPLATE_LINUX_MINIMAL
	bool "Linux Minimal - Essential features (~100KB)"
	help
	  Minimal Linux configuration for storage-constrained systems.

	  Target: ~100KB total footprint
	  Suitable for: Embedded Linux with limited flash/RAM

	  Features:
	  - OSAL: Standard IPC, basic file ops, threads, limited network
	  - HAL: Common drivers (CAN, UART, GPIO)
	  - Basic PDL support
	  - 1-2 applications

	  Use case: Simple data collectors, edge gateways

config TEMPLATE_LINUX_STANDARD
	bool "Linux Standard - Balanced configuration (~200KB) [Recommended]"
	help
	  Recommended configuration for typical Linux-based products.

	  Target: ~200KB total footprint
	  Suitable for: AM625, i.MX6/8, Zynq and similar SoCs

	  Features:
	  - OSAL: Full IPC, complete file ops, threads, full network
	  - HAL: All drivers (CAN, UART, I2C, SPI, GPIO, Watchdog)
	  - PCL: Full peripheral configuration
	  - PDL: All peripheral drivers
	  - ACL: Application configuration layer
	  - Multiple applications

	  Use case: Satellite payloads, industrial controllers, IoT gateways

	  This is the recommended starting point for most projects.

config TEMPLATE_LINUX_FULL
	bool "Linux Full - All features (~300KB)"
	help
	  All features enabled for development and testing.

	  Target: ~300KB total footprint
	  Suitable for: Development, testing, feature-rich products

	  Features:
	  - All OSAL features including debug and statistics
	  - All HAL drivers and advanced features
	  - All PCL/PDL/ACL features
	  - All applications
	  - Debug logging and diagnostics

	  Use case: Development, testing, debugging, feature exploration

endchoice

config EXPERT
	bool "Expert mode - Show advanced options"
	default n
	help
	  Enable expert mode to access advanced configuration options.

	  When enabled, you can:
	  - Fine-tune individual file-level compilation
	  - Access debug and diagnostic options
	  - Configure resource limits precisely
	  - Override automatic dependency resolution

	  Warning: Incorrect advanced settings may result in build failures
	  or runtime errors. Only enable if you know what you're doing.

	  If unsure, say N.

endmenu

# ============================================================================
# Product Selection
# ============================================================================
# Select which product to build. Only one product can be selected at a time
# for exclusive development and testing.
# ============================================================================

choice
	prompt "Select product"
	default PRODUCT_NONE
	help
	  Select which product to build.

	  Only one product can be selected at a time to ensure clean
	  separation of product-specific code and configurations.

	  If you want to run tests without building any product, select "None".

config PRODUCT_NONE
	bool "None - Testing only"
	help
	  Do not build any product.

	  Select this option when you want to:
	  - Run unit tests for core components only
	  - Build and test the SDK framework without product code
	  - Develop core components independently

	  This is the default for test configurations.

config PRODUCT_CCM
	bool "CCM Product"
	help
	  Build CCM (Central Control Module) product.

	  CCM is a satellite payload control and data management system
	  designed for H200 platform with AM625 SoC.

	  This will build:
	  - CCM libraries (libccm)
	  - CCM applications (collector, comm, health, logger, supervisor)
	  - Platform-specific configurations for AM625

# config PRODUCT_SAMPLE
# 	bool "Sample Product"
# 	help
# 	  Build Sample product (demonstration and template).
#
# 	  Sample product provides a minimal working example showing
# 	  how to structure a product using the ES-Middleware SDK framework.
#
# 	  Useful for learning and as a starting point for new products.
#
# 	  Note: Not yet implemented.

endchoice

# ============================================================================
# Project Identification (Global)
# ============================================================================
# These symbols are required by the build system and must be defined for all
# configurations, regardless of product selection.
#
# For product builds: PROJECT_NAME is derived from platform choice
# For test builds: PROJECT_NAME defaults to "tests"
# ============================================================================

config PROJECT_NAME
	string "Project name"
	default "h200_100p_am625" if PRODUCT_CCM && PROJECT_H200_100P_AM625
	default "h200_200p" if PRODUCT_CCM && PROJECT_H200_200P
	default "tests" if PRODUCT_NONE
	default "unknown"
	help
	  Project name derived from product and platform selection.

	  This is used to:
	  - Locate platform-specific configuration files
	  - Generate build artifacts with appropriate names
	  - Identify the target platform in logs and version info

	  Value is automatically set based on product and platform choices:
	  - CCM + H200 100P AM625 → "h200_100p_am625"
	  - CCM + H200 200P → "h200_200p"
	  - Testing (PRODUCT_NONE) → "tests"

config PROJECT_VERSION
	string "Project version"
	default ES_MIDDLEWARE_VERSION
	help
	  Project version string.

	  Defaults to the ES-Middleware SDK version (1.0.0), but can be
	  overridden for product-specific versioning.

# ============================================================================
# Build System Configuration
# ============================================================================
# Platform and toolchain configuration
# ============================================================================

menu "Build System Configuration"

# ============================================================================
# Platform Configuration (OS and Architecture)
# ============================================================================

menu "Platform Configuration"

choice
	prompt "Target operating system"
	default OS_LINUX
	help
	  Select the target operating system type.

	  This determines which OS abstraction layer implementation to use.
	  The choice affects available features and memory footprint.

config OS_LINUX
	bool "Linux"
	help
	  Target Linux operating system (POSIX-compliant).

	  Provides:
	  - Full POSIX API support
	  - Complete IPC, threading, networking
	  - Virtual memory management
	  - Rich filesystem support

	  Suitable for: Embedded Linux (AM625, i.MX6/8, Zynq), Desktop Linux
	  Memory: Requires MMU, typically 32MB+ RAM

config OS_WINDOWS
	bool "Windows"
	help
	  Target Windows operating system (Win32 API).

	  Provides:
	  - Win32 threading and synchronization
	  - Windows file I/O
	  - Winsock networking
	  - Limited POSIX compatibility

	  Suitable for: Windows desktop, Windows IoT
	  Memory: Requires 64MB+ RAM

config OS_RTOS
	bool "RTOS (Real-Time OS)"
	help
	  Target real-time operating system (FreeRTOS, Zephyr, etc).

	  Provides:
	  - Deterministic scheduling
	  - Low memory footprint
	  - Fast interrupt response
	  - Limited POSIX subset

	  Suitable for: Cortex-M MCUs, resource-constrained systems
	  Memory: Can run in 30KB+ RAM

	  Note: Feature availability depends on RTOS capabilities.
	  Some OSAL features may be unavailable or limited.

config OS_MACOS
	bool "macOS"
	help
	  Target macOS operating system (POSIX-compliant).

	  Provides:
	  - Full POSIX API support
	  - BSD-style networking
	  - Mach kernel primitives

	  Suitable for: macOS desktop, development/testing
	  Memory: Requires 128MB+ RAM

config OS_BARE
	bool "Bare Metal"
	help
	  No operating system (bare metal execution).

	  Provides:
	  - Direct hardware access
	  - Minimal runtime overhead
	  - Custom scheduling (if any)

	  Suitable for: Simple MCU applications, bootloaders
	  Memory: Can run in <10KB RAM

	  Note: Most OSAL features unavailable. Only basic library
	  functions (heap, string) are provided.

endchoice

config OS
	string
	default "linux" if OS_LINUX
	default "windows" if OS_WINDOWS
	default "rtos" if OS_RTOS
	default "macos" if OS_MACOS
	default "bare" if OS_BARE

choice
	prompt "Target architecture"
	default ARCH_X86_64
	help
	  Select the target CPU architecture.

	  This determines compiler flags, calling conventions,
	  and architecture-specific optimizations.

config ARCH_X86_64
	bool "x86_64 (64-bit Intel/AMD)"
	help
	  Intel/AMD 64-bit architecture (x86-64, amd64).

	  Features:
	  - 64-bit addressing
	  - SSE/AVX SIMD instructions
	  - Rich instruction set

	  Suitable for: Desktop, server, development machines
	  Performance: High compute capability, good for testing

config ARCH_ARM32
	bool "ARM (32-bit)"
	help
	  ARM 32-bit architecture (ARMv7-A and compatible).

	  Features:
	  - 32-bit addressing
	  - NEON SIMD (optional)
	  - Lower power consumption

	  Suitable for: Cortex-A7, A9, A15 processors
	  Examples: i.MX6, OMAP, older Raspberry Pi

config ARCH_ARM64
	bool "ARM64 (AArch64)"
	help
	  ARM 64-bit architecture (ARMv8-A and later).

	  Features:
	  - 64-bit addressing
	  - Advanced SIMD (NEON)
	  - Efficient instruction encoding

	  Suitable for: Cortex-A53, A72, A76 processors
	  Examples: TI AM625, NXP i.MX8, Raspberry Pi 4

config ARCH_RISCV64
	bool "RISC-V (64-bit)"
	help
	  RISC-V 64-bit architecture.

	  Features:
	  - Open ISA
	  - Modular extension architecture
	  - Clean instruction encoding

	  Suitable for: RISC-V processors (SiFive, Andes, etc)
	  Note: Experimental support

endchoice

config ARCH
	string
	default "x86_64" if ARCH_X86_64
	default "arm" if ARCH_ARM32
	default "arm64" if ARCH_ARM64
	default "riscv64" if ARCH_RISCV64

endmenu

# ============================================================================
# Build and Compiler Configuration
# ============================================================================

menu "Build Configuration"

choice
	prompt "Build type"
	default BUILD_TYPE_DEBUG
	help
	  Select the build type.

	  This affects optimization level, debug symbols, and runtime checks.

config BUILD_TYPE_DEBUG
	bool "Debug"
	help
	  Debug build with no optimization and full debug symbols.

	  - Optimization: -O0
	  - Debug symbols: -g
	  - Assertions: Enabled
	  - DEBUG macro: Defined (DEBUG=1, RELEASE=0)

	  Use for development and debugging.

config BUILD_TYPE_RELEASE
	bool "Release"
	help
	  Release build with optimization and no debug symbols.

	  - Optimization: -O2
	  - Debug symbols: None
	  - Assertions: Disabled
	  - RELEASE macro: Defined (RELEASE=1, DEBUG=0)

	  Use for production deployment.

config BUILD_TYPE_RELWITHDEBINFO
	bool "RelWithDebInfo"
	help
	  Release build with debug symbols.

	  - Optimization: -O2
	  - Debug symbols: -g
	  - Assertions: Disabled
	  - RELEASE macro: Defined (RELEASE=1, DEBUG=0)

	  Use for profiling and debugging optimized code.

config BUILD_TYPE_MINSIZEREL
	bool "MinSizeRel"
	help
	  Release build optimized for size.

	  - Optimization: -Os
	  - Debug symbols: None
	  - Assertions: Disabled
	  - RELEASE macro: Defined (RELEASE=1, DEBUG=0)

	  Use for storage-constrained systems.

endchoice

config BUILD_TYPE
	string
	default "Debug" if BUILD_TYPE_DEBUG
	default "Release" if BUILD_TYPE_RELEASE
	default "RelWithDebInfo" if BUILD_TYPE_RELWITHDEBINFO
	default "MinSizeRel" if BUILD_TYPE_MINSIZEREL

endmenu

menu "Compiler Flags"

config COMPILER_WARNINGS_AS_ERRORS
	bool "Treat warnings as errors (-Werror)"
	default y
	help
	  Enable -Werror flag to treat all compiler warnings as errors.

	  This ensures code quality by preventing compilation when
	  warnings are present.

	  Recommended for production code.

config COMPILER_WALL
	bool "Enable all warnings (-Wall)"
	default y
	help
	  Enable -Wall flag to show all common compiler warnings.

config COMPILER_WEXTRA
	bool "Enable extra warnings (-Wextra)"
	default n
	help
	  Enable -Wextra flag for additional compiler warnings.

config COMPILER_PEDANTIC
	bool "Enable pedantic warnings (-Wpedantic)"
	default n
	help
	  Enable -Wpedantic flag for strict ISO C compliance warnings.

config COMPILER_SANITIZER_ADDRESS
	bool "Enable AddressSanitizer"
	default n
	depends on BUILD_TYPE_DEBUG
	help
	  Enable AddressSanitizer for detecting memory errors.

	  Adds -fsanitize=address flag.

	  Note: This adds significant runtime overhead.
	  Only use for debugging and testing.

config COMPILER_SANITIZER_THREAD
	bool "Enable ThreadSanitizer"
	default n
	depends on BUILD_TYPE_DEBUG
	help
	  Enable ThreadSanitizer for detecting data races.

	  Adds -fsanitize=thread flag.

	  Note: Cannot be used with AddressSanitizer.

config COMPILER_SANITIZER_UNDEFINED
	bool "Enable UndefinedBehaviorSanitizer"
	default n
	depends on BUILD_TYPE_DEBUG
	help
	  Enable UndefinedBehaviorSanitizer for detecting undefined behavior.

	  Adds -fsanitize=undefined flag.

config COMPILER_COVERAGE
	bool "Enable code coverage (-fprofile-arcs -ftest-coverage)"
	default n
	depends on BUILD_TYPE_DEBUG
	help
	  Enable code coverage instrumentation for gcov/lcov.

	  Adds -fprofile-arcs -ftest-coverage flags.

config COMPILER_LTO
	bool "Enable Link Time Optimization (LTO)"
	default n
	depends on BUILD_TYPE_RELEASE || BUILD_TYPE_MINSIZEREL
	help
	  Enable Link Time Optimization for better performance.

	  Adds -flto flag.

	  Note: Increases build time significantly.

choice
	prompt "Optimization level"
	default COMPILER_OPT_DEFAULT
	help
	  Select compiler optimization level.

	  Different optimization levels trade off between code size,
	  compilation time, and runtime performance.

config COMPILER_OPT_DEFAULT
	bool "Default (based on build type)"
	help
	  Use optimization level based on build type:
	    Debug: -O0 (no optimization, best for debugging)
	    Release: -O2 (recommended for production)
	    RelWithDebInfo: -O2 (optimized with debug info)
	    MinSizeRel: -Os (optimize for size)

config COMPILER_OPT_O0
	bool "-O0: No optimization"
	help
	  Disable all optimization. Best for debugging.
	  Fastest compilation time.

	  Note: Requires CONFIG_COMPILER_DISABLE_FORTIFY_WITH_O0
	  in Buildroot/Yocto environments.

config COMPILER_OPT_O1
	bool "-O1: Basic optimization"
	help
	  Enable basic optimization that doesn't increase
	  compilation time significantly. Good balance for
	  debugging with some performance.

config COMPILER_OPT_O2
	bool "-O2: Recommended optimization"
	help
	  Enable most optimizations that don't involve a
	  space-speed tradeoff. Recommended for production.

config COMPILER_OPT_O3
	bool "-O3: Aggressive optimization"
	help
	  Enable all optimizations including those that may
	  increase code size. Maximum performance.

config COMPILER_OPT_OS
	bool "-Os: Optimize for size"
	help
	  Optimize for small code size. Good for embedded
	  systems with limited flash/ROM.

config COMPILER_OPT_OFAST
	bool "-Ofast: Maximum speed (non-standard)"
	help
	  Enable all -O3 optimizations plus fast math.
	  May not conform to standards (e.g., IEEE 754).

config COMPILER_OPT_OG
	bool "-Og: Optimize for debugging"
	help
	  Optimize while maintaining good debugging experience.
	  Better than -O0 performance, better than -O1 debugging.
	  Requires GCC 4.8+ or Clang 4.0+.

endchoice

config COMPILER_OPTIMIZATION_LEVEL
	string
	default "" if COMPILER_OPT_DEFAULT
	default "-O0" if COMPILER_OPT_O0
	default "-O1" if COMPILER_OPT_O1
	default "-O2" if COMPILER_OPT_O2
	default "-O3" if COMPILER_OPT_O3
	default "-Os" if COMPILER_OPT_OS
	default "-Ofast" if COMPILER_OPT_OFAST
	default "-Og" if COMPILER_OPT_OG

config COMPILER_DEBUG_LEVEL
	string "Debug information level"
	default "-g" if BUILD_TYPE_DEBUG || BUILD_TYPE_RELWITHDEBINFO
	default ""
	help
	  Debug information level flag.

	  Options:
	    -g   : Default debug info
	    -g3  : Maximum debug info (includes macro definitions)
	    -ggdb: GDB-specific debug info
	    (empty): No debug info

config COMPILER_DISABLE_FORTIFY_WITH_O0
	bool "Disable _FORTIFY_SOURCE when using -O0"
	default y
	help
	  Automatically disable _FORTIFY_SOURCE macro when compiling
	  with -O0 optimization level.

	  _FORTIFY_SOURCE is a glibc feature that adds compile-time and
	  runtime checks for buffer overflows. However, it requires
	  optimization (-O1 or higher) to work properly.

	  This option is essential for Buildroot/Yocto/embedded toolchains
	  that automatically add -D_FORTIFY_SOURCE=2, which conflicts with
	  debug builds using -O0.

	  When enabled, adds -U_FORTIFY_SOURCE flag automatically when
	  CONFIG_BUILD_TYPE_DEBUG uses -O0.

	  Recommended: Keep enabled for cross-compilation environments.
	  Disable only if you're sure your toolchain doesn't add
	  _FORTIFY_SOURCE automatically.

config COMPILER_CUSTOM_C_FLAGS
	string "Custom C flags"
	default ""
	help
	  Additional custom C compiler flags.

	  These flags are appended to the default flags.

	  Example: -fno-strict-aliasing -Wno-unused-parameter

config COMPILER_CUSTOM_CXX_FLAGS
	string "Custom C++ flags"
	default ""
	help
	  Additional custom C++ compiler flags.

	  These flags are appended to the default flags.

config COMPILER_CUSTOM_LINK_FLAGS
	string "Custom linker flags"
	default ""
	help
	  Additional custom linker flags.

	  Example: -Wl,--gc-sections -Wl,--print-memory-usage

endmenu

menu "Runtime Configuration"

config ENABLE_ASSERT
	bool "Enable assertions"
	default y if BUILD_TYPE_DEBUG
	default n
	help
	  Enable runtime assertions.

	  When disabled, defines NDEBUG macro to remove assert() checks.

config STACK_PROTECTOR
	bool "Enable stack protector"
	default y if BUILD_TYPE_DEBUG || BUILD_TYPE_RELEASE
	default n
	help
	  Enable stack overflow protection.

	  Adds -fstack-protector-strong flag.

config POSITION_INDEPENDENT_CODE
	bool "Generate position independent code (PIC)"
	default y
	help
	  Generate position independent code for shared libraries.

	  Adds -fPIC flag.

config FORTIFY_SOURCE
	bool "Enable FORTIFY_SOURCE"
	default y if BUILD_TYPE_RELEASE
	default n
	help
	  Enable compile-time and runtime buffer overflow protection.

	  Defines _FORTIFY_SOURCE=2.

	  Only effective with optimization level >= -O1.

endmenu

menu "Toolchain"

config TOOLCHAIN_PATH
	string "Toolchain path"
	default ""
	help
	  Absolute path to the cross-compilation toolchain.
	  Leave empty to use system default compiler.

	  Example: /opt/toolchains/gcc-arm-11.2/bin

config TOOLCHAIN_PREFIX
	string "Toolchain prefix"
	default "aarch64-linux-gnu-" if ARCH_ARM64
	default "arm-linux-gnueabihf-" if ARCH_ARM32
	default ""
	help
	  Toolchain prefix for cross-compilation.

	  Examples:
	    ARM64: aarch64-linux-gnu- or aarch64-none-linux-gnu-
	    ARM32: arm-linux-gnueabihf-
	    x86_64: Leave empty for native compilation

endmenu

endmenu

# ============================================================================
# Core Components Configuration
# ============================================================================
# Configure SDK core components that are shared across all products.
# These components provide fundamental abstractions and services.
# ============================================================================

source "core/Config.in"

# ============================================================================
# Product-Specific Configuration
# ============================================================================
# Each enabled product's configuration menu appears here.
# Product configurations are only shown if the product is enabled above.
# ============================================================================

menu "Product Configuration"

if PRODUCT_CCM
	source "products/ccm/Config.in"
endif

# if PRODUCT_SAMPLE
# 	osource "products/sample/Config.in"
# endif

endmenu

# ============================================================================
# Testing Configuration
# ============================================================================
# Configure test suite and test modules.
# Tests are only available when BUILD_TESTING is enabled.
# ============================================================================

config BUILD_TESTING
	bool "Build test suite"
	default n
	help
	  Enable building of test suite.

	  This option controls whether the test framework and test cases
	  are compiled. Tests include:
	  - Unit tests for individual modules
	  - Performance tests for benchmarking
	  - Stress tests for stability validation
	  - System tests for integration testing

if BUILD_TESTING
	menu "Test Configuration"
		source "products/tests/Config.in"
	endmenu
endif
