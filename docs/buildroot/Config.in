config BR2_PACKAGE_LPF
	bool "lpf"
	depends on BR2_LINUX_KERNEL
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on BR2_USE_MMU
	depends on BR2_INSTALL_LIBSTDCPP
	help
	  LPF is a generic Linux peripheral framework
	  with a Kconfig+CMake/Kbuild build system. It provides OSAL,
	  LPF HW, LPF Core, LPF peripheral runtime, PDI, ACONFIG, and
	  runtime configuration layers for Linux systems.

if BR2_PACKAGE_LPF

config BR2_PACKAGE_LPF_DEFCONFIG
	string "Kconfig defconfig to use"
	default "kernel_x86_modules_defconfig"
	help
	  Specify which LPF configuration to use.
	  Defconfigs are provided under configs/.

choice
	prompt "Build type"
	default BR2_PACKAGE_LPF_BUILD_TYPE_RELEASE

config BR2_PACKAGE_LPF_BUILD_TYPE_RELEASE
	bool "Release"

config BR2_PACKAGE_LPF_BUILD_TYPE_DEBUG
	bool "Debug"

config BR2_PACKAGE_LPF_BUILD_TYPE_RELWITHDEBINFO
	bool "RelWithDebInfo"

endchoice

config BR2_PACKAGE_LPF_BUILD_TYPE
	string
	default "Release" if BR2_PACKAGE_LPF_BUILD_TYPE_RELEASE
	default "Debug" if BR2_PACKAGE_LPF_BUILD_TYPE_DEBUG
	default "RelWithDebInfo" if BR2_PACKAGE_LPF_BUILD_TYPE_RELWITHDEBINFO

config BR2_PACKAGE_LPF_INSTALL_HEADERS
	bool "Install development headers"
	default n
	help
	  Install development headers to $(STAGING_DIR)/usr/include/.
	  Only needed for packages that depend on LPF.

config BR2_PACKAGE_LPF_MENUCONFIG
	bool "Enable interactive menuconfig"
	help
	  Add host-kconfig-frontends dependency to enable interactive
	  configuration via 'make lpf-menuconfig'.

endif # BR2_PACKAGE_LPF

comment "LPF needs Linux kernel and a toolchain w/ threads, C++, MMU"
	depends on !BR2_LINUX_KERNEL || !BR2_TOOLCHAIN_HAS_THREADS || \
		!BR2_USE_MMU || !BR2_INSTALL_LIBSTDCPP
