config BR2_PACKAGE_ES_MIDDLEWARE
	bool "es-middleware"
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on BR2_USE_MMU
	depends on BR2_INSTALL_LIBSTDCPP
	help
	  ES-Middleware is an embedded software middleware framework
	  with Kconfig+CMake build system. It provides OSAL, HAL, PDL,
	  PRL, ACONFIG, and PCONFIG layers for embedded systems.

	  Target platforms: TI SITARA AM62x series

	  https://github.com/your-org/ES-Middleware

if BR2_PACKAGE_ES_MIDDLEWARE

config BR2_PACKAGE_ES_MIDDLEWARE_DEFCONFIG
	string "Kconfig defconfig to use"
	default "tests_arm64_full_defconfig"
	help
	  Specify which ES-Middleware configuration to use.

	  Test configurations (configs/tests/):
	  - tests_arm64_full_defconfig            (All modules, recommended for development)
	  - tests_arm64_hal_defconfig             (HAL development)
	  - tests_arm64_minimal_defconfig         (Minimal footprint)

	  Production configurations (configs/pmc/):
	  - pmc_h200_100p_am625_release_defconfig (Production, optimized)
	  - pmc_h200_100p_am625_debug_defconfig   (Development, with debug)

	  See ES-Middleware/configs/ for all 21 available configurations.

choice
	prompt "Build type"
	default BR2_PACKAGE_ES_MIDDLEWARE_BUILD_TYPE_RELEASE
	help
	  Select the CMake build type.

config BR2_PACKAGE_ES_MIDDLEWARE_BUILD_TYPE_RELEASE
	bool "Release"

config BR2_PACKAGE_ES_MIDDLEWARE_BUILD_TYPE_DEBUG
	bool "Debug"

config BR2_PACKAGE_ES_MIDDLEWARE_BUILD_TYPE_RELWITHDEBINFO
	bool "RelWithDebInfo"

endchoice

config BR2_PACKAGE_ES_MIDDLEWARE_BUILD_TYPE
	string
	default "Release" if BR2_PACKAGE_ES_MIDDLEWARE_BUILD_TYPE_RELEASE
	default "Debug" if BR2_PACKAGE_ES_MIDDLEWARE_BUILD_TYPE_DEBUG
	default "RelWithDebInfo" if BR2_PACKAGE_ES_MIDDLEWARE_BUILD_TYPE_RELWITHDEBINFO

config BR2_PACKAGE_ES_MIDDLEWARE_INSTALL_INIT
	bool "Install init scripts"
	default n
	help
	  Install SysV init scripts for PMC applications.

config BR2_PACKAGE_ES_MIDDLEWARE_INSTALL_HEADERS
	bool "Install development headers"
	default n
	help
	  Install development headers to $(STAGING_DIR)/usr/include/.
	  Only needed for developing packages that depend on ES-Middleware.

config BR2_PACKAGE_ES_MIDDLEWARE_MENUCONFIG
	bool "Enable interactive menuconfig"
	help
	  Add host-kconfig-frontends dependency to enable interactive
	  configuration via 'make es-middleware-menuconfig'.

endif # BR2_PACKAGE_ES_MIDDLEWARE

comment "ES-Middleware needs a toolchain w/ threads, C++, MMU"
	depends on !BR2_TOOLCHAIN_HAS_THREADS || !BR2_USE_MMU || \
		!BR2_INSTALL_LIBSTDCPP
