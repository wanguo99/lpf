#!/bin/sh
#
# EMS 启动脚本 (SysV init)
#

DAEMON="ems-sample-app"
PIDFILE="/var/run/$DAEMON.pid"
CONFIG="/etc/ems.conf"

# 读取配置文件
[ -r "$CONFIG" ] && . "$CONFIG"

start() {
	printf "Starting EMS: "

	# 检查配置文件
	if [ ! -f "$CONFIG" ]; then
		echo "FAIL (config not found)"
		exit 1
	fi

	# 启动守护进程
	start-stop-daemon -S -q -b -m -p "$PIDFILE" -x /usr/bin/$DAEMON

	if [ $? -eq 0 ]; then
		echo "OK"
	else
		echo "FAIL"
		exit 1
	fi
}

stop() {
	printf "Stopping EMS: "
	start-stop-daemon -K -q -p "$PIDFILE"

	if [ $? -eq 0 ]; then
		rm -f "$PIDFILE"
		echo "OK"
	else
		echo "FAIL"
		exit 1
	fi
}

restart() {
	stop
	sleep 1
	start
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart|reload)
		restart
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
esac

exit 0
