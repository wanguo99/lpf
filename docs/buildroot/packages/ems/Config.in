config BR2_PACKAGE_EMS
	bool "ems"
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on !BR2_STATIC_LIBS
	help
	  EMS (Embedded Middleware System) is a lightweight embedded software
	  framework providing hardware abstraction and peripheral drivers.

	  Features:
	  - OSAL: Operating System Abstraction Layer
	  - HAL: Hardware Abstraction Layer (CAN, UART, I2C, SPI)
	  - PCL: Peripheral Configuration Library
	  - PDL: Peripheral Driver Layer
	  - PMC: Payload Management Controller (5-process application)

	  https://github.com/wanguo99/EMS

config BR2_PACKAGE_EMS_SAMPLE_APP
	bool "install sample application"
	depends on BR2_PACKAGE_EMS
	default y
	help
	  Install the EMS sample application to /usr/bin/sample_app

config BR2_PACKAGE_EMS_PMC
	bool "install PMC application"
	depends on BR2_PACKAGE_EMS
	default y
	help
	  Install PMC (Payload Management Controller) application.

	  PMC is a 5-process architecture application:
	  - pmc_comm: Communication process
	  - pmc_collector: Data collection process
	  - pmc_health: Health monitoring process
	  - pmc_supervisor: Process supervisor
	  - pmc_logger: Log management process

config BR2_PACKAGE_EMS_TESTS
	bool "install unit tests"
	depends on BR2_PACKAGE_EMS
	help
	  Build and install the EMS unit test suite to /usr/bin/ems-test

comment "ems needs a toolchain w/ threads, dynamic library"
	depends on !BR2_TOOLCHAIN_HAS_THREADS || BR2_STATIC_LIBS
