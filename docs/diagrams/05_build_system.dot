digraph Build_System {
    rankdir=TB;
    node [shape=box, style=filled, fontname="Arial"];

    // 用户操作
    user [label="开发者", shape=actor, fillcolor="#E8F5E9"];

    // 配置选择
    config_select [label="选择配置\npython3 build.py config\nccm_h200p100_debug_defconfig", fillcolor="#FFF3E0"];

    // Kconfig 处理
    subgraph cluster_kconfig {
        label="Kconfig 配置系统";
        style=filled;
        fillcolor="#E3F2FD";

        defconfig [label="defconfig 文件\nconfigs/*.defconfig"];
        kconfig [label="Kconfig 规则\n各模块 Kconfig"];
        menuconfig [label="menuconfig\n图形化配置 (可选)", style=dashed];
        dotconfig [label=".config 文件\n当前配置"];

        defconfig -> dotconfig [label="加载"];
        kconfig -> menuconfig [label="定义选项"];
        menuconfig -> dotconfig [label="用户修改", style=dashed];
    }

    // CMake 构建
    subgraph cluster_cmake {
        label="CMake 构建系统";
        style=filled;
        fillcolor="#F3E5F5";

        cmake_main [label="CMakeLists.txt\n顶层构建文件"];
        kconfig_cmake [label="Kconfig.cmake\n读取 .config"];
        cmake_vars [label="CMake 变量\nCONFIG_*"];
        cmake_targets [label="构建目标\nOSAL, HAL, PDL..."];

        cmake_main -> kconfig_cmake [label="包含"];
        dotconfig -> kconfig_cmake [label="读取"];
        kconfig_cmake -> cmake_vars [label="生成"];
        cmake_vars -> cmake_targets [label="条件编译"];
    }

    // 编译
    compile [label="编译\npython3 build.py build\ncmake --build _build", fillcolor="#C5E1A5"];

    // 输出
    output [label="输出产物\n_build/bin/*\n_build/lib/*", fillcolor="#FFF9C4", shape=folder];

    // 流程
    user -> config_select;
    config_select -> defconfig;
    user -> menuconfig [label="高级用户", style=dashed];
    user -> compile;
    cmake_targets -> compile;
    compile -> output;

    // 配置选项示例
    config_examples [shape=note, label="配置示例：\n\n产品配置：\n• ccm_h200p100_debug_defconfig\n• ccm_h200p100_release_defconfig\n\n测试配置：\n• tests_x86_full_defconfig\n• tests_x86_pdl_defconfig\n• tests_x86_minimal_defconfig\n\n配置选项：\n• CONFIG_OSAL=y\n• CONFIG_HAL=y\n• CONFIG_PDL=y\n• CONFIG_PRL_MCU=y\n• CONFIG_BUILD_TESTING=y", fillcolor="#FFFDE7"];

    // 特性
    features [shape=note, label="构建系统特性：\n• 图形化配置 (menuconfig)\n• 功能裁剪 (Kconfig)\n• 并行编译 (CMake)\n• 场景化配置 (defconfig)\n• 多产品支持", fillcolor="#E1F5FE"];
}
