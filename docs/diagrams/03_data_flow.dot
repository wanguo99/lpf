digraph Data_Flow {
    rankdir=LR;
    node [shape=box, style=filled, fontname="Arial"];

    // 遥控命令流程
    subgraph cluster_telecommand {
        label="遥控命令流程 (Telecommand Flow)";
        fillcolor="#E8F5E9";
        style=filled;

        tc_app [label="应用层\nCollector"];
        tc_aconfig [label="AConfig\n查询设备映射\nTC_POWER_ON → BMC[0]", fillcolor="#FFF3E0"];
        tc_pdl [label="PDL_BMC\n调用 BMC 驱动"];
        tc_prl [label="PRL\n编码协议报文", fillcolor="#F3E5F5"];
        tc_hal [label="HAL_UART\n发送数据", fillcolor="#FFEBEE"];
        tc_hw [label="硬件设备\nBMC", shape=cylinder];

        tc_app -> tc_aconfig [label="1. 查询"];
        tc_aconfig -> tc_pdl [label="2. 映射"];
        tc_pdl -> tc_prl [label="3. 编码"];
        tc_prl -> tc_hal [label="4. 传输"];
        tc_hal -> tc_hw [label="5. 发送"];

        tc_hw -> tc_hal [label="6. 响应", style=dashed];
        tc_hal -> tc_prl [label="7. 接收", style=dashed];
        tc_prl -> tc_pdl [label="8. 解码", style=dashed];
        tc_pdl -> tc_aconfig [label="9. 失效缓存", style=dashed];
        tc_aconfig -> tc_app [label="10. 返回结果", style=dashed];
    }

    // 遥测数据流程
    subgraph cluster_telemetry {
        label="遥测数据流程 (Telemetry Flow)";
        fillcolor="#E3F2FD";
        style=filled;

        tm_app [label="应用层\nLogger"];
        tm_aconfig [label="AConfig\n查询数据类型\nTM_CPU_TEMP → BMC[0]\n缓存型/实时型", fillcolor="#FFF3E0"];
        tm_cache [label="共享内存\n遥测缓存", shape=cylinder, fillcolor="#FFF9C4"];
        tm_pdl [label="PDL_BMC\n查询 BMC"];
        tm_prl [label="PRL\n编解码", fillcolor="#F3E5F5"];
        tm_hal [label="HAL_UART\n收发数据", fillcolor="#FFEBEE"];
        tm_hw [label="硬件设备\nBMC", shape=cylinder];

        tm_app -> tm_aconfig [label="1. 查询"];
        tm_aconfig -> tm_cache [label="2a. 缓存型\n直接读取", style=dashed];
        tm_cache -> tm_app [label="3a. 返回(<10μs)", style=dashed];

        tm_aconfig -> tm_pdl [label="2b. 实时型\n查询设备"];
        tm_pdl -> tm_prl [label="3b. 编码"];
        tm_prl -> tm_hal [label="4. 发送"];
        tm_hal -> tm_hw [label="5. 请求"];
        tm_hw -> tm_hal [label="6. 响应"];
        tm_hal -> tm_prl [label="7. 接收"];
        tm_prl -> tm_pdl [label="8. 解码"];
        tm_pdl -> tm_app [label="9. 返回"];

        // 后台更新
        tm_hw -> tm_pdl [label="周期上报", style=dotted, color=gray];
        tm_pdl -> tm_cache [label="更新缓存", style=dotted, color=gray];
    }

    note [shape=note, label="性能指标：\n• 缓存型遥测：<10μs\n• 实时型遥测：<1ms (超时降级到缓存)\n• 遥控命令：<10ms", fillcolor="#FFFDE7"];
}
