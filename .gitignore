# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# 但不忽略构建框架文件
!scripts/build/*.ko

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# 但不忽略构建框架文件
!scripts/build/*.lib

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# 但不忽略构建框架文件
!scripts/build/*.dll

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# 但不忽略构建框架文件
!scripts/build/*.app

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# debug information files
*.dwo

# claude
.claude/

# 构建输出目录（参考buildroot设计）
output/
/build/
target/
/bin/
/lib/

# 但不忽略构建脚本目录
!scripts/build/

*.DS_Store

# Kconfig generated files
.config
.config.old
include/config/
include/generated/

# Kconfig tools (built binaries)
scripts/kconfig/conf
scripts/kconfig/mconf
scripts/kconfig/nconf
scripts/kconfig/*.o
scripts/kconfig/lxdialog/*.o
scripts/kconfig/parser.tab.c
scripts/kconfig/parser.tab.h
scripts/kconfig/lexer.lex.c
scripts/kconfig/.*.cmd
scripts/kconfig/*.cmd

